# IAO Architecture — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to Git

# ─── Smartsheet API ──────────────────────────────────────────
SMARTSHEET_TOKEN=your_smartsheet_token_here

# ─── IAPM (Azure AD Bearer token) ───────────────────────────
# Get from browser: F12 > Console >
#   Object.entries(localStorage).find(([k,v])=>k.includes('accesstoken'))
IAPM_BEARER_TOKEN=

# ─── BIC Process Design ─────────────────────────────────────
# Get from browser: F12 > Network > filter XHR > copy Authorization header
BIC_AUTH_TOKEN=

# ─── SAP S/4HANA OData — Intel Foundry (BI0) ────────────────
SAP_BI0_HOST=https://sapbi0ci.intel.com:8220
SAP_BI0_CLIENT=200
SAP_BI0_USER=
SAP_BI0_PASS=
SAP_BI0_AUTH_METHOD=negotiate

# ─── SAP S/4HANA OData — Intel Products (DI0) ───────────────
SAP_DI0_HOST=https://sapdi0ci.intel.com:8220
SAP_DI0_CLIENT=200
SAP_DI0_USER=
SAP_DI0_PASS=
SAP_DI0_AUTH_METHOD=negotiate

# ─── SharePoint Online (for document sync) ──────────────────
# Register an Azure AD app: Azure Portal > App Registrations
# API permissions: Microsoft Graph > Sites.ReadWrite.All
SP_TENANT_ID=
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_SITE_URL=https://intel.sharepoint.com/sites/IAO-Architecture
SP_DOC_LIBRARY=Shared Documents
SP_TARGET_FOLDER=Architecture/SAD

# ─── JIRA (Test Management & Defect Tracking) ──────────────
JIRA_BASE_URL=https://jira.intel.com
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# ─── GitHub Actions ─────────────────────────────────────────
# Set all the above as GitHub Secrets (Settings > Secrets > Actions)
# GITHUB_TOKEN is auto-provided by Actions
