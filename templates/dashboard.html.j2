<!-- ============================================================ -->
<!--  PLOTLY DATA & RENDER (with client-side filtering)            -->
<!-- ============================================================ -->
<script>
// ---- Injected data ----
var ALL_TOWERS = {{ towers_json }};
var RAW_OBJS   = {{ raw_objects_json }};
var DOC_INV    = {{ doc_inventory_json }};
var towerUrls  = {{ tower_urls_json }};
var capUrls    = {{ cap_urls_json }};
var IS_TOWER   = {{ 'true' if tower_filter else 'false' }};
var AVAIL_REL  = {{ available_releases_json }};
var ARCH_DATA  = {{ arch_json | default('{}') }};
var TESTING_DATA = {{ testing_json | default('{}') }};
var activeRelease = 'All';  // global release filter state
var activePillar = 'architecture';  // default visible pillar

// ---- Constants ----
var COLORS = {
  completed:'#34a853', active:'#0071c5', rejected:'#ea4335',
  phases:['#0071c5','#00aeef','#34a853','#fbbc04'],
  tower:['#0071c5','#00395d','#00aeef','#34a853','#fbbc04','#ea4335','#8e44ad','#e67e22']
};
var TC = ['I','C','E','R','F','W'];
var TL = {I:'Interface',C:'Conversion',E:'Enhancement',R:'Report',F:'Form',W:'Workflow'};
var TCOL = {I:'#0071c5',C:'#00aeef',E:'#34a853',R:'#fbbc04',F:'#8e44ad',W:'#e67e22'};
var SCOL = {Completed:'#34a853',Active:'#0071c5',Rejected:'#ea4335'};
var isMobile = window.innerWidth < 768;
var isTablet = window.innerWidth < 1024;
var chartFont = isMobile ? 10 : (isTablet ? 12 : 14);
var LB = {
  font:{family:'Segoe UI, system-ui, sans-serif',size:chartFont},
  margin:{l:isMobile?40:55, r:isMobile?15:30, t:isMobile?35:50, b:isMobile?45:60},
  paper_bgcolor:'rgba(0,0,0,0)', plot_bgcolor:'rgba(0,0,0,0)',
  hoverlabel:{bgcolor:'#fff',font:{size:13},bordercolor:'#ccc'},
  autosize:true
};
var CFG = {responsive:true, displayModeBar:false};
// Recalculate on resize
var _resizeTimer;
window.addEventListener('resize', function(){
  clearTimeout(_resizeTimer);
  _resizeTimer = setTimeout(function(){
    isMobile = window.innerWidth < 768;
    isTablet = window.innerWidth < 1024;
    chartFont = isMobile ? 10 : (isTablet ? 12 : 14);
    LB.font.size = chartFont;
    LB.margin = {l:isMobile?40:55, r:isMobile?15:30, t:isMobile?35:50, b:isMobile?45:60};
    applyFilters();
  }, 300);
});

// ---- Filter state ----
var selected = new Set();
(function(){
  if(!IS_TOWER) ALL_TOWERS.forEach(function(t){selected.add(t.short)});
  else DOC_INV.forEach(function(d){selected.add(d.cap_id)});
})();

// ---- Filtered accessors ----
// ---- Filtered accessors (respect both tower/capability chips AND release dropdown) ----
function fObjs(){
  var objs = RAW_OBJS;
  if(activeRelease !== 'All') objs = objs.filter(function(o){ return o.r === activeRelease; });
  if(IS_TOWER) return objs;
  return objs.filter(function(o){return selected.has(o.t)});
}
function fTowers(){
  // When release filter is active, re-derive tower stats from filtered objects
  var objs = fObjs();
  if(activeRelease === 'All'){
    if(IS_TOWER) return ALL_TOWERS;
    return ALL_TOWERS.filter(function(t){return selected.has(t.short)});
  }
  // Build synthetic tower stats from filtered objects
  var tMap = {};
  objs.forEach(function(o){
    if(!tMap[o.t]) tMap[o.t] = {short:o.t,total:0,completed:0,active:0,rejected:0,
      raid_count:0,avg_fs:0,avg_tdd:0,avg_build:0,avg_fut:0,
      interfaces:0,conversions:0,enhancements:0,reports:0,forms:0,workflows:0,
      sad_count:0,ricefw_doc_count:0,testing_doc_count:0};
    var t = tMap[o.t];
    t.total++;
    if(o.s===1) t.completed++;
    else if(o.s===2) t.rejected++;
    else t.active++;
    var tc = o.tc;
    if(tc==='I') t.interfaces++;
    else if(tc==='C') t.conversions++;
    else if(tc==='E') t.enhancements++;
    else if(tc==='R') t.reports++;
    else if(tc==='F') t.forms++;
    else if(tc==='W') t.workflows++;
  });
  // Apply tower/cap chip filter
  var result = [];
  var keys = IS_TOWER ? Object.keys(tMap) : Object.keys(tMap).filter(function(k){return selected.has(k)});
  keys.forEach(function(k){
    // Merge raid count from original data
    var orig = ALL_TOWERS.find(function(t){return t.short===k});
    if(orig) tMap[k].raid_count = orig.raid_count;
    result.push(tMap[k]);
  });
  return result;
}

// ---- KPI update ----
function updateKPIs(twrs){
  var tot=0,comp=0,act=0,rej=0,raids=0,bW=0,fW=0,n=0;
  twrs.forEach(function(t){
    tot+=t.total; comp+=t.completed; act+=t.active; rej+=t.rejected;
    raids+=t.raid_count; bW+=t.avg_build*t.total; fW+=t.avg_fut*t.total; n+=t.total;
  });
  var capSet=new Set();
  DOC_INV.forEach(function(d){
    if(!IS_TOWER){ if(selected.has(d.tower)) capSet.add(d.cap_id); }
    else{ if(selected.has(d.cap_id)) capSet.add(d.cap_id); }
  });
  var devSection=document.getElementById('pillar-development');
  if(devSection){
    var cards=devSection.querySelectorAll('.kpi-card .value');
    if(cards.length>=8){
      cards[0].textContent=tot;
      cards[1].textContent=(tot?Math.round(comp/tot*100):0)+'%';
      cards[2].textContent=act;
      cards[3].textContent=twrs.length;
      cards[4].textContent=capSet.size;
      cards[5].textContent=(n?Math.round(bW/n):0)+'%';
      cards[6].textContent=(n?Math.round(fW/n):0)+'%';
      cards[7].textContent=raids;
    }
  }
}

// ---- Chart 1: RICEFW by Tower — Stacked Bar ----
function renderTowerBar(twrs){
  var nm=twrs.map(function(t){return t.short});
  Plotly.react('chart-tower-bar',[
    {x:nm,y:twrs.map(function(t){return t.completed}),name:'Completed',type:'bar',marker:{color:COLORS.completed},
     text:twrs.map(function(t){return t.completed||''}),textposition:'inside',textfont:{size:isMobile?9:11,color:'#fff'}},
    {x:nm,y:twrs.map(function(t){return t.active}),name:'Active',type:'bar',marker:{color:COLORS.active},
     text:twrs.map(function(t){return t.active||''}),textposition:'inside',textfont:{size:isMobile?9:11,color:'#fff'}},
    {x:nm,y:twrs.map(function(t){return t.rejected}),name:'Rejected',type:'bar',marker:{color:COLORS.rejected},
     text:twrs.map(function(t){return t.rejected||''}),textposition:'inside',textfont:{size:isMobile?9:11,color:'#fff'}}
  ],Object.assign({},LB,{title:{text:'RICEFW Objects by Tower',font:{size:isMobile?12:14,color:'#202124'}},barmode:'stack',
    xaxis:{title:'',tickfont:{size:isMobile?9:12},tickangle:isMobile?-45:0,automargin:true},
    yaxis:{title:'Objects',titlefont:{size:isMobile?10:12},tickfont:{size:isMobile?9:11}},
    legend:{orientation:'h',y:-0.2,font:{size:isMobile?10:12}},
    bargap:0.15}),CFG);
}

// ---- Chart 2: Completion Donut ----
function renderDonut(twrs){
  var c=0,a=0,r=0;
  twrs.forEach(function(t){c+=t.completed;a+=t.active;r+=t.rejected});
  var total=c+a+r;
  Plotly.react('chart-completion-pie',[{
    values:[c,a,r],labels:['Completed','Active','Rejected'],type:'pie',hole:0.5,
    marker:{colors:[COLORS.completed,COLORS.active,COLORS.rejected],line:{color:'#fff',width:2}},
    textinfo:'percent',textposition:'inside',textfont:{size:isMobile?11:13,color:'#fff'},
    insidetextorientation:'horizontal',
    hovertemplate:'<b>%{label}</b><br>%{value} objects (%{percent})<extra></extra>',
    pull:[0.02,0,0]
  }],Object.assign({},LB,{title:{text:'Overall Completion',font:{size:isMobile?12:14,color:'#202124'}},
    showlegend:true,legend:{orientation:'h',y:-0.15,font:{size:isMobile?10:12}},
    margin:{l:20,r:20,t:isMobile?35:50,b:isMobile?50:60},
    annotations:[{text:'<b>'+total+'</b><br>Total',showarrow:false,font:{size:isMobile?14:18,color:'#202124'},x:0.5,y:0.5}]}),CFG);
}

// ---- Chart 3: Build Phases by Tower — Grouped Bar ----
function renderPhaseBar(twrs){
  var nm=twrs.map(function(t){return t.short});
  var pL=['FS %','TDD %','Build %','FUT %'], pK=['avg_fs','avg_tdd','avg_build','avg_fut'];
  var traces=pK.map(function(k,i){
    return{x:nm,y:twrs.map(function(t){return t[k]}),name:pL[i],type:'bar',marker:{color:COLORS.phases[i]},
      text:twrs.map(function(t){return t[k]?t[k]+'%':''}),textposition:'outside',textfont:{size:isMobile?8:10},
      hovertemplate:'<b>%{x}</b><br>'+pL[i]+': %{y}%<extra></extra>'};
  });
  Plotly.react('chart-phases',traces,Object.assign({},LB,{title:{text:'Build Phase Progress by Tower',font:{size:isMobile?12:14,color:'#202124'}},barmode:'group',
    xaxis:{tickfont:{size:isMobile?9:12},tickangle:isMobile?-45:0,automargin:true},
    yaxis:{title:'%',range:[0,110],titlefont:{size:isMobile?10:12},tickfont:{size:isMobile?9:11}},
    legend:{orientation:'h',y:-0.2,font:{size:isMobile?9:12}},
    bargap:0.15,bargroupgap:0.08}),CFG);
}

// ---- Chart 4: Type Distribution — Horizontal Bar (replaces pie for better readability) ----
function renderTypePie(objs){
  var cnt={}; TC.forEach(function(c){cnt[c]=0});
  objs.forEach(function(o){if(cnt[o.tc]!==undefined)cnt[o.tc]++});
  var lb=[],vl=[],cl=[];
  TC.forEach(function(c){if(cnt[c]>0){lb.push(TL[c]);vl.push(cnt[c]);cl.push(TCOL[c]||'#999')}});
  // Horizontal bar chart — avoids label overlaps that plague pie charts
  Plotly.react('chart-type-pie',[{
    y:lb.reverse(),x:vl.reverse(),type:'bar',orientation:'h',
    marker:{color:cl.reverse(),line:{color:'#fff',width:1}},
    text:vl.map(function(v){return v+' objects'}),textposition:'outside',textfont:{size:isMobile?10:12},
    hovertemplate:'<b>%{y}</b>: %{x} objects<extra></extra>'
  }],Object.assign({},LB,{title:{text:'RICEFW by Object Type',font:{size:isMobile?12:14,color:'#202124'}},
    xaxis:{title:'Count',titlefont:{size:isMobile?10:12},tickfont:{size:isMobile?9:11}},
    yaxis:{tickfont:{size:isMobile?10:13},automargin:true},
    margin:{l:isMobile?90:110,r:isMobile?40:60,t:isMobile?35:50,b:40},
    showlegend:false}),CFG);
}

// ---- Chart 5: Sankey ----
function renderSankey(twrs,objs){
  var tL=twrs.map(function(t){return t.short});
  var tyL=['Interface','Conversion','Enhancement','Report','Form','Workflow'];
  var sL=['Completed','Active','Rejected'];
  var all=tL.concat(tyL).concat(sL);
  var allC=tL.map(function(_,i){return COLORS.tower[i%COLORS.tower.length]})
    .concat(tyL.map(function(l){return TCOL[l[0]]||'#999'}))
    .concat(sL.map(function(s){return SCOL[s]}));
  var idx={}; all.forEach(function(l,i){idx[l]=i});
  var src=[],tgt=[],val=[],col=[];
  var tSet=new Set(tL);
  twrs.forEach(function(t){
    var to=objs.filter(function(o){return o.t===t.short});
    var tc={}; to.forEach(function(o){tc[o.tc]=(tc[o.tc]||0)+1});
    [['I','Interface'],['C','Conversion'],['E','Enhancement'],['R','Report'],['F','Form'],['W','Workflow']].forEach(function(p){
      var n=tc[p[0]]||0;
      if(n){src.push(idx[t.short]);tgt.push(idx[p[1]]);val.push(n);col.push((TCOL[p[0]]||'#ccc')+'55')}
    });
  });
  [['Interface','I'],['Conversion','C'],['Enhancement','E'],['Report','R'],['Form','F'],['Workflow','W']].forEach(function(p){
    var to=objs.filter(function(o){return o.tc===p[1]&&tSet.has(o.t)});
    var c=0,a=0,r=0;
    to.forEach(function(o){if(o.s===1)c++;else if(o.s===2)r++;else a++});
    if(c){src.push(idx[p[0]]);tgt.push(idx['Completed']);val.push(c);col.push('#34a85355')}
    if(a){src.push(idx[p[0]]);tgt.push(idx['Active']);val.push(a);col.push('#0071c555')}
    if(r){src.push(idx[p[0]]);tgt.push(idx['Rejected']);val.push(r);col.push('#ea433555')}
  });
  if(!all.length) return;
  Plotly.react('chart-sankey',[{
    type:'sankey',orientation:'h',
    node:{label:all,color:allC,pad:isMobile?10:20,thickness:isMobile?15:22,
      line:{color:'#ddd',width:0.5}},
    link:{source:src,target:tgt,value:val,color:col},
    textfont:{size:isMobile?9:12,color:'#202124'}
  }],Object.assign({},LB,{title:{text:'Object Flow: Tower \u2192 Type \u2192 Status',font:{size:isMobile?12:14,color:'#202124'}},
    margin:{l:isMobile?5:10,r:isMobile?5:10,t:isMobile?35:45,b:isMobile?5:10}}),CFG);
}

// ---- Chart 6: RAID by Tower — Bar ----
function renderRaidBar(twrs){
  var nm=twrs.map(function(t){return t.short});
  var rd=twrs.map(function(t){return t.raid_count});
  var cl=rd.map(function(v){return v>20?COLORS.rejected:v>10?'#fbbc04':COLORS.completed});
  Plotly.react('chart-raids',[{
    x:nm,y:rd,type:'bar',marker:{color:cl,line:{color:'rgba(0,0,0,.1)',width:1}},
    text:rd.map(String),textposition:'outside',textfont:{size:isMobile?10:12},
    hovertemplate:'<b>%{x}</b>: %{y} RAID items<extra></extra>'
  }],Object.assign({},LB,{title:{text:'Open RAID Items by Tower',font:{size:isMobile?12:14,color:'#202124'}},
    xaxis:{tickfont:{size:isMobile?9:12},tickangle:isMobile?-45:0,automargin:true},
    yaxis:{title:'RAID Count',titlefont:{size:isMobile?10:12},tickfont:{size:isMobile?9:11},
      range:[0,Math.max.apply(null,rd)*1.15||10]},
    showlegend:false}),CFG);
}

// ---- Chart 7: Completion by Type — Line + value annotations ----
function renderTypeLine(objs){
  var cnt={},comp={};
  TC.forEach(function(c){cnt[c]=0;comp[c]=0});
  objs.forEach(function(o){if(cnt[o.tc]!==undefined){cnt[o.tc]++;if(o.s===1)comp[o.tc]++}});
  var lb=[],pc=[];
  TC.forEach(function(c){if(cnt[c]>0){lb.push(TL[c]);pc.push(Math.round(comp[c]/cnt[c]*100))}});
  Plotly.react('chart-type-phases',[{
    x:lb,y:pc,name:'Completed %',mode:'lines+markers+text',
    line:{color:COLORS.completed,width:3,shape:'spline'},marker:{size:isMobile?8:10,color:COLORS.completed,line:{color:'#fff',width:2}},
    text:pc.map(function(v){return v+'%'}),textposition:'top center',textfont:{size:isMobile?10:12,color:'#202124'},
    fill:'tozeroy',fillcolor:'rgba(52,168,83,0.08)',
    hovertemplate:'<b>%{x}</b>: %{y}% completed<extra></extra>'
  }],Object.assign({},LB,{title:{text:'Completion Rate by Object Type',font:{size:isMobile?12:14,color:'#202124'}},
    xaxis:{tickfont:{size:isMobile?10:12},automargin:true},
    yaxis:{title:'%',range:[0,110],titlefont:{size:isMobile?10:12},tickfont:{size:isMobile?9:11}},
    showlegend:false}),CFG);
}

// ---- Table filtering ----
function filterDocTable(){
  document.querySelectorAll('.doc-table tbody tr[data-tower]').forEach(function(row){
    var tower=row.getAttribute('data-tower');
    var capId=row.getAttribute('data-cap');
    row.style.display = IS_TOWER ? (selected.has(capId)?'':'none') : (selected.has(tower)?'':'none');
  });
}
function filterRaidTable(){
  document.querySelectorAll('#raid-doc-table tbody tr[data-tower]').forEach(function(row){
    var tower=row.getAttribute('data-tower');
    row.style.display = (!IS_TOWER && !selected.has(tower)) ? 'none' : '';
  });
}

// ---- Click navigation on bar charts ----
function attachNav(){
  ['chart-tower-bar','chart-phases','chart-raids'].forEach(function(id){
    var div=document.getElementById(id);
    if(!div) return;
    div.on('plotly_click',function(data){
      var pt=data.points[0]; var key=pt.x||pt.label;
      if(towerUrls[key]) window.location.href=towerUrls[key];
    });
  });
}

// ---- Pillar tab switching ----
function switchPillar(pillar){
  activePillar = pillar;
  document.querySelectorAll('.pillar-section').forEach(function(s){
    s.classList.toggle('active', s.id === 'pillar-' + pillar);
  });
  document.querySelectorAll('.pillar-tab').forEach(function(t){
    t.classList.toggle('active', t.dataset.pillar === pillar);
  });
  // Trigger Plotly relayout so charts render at correct size in newly-visible section
  setTimeout(function(){ window.dispatchEvent(new Event('resize')); }, 50);
}
// Wire clicks
document.querySelectorAll('.pillar-tab').forEach(function(tab){
  tab.addEventListener('click', function(){ switchPillar(tab.dataset.pillar); });
});

// ---- Architecture charts ----
function renderArchCharts(){
  var ad = ARCH_DATA;
  if(!ad || !ad.towers) return;
  // Systems per tower bar
  var tNames = Object.keys(ad.towers);
  var sysCounts = tNames.map(function(t){ return ad.towers[t].systems || 0; });
  Plotly.react('arch-chart-systems',[{
    x:tNames, y:sysCounts, type:'bar', marker:{color:'#0071c5'},
    text:sysCounts.map(String), textposition:'outside', textfont:{size:isMobile?10:12}
  }],Object.assign({},LB,{title:{text:'Systems per Tower',font:{size:isMobile?12:14,color:'#202124'}},
    xaxis:{tickfont:{size:isMobile?9:12},automargin:true},
    yaxis:{title:'Systems',titlefont:{size:isMobile?10:12}},showlegend:false}),CFG);
  // Integration pattern pie
  var pats = ad.patterns || {};
  var patKeys = Object.keys(pats);
  if(patKeys.length){
    Plotly.react('arch-chart-patterns',[{
      labels:patKeys, values:patKeys.map(function(k){return pats[k]}),
      type:'pie', hole:0.4,
      marker:{colors:['#0071c5','#00aeef','#34a853','#fbbc04','#8e44ad','#e67e22','#ea4335','#00395d']},
      textinfo:'label+percent', textfont:{size:isMobile?10:12}
    }],Object.assign({},LB,{title:{text:'Integration Patterns',font:{size:isMobile?12:14,color:'#202124'}},
      showlegend:false,margin:{l:20,r:20,t:50,b:20}}),CFG);
  }
  // Lanes heatmap placeholder — use horizontal bar
  var lCounts = tNames.map(function(t){ return ad.towers[t].lanes || 0; });
  Plotly.react('arch-chart-lanes',[{
    y:tNames, x:lCounts, type:'bar', orientation:'h',
    marker:{color:'#00aeef'}, text:lCounts.map(String), textposition:'outside', textfont:{size:isMobile?10:12}
  }],Object.assign({},LB,{title:{text:'Process Lanes by Tower',font:{size:isMobile?12:14,color:'#202124'}},
    yaxis:{tickfont:{size:isMobile?10:13},automargin:true},xaxis:{title:'Lanes'},showlegend:false,
    margin:{l:isMobile?90:110,r:40,t:50,b:40}}),CFG);
  // Flow count by tower
  var fCounts = tNames.map(function(t){ return ad.towers[t].flows || 0; });
  Plotly.react('arch-chart-towers',[{
    x:tNames, y:fCounts, type:'bar', marker:{color:'#34a853'},
    text:fCounts.map(String), textposition:'outside', textfont:{size:isMobile?10:12}
  }],Object.assign({},LB,{title:{text:'E2E Flows by Tower',font:{size:isMobile?12:14,color:'#202124'}},
    xaxis:{tickfont:{size:isMobile?9:12},automargin:true},
    yaxis:{title:'Flows',titlefont:{size:isMobile?10:12}},showlegend:false}),CFG);
}

// ---- Testing charts ----
function renderTestCharts(){
  var td = TESTING_DATA;
  if(!td || !td.defects_by_severity) return;
  // Defects by severity — stacked bar by tower
  var sevKeys = Object.keys(td.defects_by_severity);
  var sevColors = {Critical:'#ea4335',High:'#fbbc04',Medium:'#00aeef',Low:'#34a853'};
  if(sevKeys.length){
    var tws = td.towers || [];
    var traces = ['Critical','High','Medium','Low'].filter(function(s){return td.defects_by_severity[s]}).map(function(sev){
      return {x:tws, y:tws.map(function(t){return (td.defects_by_severity[sev]||{})[t]||0}),
        name:sev, type:'bar', marker:{color:sevColors[sev]||'#999'}};
    });
    Plotly.react('test-chart-severity',traces,Object.assign({},LB,{
      title:{text:'Defects by Severity & Tower',font:{size:isMobile?12:14,color:'#202124'}},
      barmode:'stack', xaxis:{tickfont:{size:isMobile?9:12},automargin:true},
      yaxis:{title:'Defects'},legend:{orientation:'h',y:-0.2,font:{size:isMobile?10:12}}}),CFG);
  }
  // Test execution donut
  var exec = td.execution || {};
  var eLabels = Object.keys(exec);
  var eValues = eLabels.map(function(k){return exec[k]});
  var eColors = {Pass:'#34a853',Fail:'#ea4335','Not Executed':'#fbbc04','In Progress':'#00aeef','Blocked':'#8e44ad'};
  if(eLabels.length){
    Plotly.react('test-chart-exec',[{
      labels:eLabels, values:eValues, type:'pie', hole:0.5,
      marker:{colors:eLabels.map(function(l){return eColors[l]||'#999'})},
      textinfo:'label+percent', textfont:{size:isMobile?10:12}
    }],Object.assign({},LB,{title:{text:'Test Execution Status',font:{size:isMobile?12:14,color:'#202124'}},
      showlegend:true,legend:{orientation:'h',y:-0.15,font:{size:isMobile?10:12}},
      margin:{l:20,r:20,t:50,b:60},
      annotations:[{text:'<b>'+(eValues.reduce(function(a,b){return a+b},0))+'</b><br>Tests',
        showarrow:false,font:{size:isMobile?14:18,color:'#202124'},x:0.5,y:0.5}]}),CFG);
  }
  // Defect aging bar
  var aging = td.aging || {};
  var agLabels = Object.keys(aging);
  if(agLabels.length){
    Plotly.react('test-chart-aging',[{
      x:agLabels, y:agLabels.map(function(k){return aging[k]}), type:'bar',
      marker:{color:agLabels.map(function(k){return aging[k]>20?'#ea4335':aging[k]>10?'#fbbc04':'#34a853'})},
      text:agLabels.map(function(k){return aging[k]}), textposition:'outside', textfont:{size:isMobile?10:12}
    }],Object.assign({},LB,{title:{text:'Open Defect Aging (days)',font:{size:isMobile?12:14,color:'#202124'}},
      xaxis:{title:'Age Bucket',tickfont:{size:isMobile?9:12}},
      yaxis:{title:'Defects',titlefont:{size:isMobile?10:12}},showlegend:false}),CFG);
  }
  // Defects by tower
  var twDef = td.defects_by_tower || {};
  var twKeys = Object.keys(twDef);
  if(twKeys.length){
    Plotly.react('test-chart-tower-defects',[{
      x:twKeys, y:twKeys.map(function(k){return twDef[k]}), type:'bar',
      marker:{color:'#ea4335'}, text:twKeys.map(function(k){return twDef[k]}),
      textposition:'outside', textfont:{size:isMobile?10:12}
    }],Object.assign({},LB,{title:{text:'Open Defects by Tower',font:{size:isMobile?12:14,color:'#202124'}},
      xaxis:{tickfont:{size:isMobile?9:12},automargin:true},
      yaxis:{title:'Defects'},showlegend:false}),CFG);
  }
}

// ---- Master apply ----
function applyFilters(){
  var twrs=fTowers(), objs=fObjs();
  updateKPIs(twrs);
  renderTowerBar(twrs);
  renderDonut(twrs);
  renderPhaseBar(twrs);
  renderTypePie(objs);
  renderSankey(twrs,objs);
  renderRaidBar(twrs);
  renderTypeLine(objs);
  filterDocTable();
  filterRaidTable();
  attachNav();
  renderArchCharts();
  renderTestCharts();
}

// ---- Filter chip handlers ----
(function(){
  var box=document.getElementById('filter-chips');
  if(!box) return;
  var chips=box.querySelectorAll('.filter-chip');
  var allChip=box.querySelector('[data-key="__ALL__"]');

  var allKeys=[];
  chips.forEach(function(c){var k=c.dataset.key; if(k!=='__ALL__') allKeys.push(k)});

  chips.forEach(function(chip){
    chip.addEventListener('click',function(){
      var key=chip.dataset.key;
      if(key==='__ALL__'){
        var allOn=allKeys.every(function(k){return selected.has(k)});
        if(allOn){ selected.clear(); chips.forEach(function(c){c.classList.remove('active')}); }
        else{ allKeys.forEach(function(k){selected.add(k)}); chips.forEach(function(c){c.classList.add('active')}); }
      } else {
        if(selected.has(key)){selected.delete(key);chip.classList.remove('active')}
        else{selected.add(key);chip.classList.add('active')}
        if(allChip) allChip.classList.toggle('active',allKeys.every(function(k){return selected.has(k)}));
      }
      applyFilters();
    });
  });

  // Search box for capability filter
  var si=document.getElementById('cap-filter-input');
  if(si){
    si.addEventListener('input',function(){
      var q=si.value.trim().toLowerCase();
      chips.forEach(function(c){
        var k=c.dataset.key;
        if(k==='__ALL__'){c.style.display=q?'none':''; return}
        c.style.display=(!q||k.toLowerCase().indexOf(q)!==-1)?'':'none';
      });
    });
  }
})();

// ---- Initial render ----
applyFilters();
switchPillar('architecture');  // show Architecture pillar by default

// ---- Release dropdown handler ----
(function(){
  var sel = document.getElementById('release-filter');
  if(!sel) return;
  // Check URL param first, then localStorage
  var urlParams = new URLSearchParams(window.location.search);
  var urlRel = urlParams.get('release');
  var savedRel = localStorage.getItem('iao-release-filter');
  var initRel = urlRel || savedRel;
  if(initRel && initRel !== 'All'){
    activeRelease = initRel;
    sel.value = initRel;
    applyFilters();
  }
  sel.addEventListener('change', function(){
    activeRelease = sel.value;
    localStorage.setItem('iao-release-filter', sel.value);
    // Update URL without reload
    var url = new URL(window.location);
    if(activeRelease === 'All') url.searchParams.delete('release');
    else url.searchParams.set('release', activeRelease);
    window.history.replaceState({}, '', url);
    rewriteDocTableLinks();
    applyFilters();
  });

  // Rewrite doc inventory "View" links to include release prefix
  function rewriteDocTableLinks(){
    document.querySelectorAll('.doc-table tbody a[href*="towers/"]').forEach(function(a){
      var orig = a.getAttribute('data-orig-href') || a.getAttribute('href');
      a.setAttribute('data-orig-href', orig);
      if(activeRelease && activeRelease !== 'All'){
        var pat = /(\.\.\/)*towers\//;
        var newHref = orig.replace(pat, function(m){
          return m.replace('towers/', activeRelease + '/towers/');
        });
        a.setAttribute('href', newHref);
      } else {
        a.setAttribute('href', orig);
      }
    });
  }
  // Rewrite on initial load if release was set
  rewriteDocTableLinks();
})();

// ---- Print/PDF: freeze Plotly charts to static PNG images, then print ----
(function(){
  var chartIds=['chart-tower-bar','chart-completion-pie','chart-phases',
                'chart-type-pie','chart-sankey','chart-raids','chart-type-phases',
                'arch-chart-systems','arch-chart-patterns','arch-chart-lanes','arch-chart-towers',
                'test-chart-severity','test-chart-exec','test-chart-aging','test-chart-tower-defects'];
  var snapshots={};
  var frozen=false;

  function freezeCharts(){
    var promises=[];
    chartIds.forEach(function(id){
      var div=document.getElementById(id);
      if(!div) return;
      if(!div.classList.contains('js-plotly-plot') && !div.querySelector('.js-plotly-plot')) return;
      snapshots[id]={html:div.innerHTML, w:div.style.width, h:div.style.height};
      var w=id==='chart-sankey'?900:500;
      var h=id==='chart-sankey'?400:320;
      promises.push(
        Plotly.toImage(div,{format:'png',width:w,height:h,scale:2}).then(function(dataUrl){
          // Return a promise that resolves only after the <img> has loaded
          return new Promise(function(resolve){
            var img=new Image();
            img.className='chart-snapshot';
            img.onload=function(){ resolve(); };
            img.onerror=function(){ resolve(); }; // don't block on error
            img.src=dataUrl;
            div.innerHTML='';
            div.appendChild(img);
          });
        })
      );
    });
    return Promise.all(promises);
  }

  function restoreCharts(){
    chartIds.forEach(function(id){
      var div=document.getElementById(id);
      if(!div||!snapshots[id]) return;
      div.innerHTML=snapshots[id].html;
      if(snapshots[id].w) div.style.width=snapshots[id].w;
      if(snapshots[id].h) div.style.height=snapshots[id].h;
    });
    snapshots={};
    frozen=false;
    setTimeout(function(){ applyFilters(); },150);
  }

  // PDF button: freeze → wait for paint → print → restore
  document.getElementById('btn-pdf').addEventListener('click', function(){
    if(frozen) return; // guard against double-click
    frozen=true;
    freezeCharts().then(function(){
      // Two rAF + timeout ensures both Chrome and Edge have painted the images
      return new Promise(function(resolve){
        requestAnimationFrame(function(){
          requestAnimationFrame(function(){
            setTimeout(resolve, 300);
          });
        });
      });
    }).then(function(){
      window.print();
      restoreCharts();
    });
  });

  // Fallback for Ctrl+P (best-effort — can't await async in synchronous event)
  window.addEventListener('afterprint', function(){
    if(Object.keys(snapshots).length>0) restoreCharts();
  });
})();
</script>

