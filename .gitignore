# ─── Secrets & credentials ───────────────────────────────────
.env
*.pem
*.key

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
*.egg
dist/
build/
*.whl

# ─── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ─── Generated outputs (rebuild via pipeline) ───────────────
towers/*/output/
output/
_site/

# ─── Probe results (may contain auth tokens/session data) ───
data/sap_odata/*.json

# ─── JIRA cache (allow cached data for CI, exclude raw API dumps) ───
data/jira/*.log
data/jira/raw/

# ─── Smartsheet API-fetched data (rebuilt by CI via fetch_smartsheet_data.py) ─
data/smartsheet/api/

# ─── Archive (historical probe/exploration scripts) ─────────
_archive/

# ─── Reference scripts (not part of pipeline) ───────────────
reference/

# ─── Test artifacts ─────────────────────────────────────────
test*.png
*.log

# ─── Jupyter notebook checkpoints ───────────────────────────
.ipynb_checkpoints/

# ─── OS files ────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db
