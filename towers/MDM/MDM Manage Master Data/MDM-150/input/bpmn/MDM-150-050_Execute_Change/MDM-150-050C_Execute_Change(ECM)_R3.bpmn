   <collaboration id="sid-fcf4dd71-b2a6-4c6e-88ee-c4004fb82433">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="The process of executing a change in the material master involves multiple steps to ensure that material attributes are correctly updated and replicated across systems. The process begins with the initiation of the change and involves determining the source system (SPEED or MDG). Depending on the source system, different workflows are followed to send, receive, convert, map, and validate material attributes. The process includes error handling, approval workflows, and notifications to relevant stakeholders. The final steps involve updating the material in SAP S/4HANA and replicating the changes to downstream systems.&#10;&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Shaik, Moti &lt;moti.shaik@intel.com&gt;&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="19/04/25"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved on Signavio Collab Hub"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="1f7f6bfc326c4fd18605b3e9796351bc"/>
      </extensionElements>
