   <collaboration id="sid-7a0690b2-1f76-48cf-b50e-2ed442c1de71">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="The 'Classify Data Change' process involves initiating a data update with the receipt of a new product creation request, populating and uploading data, verifying and validating data integrity, automatically approving changes, and finally replicating and distributing updated material master records to relevant systems. This ensures the material master data is accurately updated and propagated throughout the enterprise ecosystem."/>
