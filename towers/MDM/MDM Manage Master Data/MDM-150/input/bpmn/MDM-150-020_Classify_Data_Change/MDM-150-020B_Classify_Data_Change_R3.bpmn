   <collaboration id="sid-f731ecae-40b2-479b-8f83-4123b715b6e0">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="The mass product change process involves managing and executing changes to material master data within the SAP system. It begins with the receipt of a change request and involves exporting product attributes, preparing the data for changes, and managing mass processes in SAP MDG. The process includes validating the data, submitting change requests, and handling approvals or rejections. Once approved, the material data is updated in SAP S/4HANA and replicated to downstream systems. Notifications are sent to stakeholders at various stages to ensure transparency and coordination. The process ensures accurate and up-to-date material data across the SAP landscape."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Shaik, Moti &lt;moti.shaik@intel.com&gt;&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="19/04/25"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved on Signavio Collab Hub"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="70a90a041eca41a2907cfeca60606947"/>
      </extensionElements>
