   <collaboration id="sid-27691ab5-a5a9-421e-8656-8df2044914d7">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="If the asset is an internal acquisition it will be dealt with differently from an external purchase.  When an asset has been constructed by the company itself, it is necessary to accumulate labor, material, overhead charges and capitalized interest and allocate these costs to the asset.  This is often done by project accounting and an integration point is shown. Periodically (usually monthly) projects will post to an asset under construction to avoid recording the costs associated with it in the profit and loss account.  In some cases the asset under construction may be recorded as such at the month end and backed out at the beginning of the next month, in others the value of the asset will be increased by the monthly costs attributed to it. On completion of an asset under construction or a project it is necessary to ensure that the asset in accounting terms captured all charges.  Once all costs are captured the asset can be capitalized using the appropriate capitalization method."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Rea M Meyer&quot;,&quot;Jamie Sutton&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="23/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Linked sub-process approved on signavio"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="588386cb0e8746ac80c4aab2852b79b6"/>
      </extensionElements>
