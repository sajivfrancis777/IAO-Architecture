   <collaboration id="sid-c6678ee7-a34b-496e-b59c-ec8cf2baab7d">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="When an asset has been leased by the organization, accounts payable should advise the asset manager of the leasing data to allow the asset to be capitalized. Typically, the value of the asset is equivalent to the value of the principal repayments over the term of the lease. There are often onerous terms associated with a lease to do with buyback and return options. Where these exist they should be captured to allow for management of the leased asset base. Typical leased data includes the value and number of payments and their timing, the effective interest rate, the buyback or terminal value of the asset. Generally accepted accounting practices apply stringent criteria for the capitalization of leased assets.  It is important to monitor leased assets within the asset ledger to prevent unnecessary expense and manage contractual obligations. Purchase may be a cheaper means of getting access to the asset, or might allow freedom for modifications not enabled under the terms of the lease."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Jaime Sutton&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="06/09/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved on Signavio"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="35781a47789847ce802c7ec23a006d8a"/>
      </extensionElements>
