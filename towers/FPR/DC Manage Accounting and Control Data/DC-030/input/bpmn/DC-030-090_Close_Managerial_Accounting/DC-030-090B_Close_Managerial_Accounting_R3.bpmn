<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_094aa6a0-4dae-451d-ae8d-8b362dccf1ae" name="DC-030-090_Close Managerial Accounting" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-257a95ce-59bd-4fe3-bbe3-ce729c5a8811">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="First, the organization must identify certain cost allocations to be applied upon completing all analyses. An example would be allocating overhead based on a set of predefined criteria. After allocations are completed, run analysis reports to confirm the process operated correctly.  An integration point exists here with Overhead Accounting and Allocation (located in Provide Financial Decision Support).  The next step in closing is to reconcile financial and managerial accounting to ensure that reorganizations, reallocations and reclassifications performed in the management accounting module are reflected in the financial accounting module.  This comparison can be done automatically by the system and the net differences between the two posted to the G/L.  (Note: The inverse can be done at a detailed level, if financial transactions are not automatically reflected in the management accounting module).  Any corrections or adjustments that arise from the reconciliation should be made at this time."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Josh Philpot&quot;,&quot;Rea M Meyer&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="17/10/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved on Signavio by Team 7.&#10;Approved via email by Team 1"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 01 - GL Close %26 Consolidate/DC-030 Perform closing/DC-030-090.msg?csf=1&amp;web=1&amp;e=Y9XCej&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="008fd9f6e56148668300b51bb16db205"/>
      </extensionElements>
