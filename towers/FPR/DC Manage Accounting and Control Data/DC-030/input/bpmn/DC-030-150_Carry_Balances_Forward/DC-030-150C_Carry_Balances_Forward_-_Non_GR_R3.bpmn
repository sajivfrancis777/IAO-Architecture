         <text>SAP CFIN</text>
      </textAnnotation>
      <textAnnotation id="sid-C863E35F-94B0-485F-BC17-8175698F2A5C" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-B18B5E26-C6D8-45A5-8298-AD8DA0B3B908" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>- Off set Current Retained Earning A/C Balance against Prior Retained Earnings Account Annually

- Offset Current Dividend A/C Balance against Prior Dividend Account</text>
      </textAnnotation>
      <textAnnotation id="sid-951228FB-B642-49FC-BB3C-C4239C490D05" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/76fb9d83aa7444efba4e0d9c599ba45a</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="ProcessParticipant"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="27.0" y="-9.0"/>
         </extensionElements>
         <text>Consolidation Accountant</text>
      </textAnnotation>
      <textAnnotation id="sid-12ECF90C-000F-4C60-A1D1-00C62F924445" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>-In R3, Reclassification will be done in IP and IF and the same will be replicated in CFIN. This program will be executed in CFIN in case of business requirement
-Detailed process will be covered as part of RICEFW - FPRE0360_CFIN, FPRE0360_IF, FPRE0360_IP
- S4 HANA system is IP &amp; IF system. This process execution will be in all three system (IP, IF &amp; CFin system).</text>
      </textAnnotation>
      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Finance Plan To Report
Process Group: DC Manage Accounting and Control Data
Process: DC-030-150C Carry Balances Forward - Non GR_R3</text>
      </textAnnotation>
   </process>
