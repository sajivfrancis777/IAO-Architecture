<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-500ab9ed-62b6-4c4b-9da2-31d62a08126a" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-a8c0eaba-3ad4-4637-814f-19bcc3230749">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Balance carryforwards will be executed in S/4 (IF &amp; IP) &amp; CFin systems. By standard through balance carryforward program execution, the Profit &amp; Loss A/C balance will be transferred to Retained Earnings account (in this case based on the configuration setup in IF, IP &amp; CFin system, balance will be transferred to Prior Retained Earnings account). Further based on the adjustments required, this program will be executed to reclassify GL accounts in S/4 system (i.e. IF &amp; IP systems). Any reclassification performed in S/4 systems will be replicated to CFin system. Further based on business requirement, incase any adjustments needs to be performed in CFin system, business will use this custom program."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Rea M Meyer&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="25/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved on Signavio"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="cb64a4eef4164b29b1aba3448e3d4755"/>
      </extensionElements>
