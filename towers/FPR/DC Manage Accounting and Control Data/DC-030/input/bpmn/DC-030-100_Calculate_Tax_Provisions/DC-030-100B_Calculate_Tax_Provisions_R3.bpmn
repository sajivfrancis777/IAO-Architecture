         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Finance Plan To Report
Process Group: DC Manage Accounting and Control Data
Process: DC-030-100B Calculate Tax Provisions_R3</text>
      </textAnnotation>
      <textAnnotation id="sid-BC84F778-9352-4122-90BA-264CF12FD67C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Note: Tax Provisions will be calculated in Onesource system and same would get posted to S4HANA system (IP/IF)
Further these entries from IP and IF would be posted in CFIN system through CFIN Replication
</text>
      </textAnnotation>
