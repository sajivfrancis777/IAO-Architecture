         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Finance Plan To Report
Process Group: DC Manage Accounting and Control Data
Process: DC-030-140 Process Year End Adjustments</text>
      </textAnnotation>
      <textAnnotation id="sid-2D89C355-C748-4B9C-86C6-4F9669594D5A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Note: As part of R1 &amp; R2, year end adjustment process will continue in source ECC system, same will be replicated in CFin system. There will be no direct postings in CFin System.</text>
      </textAnnotation>
