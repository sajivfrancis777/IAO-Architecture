   <collaboration id="sid-9855d0b4-0d90-41da-8e30-f511e762ecb5">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Devise and maintain a schedule detailing the timing and frequency of each closing-related process, including sub-system feeds, automated journal entries, manual entries and all the processes to follow.  Distribute the schedule to all source groups affected. After receiving final transactions from sub-systems, close these systems’ periods to ensure no further transactions are processed for that period.  Only authorized users should be allowed to post transactions to the prior period.  Additional tasks that should be performed include, managing g/l and sub-ledger cut-off dates, closing the period for administrative functions, and opening the next period.&#10;&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Rea M Meyer&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="19/10/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved on Signavio"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="feddea3bc19848678f623ed9a3b32211"/>
      </extensionElements>
