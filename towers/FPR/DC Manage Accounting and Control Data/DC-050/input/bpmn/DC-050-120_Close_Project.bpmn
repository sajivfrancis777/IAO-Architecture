<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_39f7de73-cf96-437b-a336-6570a289c5f0" name="DC-050-120_Close Project" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-069be6e5-0210-42a7-9c74-799a114e5198">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="You use Close status for a project / WBS element that has been completed from both a logistic and an accounting point of view.&#10;&#10;You can only set the Closed (CLSD) status if the WBS element has either the Released (REL) or the Technically Completed (TECO) status and if all items attached to the WBSE are complete (no outstanding committments, settlement completed, etc.).  In the Closed status you can no longer make any changes to the project hierarchy and you cannot post any actual costs or commitments. Cost planning and budgeting is also deactivated. The status is passed on to subordinate WBS elements.&#10;&#10;CLSD status may be reset and the WBS element reverts to TECO status.&#10;&#10;The status deactivates any assets under construction (AUC) that are assigned to the WBS element."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Onopa, Amanda&quot;,&quot;Rojas, Doris R&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="02/04/25"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved on signavio"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Evidence &quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared%20Documents/General/Implementation/03.%20FPR/3%20Final%20Deliverables/05.%20Process%20Approval%20Evidence/Team%2011%20-%20Project%20Accounting/DC-050%20Project%20Accounting/EXT%20RE%20DC-050%20Capex%20Updated%20L3s.msg?csf=1&amp;web=1&amp;e=eogCOW&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="9c2396769b51422aada472cff1cd8335"/>
      </extensionElements>
