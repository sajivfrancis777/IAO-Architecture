<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_4a48929f-fade-4ba4-af7a-67b1537de781" name="DC-050-150_Run final settlement to Assets" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-09e6f520-2ab9-4793-a853-d657b2f9473a">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Settlement is a period end closing process that allocates the actual costs of a project that were posted during the month from &#10;a WBS element to the final assets and/or cost centers.  The allocation / settlement is to one or more receivers.  The receivers &#10;are entered in the settlement rule for each WBS element that has received actual costs.  Once the WBS element settlement &#10;rules are updated with the fixed asset numbers and/or cost centers (for expense costs), the settlement of actual costs can be &#10;performed.  Costs can be allocated using percentages or equivalence numbers.  Settlement allows: &#10;This settlement sub-process is the final settlement to fixed assets.  This process will continue each month for projects in TECO &#10;status until all costs have been accumulated and settled to fixed assets.&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Matthew C Roberts&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="06/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 11 - Project Accounting/DC-050 Project Accounting/DC-050 Sprint 5.msg?csf=1&amp;web=1&amp;e=JhalHl&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="c63b33d6aa4e4f81ac31f5d82dfc0b63"/>
