      <textAnnotation id="sid-20D22CE2-2B9D-4A06-934E-4F982DACE603" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IT Department</text>
      </textAnnotation>
      <textAnnotation id="sid-7427AAD6-7385-4456-9646-35383437BCE2" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Graphite/Supplier Master Data Team</text>
      </textAnnotation>
      <textAnnotation id="sid-329245BE-0FFF-4A1D-96F5-CD7015F1A27F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Any future update in rules will be maintained in tax master data</text>
      </textAnnotation>
      <textAnnotation id="sid-2F7714C8-BDD5-4CE0-BBB4-E0719FFA17D4" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-E609C044-68C4-4B90-84D7-971E8E18F8E2" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-3656652D-AFE4-423E-A0D5-F6D1B931F13A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>ISR will have a specific process where WHT type
and codes are provided to Graphite team to
update as per local requirements</text>
      </textAnnotation>
      <textAnnotation id="sid-A82478D0-2898-44D7-B4CB-24D49224AD98" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/63e9a7c4a30a4113868d7827194f1a9c</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="ProcessParticipant"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Vendor Master Team</text>
      </textAnnotation>
      <textAnnotation id="sid-2DB3675F-B9AE-4ACA-B6A9-1CAFA5C48214" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/7543ee6a8ccb40848090023c64c39559</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="ProcessParticipant"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Global Tax Analyst</text>
      </textAnnotation>
      <textAnnotation id="sid-5227E429-4167-4123-BC10-B7A36D66FD87" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual assigning of WHT code if BRF is not set up for particular countries</text>
      </textAnnotation>
      <textAnnotation id="sid-954EB167-CBD3-4CF8-B488-42FFADFC5D50" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>The invoice will continue to follow the standard invoice processing procedure performed by GSPO.

If any errors or BRF+ requirements are encountered,
it will be routed to the error queue for further review and resolution.</text>
      </textAnnotation>
      <textAnnotation id="sid-EF47C02E-66E1-4378-806A-528B69F653B3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GSPO to further clarify with tax team/supplier and send questionnaires to supplier wherever required for additional information to determine the WHT tax code</text>
      </textAnnotation>
      <textAnnotation id="sid-4432ED50-B312-48D0-AB0B-EDB33ACF6E7C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Override WHT code</text>
      </textAnnotation>
      <textAnnotation id="sid-CC4ABFEE-E306-4C73-948A-7BF1FBA2CE91" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Potential WHT code error due to WHT code changes at vendor level which only applicable for WHT trigger upon payment</text>
      </textAnnotation>
      <textAnnotation id="sid-19E26DD6-772F-4E66-B074-B138FDE74CA6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. override tax code based on WHT code stated in supplier master data
2. override tax code based on WHT code determined by BRF</text>
      </textAnnotation>
      <textAnnotation id="sid-6AE3ADC3-FB8D-40B6-9B06-DEFE4CBE8F7E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
