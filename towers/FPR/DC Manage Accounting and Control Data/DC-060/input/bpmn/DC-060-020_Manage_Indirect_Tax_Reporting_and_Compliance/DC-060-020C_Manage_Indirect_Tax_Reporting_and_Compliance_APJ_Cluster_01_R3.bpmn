      <textAnnotation id="sid-2CBF9400-E224-4F8F-898C-89F5559995EA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>CN - tax payment is paid via direct debit by tax team directly and provide e-filed VAT return together with tax receipt to ICA for payment posting</text>
      </textAnnotation>
      <textAnnotation id="sid-2A87444D-5F0A-4ED3-BC05-6A5456D2386B" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/ba0ca5b44d254ba2accdef6b53728447</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
