            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Microsoft Excel</text>
      </textAnnotation>
      <textAnnotation id="sid-7340EC4D-0309-4CB3-A440-38525A4F5C67" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IN - Reconciliation performed
by ICA and review by TCO
CN - Reconciliation performed by ICA and review by tax team</text>
      </textAnnotation>
      <textAnnotation id="sid-724CC821-2BF0-4D3F-88E1-00483CFA0511" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IN - Draft return prepared by TCO and review by tax team
CN - Draft return prepared by tax team</text>
      </textAnnotation>
      <textAnnotation id="sid-D77CAE74-43FE-4275-B7D5-C0D067D16236" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>ICA/Tax team reconciles the accounts after payment is posted to
the GL(s)</text>
      </textAnnotation>
