         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="19/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Email Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 02 - Tax/DC-060 Manage Taxes/R3S6/DC-060-010,020,140,170,180 Indirect Tax Process Flow Review - APJ Cluster 01.pdf?csf=1&amp;web=1&amp;e=Gs8jHS&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="814dd38b296f42c389fd00a3558fc1c0"/>
      </extensionElements>
