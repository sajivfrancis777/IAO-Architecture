   <collaboration id="sid-5623bc03-fdf1-4cf0-b1a7-fbbf07fcd671">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="In the Indirect Tax Reporting and Compliance process,  indirect tax(IDT) reports are generated from SAP S/4 HANA. After the report is reviewed and reconciliated, the IDT form is prepared for tax filling, posting to target sales &amp; use tax or VAT account, and process tax payment. By introducing the SAP DRC functionality, most of the manual process could be automatied. "/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Castro, Fabian&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="21/05/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Email Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 02 - Tax/DC-060 Manage Taxes/DC-060-010,010A,020A,140A,170A,180A.pdf?csf=1&amp;web=1&amp;e=G2NjpJ&quot;}]"/>
