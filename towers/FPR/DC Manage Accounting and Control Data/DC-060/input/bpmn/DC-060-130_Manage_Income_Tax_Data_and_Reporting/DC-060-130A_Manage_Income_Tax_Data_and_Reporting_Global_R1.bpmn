         <text>eFront Invest LP</text>
      </textAnnotation>
      <textAnnotation id="sid-EA91657B-4F67-4F8D-80BF-68154B63EA70" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Description :	eFront Invest LP is a SaaS application for Intel Capital to track financial and accounting information for its portfolio companies in order to facilitate financial reporting and close activities.</text>
      </textAnnotation>
      <textAnnotation id="sid-1F0EB7E1-D942-4167-AD16-C61CDC10D5C3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Description :	Platform for portfolio monitoring, valuation and reporting for Intel Capital</text>
      </textAnnotation>
      <textAnnotation id="sid-6FF2EE87-D971-430B-B36E-B3C5F8C0CC0A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Treasury system has been added as an example and is not a complete list. </text>
      </textAnnotation>
