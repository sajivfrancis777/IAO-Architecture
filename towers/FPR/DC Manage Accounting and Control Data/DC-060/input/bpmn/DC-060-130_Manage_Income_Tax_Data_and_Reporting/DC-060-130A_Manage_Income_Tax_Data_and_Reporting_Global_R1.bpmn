   <collaboration id="sid-d421e256-b937-40ca-9bff-25f589495553">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="This Income Tax Data and Reporting process generates the primary data to file the tax returns to tax authorities. Different GL data and reports needs to be captured from SAP or boundry apps to completed all book/tax adjustment. There are also special adjustment, such as FDII, BEAT, NOL, etc., needs to be include before computing tax liability and tax credit. Then the tax form will be prepared in ONESOURCE Income Tax(for US) or other Local Tax Filling Apps(for non US)  file the tax returns to tax authorities. &#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Cook, Paula&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="19/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved Via Teams conversation. We use the Americas Cluster 01 as Global process."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Teams Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:i:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 02 - Tax/DC-060 Manage Taxes/DC-060-130A Global approval.png?csf=1&amp;web=1&amp;e=jeOAtB&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="26489819b6dd42eaaea1d82d557d2634"/>
