   <collaboration id="sid-d1a79202-93c9-401c-9799-905dca7a6964">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="This Income Tax Data and Reporting process generates the primary data to file the tax returns to tax authorities. Different GL data and reports needs to be captured from SAP or boundry apps to completed all book/tax adjustment. There are also special adjustment, such as FDII, BEAT, NOL, etc., needs to be include before computing tax liability and tax credit. Then the tax form will be prepared in ONESOURCE Income Tax(for US) or other Local Tax Filling Apps(for non US)  file the tax returns to tax authorities. &#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Zhou, Julin&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="29/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Email Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 02 - Tax/DC-060 Manage Taxes/DC-060-130 EMEA 01, EMEA 02, and APJ 02 2.pdf?csf=1&amp;web=1&amp;e=2GfhUn&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="75b7e40a65a049db9f0e70f655b87624"/>
