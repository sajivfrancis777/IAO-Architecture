      <textAnnotation id="sid-C7B8535B-3441-416F-8763-D87C89E281A4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Tax requirement provided by Tax team</text>
      </textAnnotation>
      <textAnnotation id="sid-2286172F-8D80-49F5-BD6B-FA3D0112E09E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Chile, Colombia, Costa Rica, Mexico, and Peru are using ONESOURCE for Indirect Tax calculation. Argentina and Brazil are manual.</text>
      </textAnnotation>
      <textAnnotation id="sid-65E18090-E5FC-4F54-897D-DFAE4D269BB5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Chile, Colombia, Costa Rica, Mexico, and Peru are using ONESOURCE for Indirect Tax calculation. Argentina and Brazil are manual.</text>
      </textAnnotation>
      <textAnnotation id="sid-4DCEF051-8B40-4589-B889-5E6BC24F49E1" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Including IT Tax APT, IT MDG, GSPO IT, Global Tax</text>
      </textAnnotation>
