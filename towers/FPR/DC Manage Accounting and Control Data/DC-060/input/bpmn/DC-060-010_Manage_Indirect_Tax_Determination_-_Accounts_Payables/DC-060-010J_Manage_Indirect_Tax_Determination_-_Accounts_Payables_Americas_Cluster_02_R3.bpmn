      <textAnnotation id="sid-740E6BEB-9308-4E7E-AEAE-93B77B2094A4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
