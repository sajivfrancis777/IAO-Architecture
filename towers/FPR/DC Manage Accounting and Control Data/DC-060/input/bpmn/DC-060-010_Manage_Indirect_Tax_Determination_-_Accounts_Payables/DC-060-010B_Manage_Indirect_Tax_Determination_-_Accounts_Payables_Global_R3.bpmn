      <textAnnotation id="sid-4556DC6F-DB47-422A-ADA6-A72B97C5BAD8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Ariba invoice, web invoice, B2B, ERS, Non PO, e-check, OCR, Miro are all managed under Process Director</text>
      </textAnnotation>
      <textAnnotation id="sid-ECD72F9E-E1C9-4F3E-93CB-9839C9171C64" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Tax review is performed by TCO and GSPO CS</text>
      </textAnnotation>
      <textAnnotation id="sid-4B6DD99E-C84C-42EF-B8B2-49E290F1B403" signavio:alignment="left">
