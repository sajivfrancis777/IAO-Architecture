            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-5163025E-88BB-40D9-A857-35D59BDFD197" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Ariba PO, Direct Material, Capital PO,
CPM PO, Wiings PO, Non-PO, e-check,
contract invoice (IAC)</text>
      </textAnnotation>
      <textAnnotation id="sid-7342BB88-FFAA-4E24-B53A-F91115554505" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-63A0316A-9165-4CEF-ABAE-A315AE8D2670" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>For Uruguay (e-invoicing countries TBD pending e-invoicing solutions decision)</text>
      </textAnnotation>
      <textAnnotation id="sid-4556DC6F-DB47-422A-ADA6-A72B97C5BAD8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Ariba invoice, web invoice, B2B, Non PO, e-check, OCR, Miro are all managed under Process Director</text>
      </textAnnotation>
      <textAnnotation id="sid-ECD72F9E-E1C9-4F3E-93CB-9839C9171C64" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Tax review is performed by Tax APT after GSPO log the ticket</text>
      </textAnnotation>
      <textAnnotation id="sid-3CAF7877-54D8-47A6-8D33-B9716C30984A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Ariba invoice, web invoice,
B2B, ERS, consignment
OCR, Miro are all
managed under Process
Director</text>
      </textAnnotation>
      <textAnnotation id="sid-3656652D-AFE4-423E-A0D5-F6D1B931F13A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Utilize local apps for e-invoicing</text>
      </textAnnotation>
      <textAnnotation id="sid-F1062CBC-D9AE-420D-8F03-FC275DD98715" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
