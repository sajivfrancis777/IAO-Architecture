      <manualTask completionQuantity="1" id="sid-130329F1-D782-438C-95F6-6E42682E7733" isForCompensation="false" name="DC-060-080E-060 Apply Transfer Pricing Methods and set Transfer prices for tangibles" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-jobprofile" metaValue="/glossary/0a3f7c4bf2034fbdb571633c7cab6d4c"/>
            <signavio:signavioMetaData metaKey="meta-screenfloriapps" metaValue="[&quot;/glossary/84bcb166c64448ac8a507eb799124bbf&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-system" metaValue="[&quot;/glossary/84bcb166c64448ac8a507eb799124bbf&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-securityrole" metaValue="[&quot;/glossary/f86e941de6604f41bdeabfc6db072085&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci1704366147381296654580"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="Managing transfer pricing involves several key components that ensure compliance with global regulatory requirements and facilitate effective policy management. Here's a breakdown of the process:&#10;&#10;• Create,update TP contracts which are mapped with appropriate cost center.&#10;&#10;• Manage Transfer Pricing policies: Determine and compile advance pricing agreement and all valid Transfer Pricing agreements between entities.&#10;&#10;• Apply TP methods and set Transfer Prices for tangibles and set transfer prices for tangibles.&#10;&#10;• Set Cost Center/GL code mapping and mark-ups for Intercompany services and royalty&#10;&#10;• Set intercompany interest rates for IC Loans/Cash pooling with Treasury inputs.&#10;&#10;After the intercompany accounting transactions are posted:&#10;&#10;• Generate report to review Segmented LE P&amp;L Results. Determine segmented profitability by legal entity (mines and selling entities), product and generate TP adjustments&#10;&#10;• Perform TP Reporting and Analytics&#10;&#10;• Generate SAP data, tax input data, headcount data at various levels for tax reporting purposes.&#10;&#10;• Generate reports to aid in country-by-country compliance requirements.&#10;"/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/c8ce8a8dae0141428c9aa709c8fe18c9&quot;,&quot;/glossary/f6d8ca83167e4975b0a785eae90f4d34&quot;,&quot;/glossary/aacdd2d442004dbf98224a8c62414d20&quot;]"/>
            <caseagile:model xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:semantic="http://www.omg.org/spec/BPMN/20100524/MODEL">
