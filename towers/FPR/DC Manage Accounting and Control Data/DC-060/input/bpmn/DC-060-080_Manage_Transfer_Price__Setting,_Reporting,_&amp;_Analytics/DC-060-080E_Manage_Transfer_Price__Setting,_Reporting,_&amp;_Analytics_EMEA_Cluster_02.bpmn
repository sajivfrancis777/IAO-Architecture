               </caseagile:properties>
               <caseagile:values>
                  <caseagile:value name="bgcolor" value="FFFFFF"/>
               </caseagile:values>
            </caseagile:model>
         </extensionElements>
         <incoming>sid-C4B59E6C-1C70-47C6-8C5E-196D72425533</incoming>
