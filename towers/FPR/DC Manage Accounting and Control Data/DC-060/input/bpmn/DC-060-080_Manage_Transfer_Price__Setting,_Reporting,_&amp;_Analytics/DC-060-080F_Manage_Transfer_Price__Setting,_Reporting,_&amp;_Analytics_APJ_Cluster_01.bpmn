<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_916e9e1d-71e8-43d8-86d5-956eabc0c481" name="DC-060-080_Manage Transfer Price Setting, Reporting, &amp; Analytics" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-5667bea1-38dc-48f4-b82d-f9c4eac05339">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Managing transfer pricing involves several key components that ensure compliance with global regulatory requirements and facilitate effective policy management. Here's a breakdown of the process:&#10;&#10;• Create,update TP contracts which are mapped with appropriate cost center.&#10;&#10;• Manage Transfer Pricing policies: Determine and compile advance pricing agreement and all valid Transfer Pricing agreements between entities.&#10;&#10;• Apply TP methods and set Transfer Prices for tangibles and set transfer prices for tangibles.&#10;&#10;• Set Cost Center/GL code mapping and mark-ups for Intercompany services and royalty&#10;&#10;• Set intercompany interest rates for IC Loans/Cash pooling with Treasury inputs.&#10;&#10;After the intercompany accounting transactions are posted:&#10;&#10;• Generate report to review Segmented LE P&amp;L Results. Determine segmented profitability by legal entity (mines and selling entities), product and generate TP adjustments&#10;&#10;• Perform TP Reporting and Analytics&#10;&#10;• Generate SAP data, tax input data, headcount data at various levels for tax reporting purposes.&#10;&#10;• Generate reports to aid in country-by-country compliance requirements.&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Steele, Brad&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="23/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Email Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 02 - Tax/DC-060 Manage Taxes/DC-060-080 Transfer Pricing APJ01, APJ03, EMEA 03.pdf?csf=1&amp;web=1&amp;e=wB45hC&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="efe0aa85916547f6b1865ce4f47f1d39"/>
      </extensionElements>
