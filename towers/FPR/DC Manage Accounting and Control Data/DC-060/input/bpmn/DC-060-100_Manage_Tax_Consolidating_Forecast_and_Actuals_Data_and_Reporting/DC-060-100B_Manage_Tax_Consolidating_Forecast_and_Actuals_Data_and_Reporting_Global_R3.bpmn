   <collaboration id="sid-fb6763c1-c2fb-43ce-8fa9-f7510be70238">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="The Consolidating Forecast and Actuals Data and Reporting process collects P&amp;L data at the Cost Center level, rolls it up according to the Tax Legal Entity structure, and makes adjustments (such as transfer pricing markups). Operating income/expense (including ATM, DISTI, FAB, and R&amp;D), non-operating income/expense, tier two level income/expense, and IC income/expense calculations are prepared in SAP Analytic Cloud for pretax forecast reports by legal entity. The pretax forecast financial reports will be used to analyze the profitability and provision calculation processes.&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Ahmed, Arif&quot;,&quot;Cook, Paula&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="18/10/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Email Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 02 - Tax/DC-060 Manage Taxes/R3S8/Direct/FW_ DC-060-100 Intel_ Manage Tax Consolidating Forecast and Actuals Global R3 Process Flow .pdf?csf=1&amp;web=1&amp;e=3S8Ahe&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="eeabff9ce051419bb64afb443af3369b"/>
      </extensionElements>
