            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP SAC (Financial Planning)</text>
      </textAnnotation>
      <textAnnotation id="sid-35840A8E-37FA-4B22-828B-7C8823C3C016" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>List of the report types:
- Detailed P&amp;L report
- Summary P&amp;L report (including flux analysis)
- Calculation report from PAPM, showing how the system arrived at numbers
- Total legal entity P&amp;L report, including all entities.
- Comparison report of all legal entities against the Plan of Record (POR), highlighting the differences between the computed results and the POR</text>
      </textAnnotation>
      <textAnnotation id="sid-C68046A1-0D38-4EFC-98BC-A87C8F3BF1E9" signavio:alignment="left" textFormat="text/plain">
