      <textAnnotation id="sid-2AB5C3DD-660B-441C-A9C5-330931CA55B9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>During interim material permanent items and temporary difference are forecasted quarterly. During year-end all schedule M are prepared</text>
      </textAnnotation>
      <textAnnotation id="sid-DF002188-4B4E-455D-8AFD-DDF09EBDF243" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/250f7fc1c6254d97b8371e6df3e91188</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
