         <text>OneSource Provision Tax</text>
      </textAnnotation>
      <textAnnotation id="sid-E5A7A320-DEBF-441E-B4C5-BD21851F3058" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/250f7fc1c6254d97b8371e6df3e91188</signavio:dictionaryLink>
