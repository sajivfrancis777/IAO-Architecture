            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="-17.0" y="73.0"/>
         </extensionElements>
         <text>Microsoft Excel</text>
      </textAnnotation>
      <textAnnotation id="sid-2BBC1FEB-AC97-4314-8892-CCE2CA7C472B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>ETR - Effective Tax Rate</text>
      </textAnnotation>
      <textAnnotation id="sid-122ED58E-18F7-4D7A-8B8C-B0E8517F60C3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
