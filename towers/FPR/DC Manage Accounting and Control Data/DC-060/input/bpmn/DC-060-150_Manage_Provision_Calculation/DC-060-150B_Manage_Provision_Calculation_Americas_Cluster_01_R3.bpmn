            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>OneSource Provision Tax</text>
      </textAnnotation>
      <textAnnotation id="sid-D3351B39-43E2-4D34-87B8-62117CD50EE4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>e.g. Direct Tax Analyst</text>
      </textAnnotation>
      <textAnnotation id="sid-8F4C0EA1-6D66-469E-8C1F-1C988C1074AC" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Quarterly state adjustments are considered, and the state rate is reviewed for reasonableness. State return to provision and stated ending DTA's are reviewed once a year.</text>
      </textAnnotation>
      <textAnnotation id="sid-06B32F34-0501-432B-8367-4ACCA34F2D49" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
