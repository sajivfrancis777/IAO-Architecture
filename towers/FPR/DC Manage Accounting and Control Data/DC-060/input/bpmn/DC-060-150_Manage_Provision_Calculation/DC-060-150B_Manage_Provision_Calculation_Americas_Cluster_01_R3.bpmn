         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-4A1314D2-A97A-4167-A3FE-252C2E06D5C9" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/250f7fc1c6254d97b8371e6df3e91188</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
