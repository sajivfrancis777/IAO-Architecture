         <text>Microsoft Excel</text>
      </textAnnotation>
      <textAnnotation id="sid-4503FE81-EA72-47CF-9E6C-1679EF160EFC" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Prepared JE is Approved by Designated Global Tax Accountant or Global Tax manager</text>
      </textAnnotation>
