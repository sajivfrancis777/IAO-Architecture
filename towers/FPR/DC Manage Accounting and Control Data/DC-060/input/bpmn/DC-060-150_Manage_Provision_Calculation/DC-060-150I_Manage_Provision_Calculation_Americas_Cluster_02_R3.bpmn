<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_76b1e250-9748-4acd-9708-ebd85c5e9235" name="DC-060-150_Manage Provision Calculation" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-8c2755cd-df46-470e-b7fc-6d5792b1d97a">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="The &quot;Manage Provision Calculation&quot; process involves calculating, recording, and managing provisions within an organization's financial statements. Provisions, which are liabilities with uncertain timing or amounts, are recognized when an organization incurs a present obligation (either legal or constructive) due to past events.&#10;Book income (including transfer pricing adjustments) is retrieved from SAP (actual) and POR (forecast) obtained from Corporate Planning or Entity Accountants. &#10;Forecasted M adjustments are calculated. &#10;Quarterly state adjustments are considered, and the state rate is reviewed for reasonableness. State return to provision and stated ending Deferred Tax Assets (DTAs) are reviewed annually.&#10;The forecasted effective tax rate, DTAs, and Deferred Tax Liabilities (DTLs) are calculated. &#10;After the year-end, the return to provision recalculates the effective tax rate.&#10;Journal entries (JEs) are prepared and, once approved by the designated global tax accountant or global tax manager, are sent to the SEC for disclosure along with supporting documents."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Cook, Paula&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="20/09/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Email Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 02 - Tax/DC-060 Manage Taxes/R3S7/Direct Tax/Fwd_ DC-060-150 Manage Provision Calculation Process Flow %26 Attributes Americas Cluster 02 and APJ Cluster 04.pdf?csf=1&amp;web=1&amp;e=bMKQl5&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="8e225ed082eb44139d792e648d561b3f"/>
      </extensionElements>
