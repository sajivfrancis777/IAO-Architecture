<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-2b53a63e-947d-4fa9-aefc-26a0ef3ec934" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-5246a46d-46f2-4bca-8f31-03c2778f24da">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="*This flow is combined with the DC-060-040E Manage Withholding Tax Determination - Customer Data_Amercias Cluster 02.&#10;&#10;&#10;The Withholding Certification Receivable Collection process includes the following activities: Issue a certificate of residency to the customer with Intel's local EIN number. Customer then determines if the service Intel is providing is applicable for WHT and/or subject to reduced treaty rates. Set up withholding tax type and tax code for each country where there is an entity, and assign that tax code to every customer that is NOT within the same country (foreign customer). Issue an invoice to customer. Customer then short-pay the WHT, which is then posted to appropriate WHT accounts (could be a contra-receivable or expense account). WHT report then shows the country of the customer. It also tracks the remittance of WHT withheld by the customer for each certificate. It is either required by law or as requested that customer provides Intel the receipt of WHT paid (local requirement).&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Jain, Priya&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="16/09/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Linked sub-process approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Email Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 02 - Tax/DC-060 Manage Taxes/R3S7/WHT/[EXT] RE_ R3S7 - WHT Signavio flow .pdf?csf=1&amp;web=1&amp;e=rTaMDc&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="57c9e6ba5bdb4b7f84bdf77bfc781080"/>
      </extensionElements>
