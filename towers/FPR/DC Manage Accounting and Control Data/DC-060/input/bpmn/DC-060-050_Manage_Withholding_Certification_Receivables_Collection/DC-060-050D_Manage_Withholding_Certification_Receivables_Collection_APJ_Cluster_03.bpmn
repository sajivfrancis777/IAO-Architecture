<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-55b23749-11b3-4815-bd2e-9d076bccd01e" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-ec7d6dd2-e644-41c2-9add-b01ec4ef849a">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="*This flow is combined with the DC-060-040 Manage Withholding Tax Determination - Customer Data_APJ Cluster 03.&#10;&#10;&#10;The Withholding Certification Receivable Collection process includes the following activities: Issue a certificate of residency to the customer with Intel's local EIN number. Customer then determines if the service Intel is providing is applicable for WHT and/or subject to reduced treaty rates. Set up withholding tax type and tax code for each country where there is an entity, and assign that tax code to every customer that is NOT within the same country (foreign customer). Issue an invoice to customer. Customer then short-pay the WHT, which is then posted to appropriate WHT accounts (could be a contra-receivable or expense account). WHT report then shows the country of the customer. It also tracks the remittance of WHT withheld by the customer for each certificate. It is either required by law or as requested that customer provides Intel the receipt of WHT paid (local requirement).&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Jain, Priya&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="19/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Linked sub-process approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/sites/inteldeloitteiao/Shared Documents/Forms/AllItems.aspx?id=%2Fsites%2Finteldeloitteiao%2FShared Documents%2FGeneral%2FImplementation%2F03. FPR%2F3 Final Deliverables%2F05. Process Approval Evidence%2FTeam 02 - Tax%2FDC-060 Manage Taxes%2FR3S6%2FWHT Signavio flow APJ01%2C APJ03%2C EMEA03 .pdf&amp;parent=%2Fsites%2Finteldeloitteiao%2FShared Documents%2FGeneral%2FImplementation%2F03. FPR%2F3 Final Deliverables%2F05. Process Approval Evidence%2FTeam 02 - Tax%2FDC-060 Manage Taxes%2FR3S6&quot;}]"/>
