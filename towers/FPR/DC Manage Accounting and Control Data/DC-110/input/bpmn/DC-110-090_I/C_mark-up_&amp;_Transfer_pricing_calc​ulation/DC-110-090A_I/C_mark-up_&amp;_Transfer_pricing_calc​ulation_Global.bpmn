   <collaboration id="sid-fcb6a482-9764-402a-bf92-09fe35152d0d">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Intercompany mark up and transfer pricing are two critical componenets of the intercompany process that involve determining the price of good or services exchanged between companies within the same corporate group or parent company.&#10;&#10;Intercompany mark up refers to the additional amount added to the cost of good or services by the selling company to account for expenses such as overheads cost, profits or taxes.&#10;&#10;Transfer pricing , on the other hand , refers to the price at which good and services are sold between two companies within the same corporate group."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Lim, Alicia Jia Ping&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="21/10/24"/>
