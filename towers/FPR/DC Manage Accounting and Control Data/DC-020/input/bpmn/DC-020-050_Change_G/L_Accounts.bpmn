   <collaboration id="sid-027c72a1-7ffc-4e73-9270-948226cb6425">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="After the approval of a general ledger (GL) maintenance request, accounts can be deleted or changed within the GL. This requires updating the appropriate account file/table. Deleting accounts differs from changing accounts.  After approving the deletion of an account, the account is marked for deletion.  This flags the account, and whenever an attempt is made to post to this account, a warning message appears.  Periodically, a program is run to delete all records that have been marked for deletion."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Jiang, Huiying &lt;huiying.jiang@intel.com&gt;&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="11/04/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved in Collaboration HUB by Business"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="6210f2f512644c33be48725b2c9ced88"/>
      </extensionElements>
