   <collaboration id="sid-e6a7438a-206f-40ee-834b-0d81006c35c0">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="This activity ensures that all the correct accounts are grouped with their respective financial statement classifications for external reporting. As an example, accounts relating to marketable securities and cash should be grouped under current assets.  Also, for internal reporting, this activity ensures that accounts needing to be reported together for management reporting requirements reflect any changes occurring as a result of maintenance performed to the chart of accounts."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Jiang, Huiying &lt;huiying.jiang@intel.com&gt;&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="11/04/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved in Collaboration HUB by Business"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="f42b4516d29544f9817689cf24092236"/>
      </extensionElements>
