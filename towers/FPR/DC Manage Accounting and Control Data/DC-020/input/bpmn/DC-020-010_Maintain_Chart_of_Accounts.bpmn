   <collaboration id="sid-619f955a-0e7f-4f16-93ca-a34a4fdcc437">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Companies must maintain a chart of accounts for reporting purposes.  Accounts are maintained in groups in the chart of accounts.  Some companies may utilize more than one chart of accounts (depending on countries of operation, or special reporting requirements).  The chart of accounts should be reviewed periodically to ensure that all necessary accounts are included, and no obsolete accounts are maintained."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Jiang, Huiying &lt;huiying.jiang@intel.com&gt;&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="11/04/24"/>
