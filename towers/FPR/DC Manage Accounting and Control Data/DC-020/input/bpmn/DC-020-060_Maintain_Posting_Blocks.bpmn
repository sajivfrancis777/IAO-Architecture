      <userTask completionQuantity="1" id="sid-17C0BFA7-FDFB-4D85-A628-99AE35D63A26" implementation="##WebService" isForCompensation="false" name="DC-020-060-060&#10;Perform Block / Unblock G/L Accounts Validation" startQuantity="1">
         <documentation id="sid-22f80343-2c0b-4e7f-8dcc-2db4ae685c3b">
</documentation>
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFCC"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-jobprofile" metaValue="/glossary/ec8608c22a6d4691ac87adaa5627efd2"/>
            <signavio:signavioMetaData metaKey="meta-screenfloriapps" metaValue="[&quot;/glossary/4c9b272e95704440959721109ca5ebd4&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-system" metaValue="[&quot;/glossary/433d6e59a61448faaf7f272e66f55e61&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-securityrole" metaValue="[&quot;/glossary/62e3de3e5a4f48cdb6d6d295b1abbccd&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci170436614738196523502"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="It is expected to perform below validations (against all 3 instances):&#10;​&#10;1. ending balance as of now should be zero. Hard error for any levels in the workflow if validation fails. ​&#10;2. If the GL account is an OIM or a Recon account, there should be no open items. Hard error for any levels in the workflow if validation fails.​&#10;3. The GL account is not mapped with any active commodity code. Hard error for any levels in the workflow if validation fails.​&#10;4. Account should not be active for Revenue Account Determination (VKOA/C711), Service Revenue account determination (VKOA/C713), Exchange rate difference posting (OB09), material valuation (OBYC/T030), tax determination (OBYC/T030K), vendor recon account (XK02/LFB1), Customer recon account (FD02/KNB1), vendor downpayment (OBXB/T074)."/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/dbb3746f43bc4d218e7c0835b8d8fe3b&quot;]"/>
         </extensionElements>
         <incoming>sid-B201E6EA-0D99-4CF5-AD17-2AB5BADE38DE</incoming>
         <outgoing>sid-D9DF4D28-AAE8-4491-9019-6DC13B99E5A7</outgoing>
      </userTask>
      <exclusiveGateway gatewayDirection="Diverging" id="sid-22B97EA3-CB55-4004-AB4F-B72B20D1C209" name="Validation&#10; Successful ?">
