   <collaboration id="sid-0cdbf573-9a6e-40dc-b8e8-ce663495f4c4">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Preparing the budget can be accomplished in a number of ways.  Some companies use a top-down, while others a bottom-up approach in budget preparation. Careful delineation of line participation and responsibility versus finance staff responsibility is of considerable consequence.  To align responsibility, authority and accountability, the operations staff should be committed to develop, implement and attain business unit objectives. They must view the plan and budgets as their own and use it as a tool to guide them in implementing strategic initiatives. The finance staff, in contrast, is responsible for facilitating and coordinating the process, improving the system, providing technical assistance, providing analysis and advice to line management and preparing the consolidated view for top-management review and approval. These plans may include a marketing forecast, which will drive sales targets and production plans. Research and development plans are entirely independent of current forecasts."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Tames, Daniela&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="31/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 08 - Financial Planning %26 Analysis/MB-070 Prepare Budgets/MB-070-050, MB-070-120.msg?csf=1&amp;web=1&amp;e=5kfm7f&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="da0dd96328e841e1b96fd65dd428a1f5"/>
      </extensionElements>
