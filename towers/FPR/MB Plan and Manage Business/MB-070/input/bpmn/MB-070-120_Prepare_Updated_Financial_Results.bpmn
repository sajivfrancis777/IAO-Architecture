   <collaboration id="sid-11a95782-81da-4612-879a-2ba8e8b122ce">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="After all reconciliations and required changes are made, corporate finance personnel consolidate all the budgets to provide a final enterprise-wide view of the organization. Consolidation has to be two-dimensional: program and business unit level.  Numerous iterations are involved, as all final details are resolved.  There can be several meetings at various levels of management to get closure.  This is typically where many companies get bogged down."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Tames, Daniela&quot;]"/>
