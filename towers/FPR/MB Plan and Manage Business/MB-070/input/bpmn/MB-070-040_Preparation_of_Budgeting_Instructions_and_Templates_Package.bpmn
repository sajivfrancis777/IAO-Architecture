   <collaboration id="sid-06d8c023-14d7-48d3-8440-0d4a4c453ec7">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Preparation of budgeting instructions and template packages will most likely originate from Finance, with logistics support. These are activities related to defining and communicating budgeting policies, guidelines, timetables, schedules and templates. The budgeting package should include non-financial parameters and targets.  An electronic version of the package is preferred, since this will reduce the amount of manual input, improve accuracy and facilitate the time to consolidate.  There needs to be prior discussion on the level of detail required."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Tames, Daniela&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="26/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 08 - Financial Planning %26 Analysis/MB-070 Prepare Budgets/MB-070-040, 060, 090, 100, 110.msg?csf=1&amp;web=1&amp;e=9grigP&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="8edb7ed650b24fd8a6c6ab49264b5c61"/>
