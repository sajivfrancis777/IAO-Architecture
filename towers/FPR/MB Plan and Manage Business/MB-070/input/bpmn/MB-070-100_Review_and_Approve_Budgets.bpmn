<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_3ed516c0-f99e-42dc-b5b2-16037801c230" name="MB-070-100_Review and Approve Budgets" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-b6d105b1-cafd-49a3-ab95-37c792209e11">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Reconciliation with the Financial Plan is test for reasonableness.  It is to ensure that operating and supporting entities and segments have adhered to the commitments in their 3-5 year Business and Financial Plans (and strategies).  Variances need to be clearly understood, analyzed and reported to senior management by Finance. This is an iterative process that may require the refining or revisiting of Business and Financial Plans, particularly if large variance are reported.  Reconciling is far trickier than first anticipated.  The technology supporting the budgeting process will facilitate this activity; however, it is common to first roll-up and consolidate the budgets by legal entity or organizational reporting structure/divisions.  This is followed by carving out portions of a budget contributing to the support of products/brands/markets/customers (horizontal planning).  It also may involve overhead or Corporate allocations to these segments.  Note:  The program financial plan and the business unit financial plan are identical values since they represent two different views of the organization (horizontal and vertical)."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Tames, Daniela&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="26/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/sites/inteldeloitteiao/Shared Documents/Forms/AllItems.aspx?id=%2Fsites%2Finteldeloitteiao%2FShared Documents%2FGeneral%2FImplementation%2F03. FPR%2F3 Final Deliverables%2F05. Process Approval Evidence%2FTeam 08 - Financial Planning %26 Analysis%2FMB-070 Prepare Budgets%2FMB-070-040%2C 060%2C 090%2C 100%2C 110.msg&amp;parent=%2Fsites%2Finteldeloitteiao%2FShared Documents%2FGeneral%2FImplementation%2F03. FPR%2F3 Final Deliverables%2F05. Process Approval Evidence%2FTeam 08 - Financial Planning %26 Analysis%2FMB-070 Prepare Budgets&quot;}]"/>
