         </extensionElements>
         <text>Memo record interfaces Quantum</text>
      </textAnnotation>
      <textAnnotation id="sid-ACC2AE59-9C66-4771-97A8-71C446AECFB3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>TFR request can be created by HR, TAX, AP, Misc and TR team</text>
      </textAnnotation>
