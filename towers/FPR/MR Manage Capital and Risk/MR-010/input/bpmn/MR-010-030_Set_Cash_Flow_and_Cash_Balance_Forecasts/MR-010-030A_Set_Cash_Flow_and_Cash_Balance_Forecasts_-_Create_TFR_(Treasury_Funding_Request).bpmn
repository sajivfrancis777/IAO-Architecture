      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Finance Plan To Report
Process Group: MR Manage Capital and Risk
Process: MR-010-030A Set Cash Flow and Cash Balance Forecasts - Create TFR (Treasury Funding Request)</text>
      </textAnnotation>
      <textAnnotation id="sid-F8B39D49-4ED1-4069-B121-58095B4E74DE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Applies only for Treasury Requestors</text>
      </textAnnotation>
      <textAnnotation id="sid-29A25415-D636-41C4-8C6A-35B1EC761F4A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
