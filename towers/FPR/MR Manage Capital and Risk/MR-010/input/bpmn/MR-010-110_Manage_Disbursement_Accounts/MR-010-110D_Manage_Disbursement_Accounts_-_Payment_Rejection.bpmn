<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_5d309097-2a9c-46f5-a719-ecfedb9626e5" name="MR-070-060_End of Day Period End Accounting" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-563da03c-4878-4ced-b556-bbfc2d4056aa">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Aggressive cash management does not allow business units to draw down their cash balances from the consolidated account at will. Instead their disbursement forecasts are used by Treasury to periodically fund the disbursement accounts of each business unit. This imposes a certain discipline on the system. In the extreme case, all disbursements are actually handled centrally - but this implies separating the management of supplier relations from management of supplier payments with all its attendant risks given the strategic importance of managing the whole value chain to many of today’s enterprises.  Again, day to day management of this process relies on effective banking infrastructure on the disbursement side - see the discussion below in Establish And Maintain Optimal Banking Architecture."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Praveen Singh&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="07/11/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 09 - Treasury %26 Cash Management/MR- 10 Manage Liquidity/MR-010-110 A, B. C, D.msg?csf=1&amp;web=1&amp;e=F5qsvJ&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="61a4967aad1149b7b230be325ada2f20"/>
      </extensionElements>
