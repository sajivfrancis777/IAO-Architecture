   <collaboration id="sid-1dc115e2-816b-4eeb-9c2f-6f9f0e5f71ea">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Aggressive cash management does not allow business units to draw down their cash balances from the consolidated account at will. Instead their disbursement forecasts are used by Treasury to periodically fund the disbursement accounts of each business unit. This imposes a certain discipline on the system. In the extreme case, all disbursements are actually handled centrally - but this implies separating the management of supplier relations from management of supplier payments with all its attendant risks given the strategic importance of managing the whole value chain to many of today’s enterprises.  Again, day to day management of this process relies on effective banking infrastructure on the disbursement side - see the discussion below in Establish And Maintain Optimal Banking Architecture. This process was the best fit for managing Treasury payments which are Intercompany, but not ZBA / AR-AP related."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Praveen Singh&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="07/11/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Approved via email"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/03. FPR/3 Final Deliverables/05. Process Approval Evidence/Team 09 - Treasury %26 Cash Management/MR- 10 Manage Liquidity/MR-010-110 A, B. C, D.msg?csf=1&amp;web=1&amp;e=F5qsvJ&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="a8c8a5f70e0f47488f23d2b04f64b712"/>
      </extensionElements>
