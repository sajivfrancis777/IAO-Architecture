            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP Connector monitor (Tcode /BSNAGT/MONITOR is used to monitor your incoming as well as outgoing files send or received via MBC</text>
