         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP Connector monitor (Tcode /BSNAGT/MONITOR is used to monitor your incoming as well as outgoing files send or received via MBC</text>
      </textAnnotation>
      <textAnnotation id="sid-7987A46E-A2FB-4D49-B5E6-31FA53916BF3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Only Quantum acknowledgement messages will go to Quantum</text>
      </textAnnotation>
