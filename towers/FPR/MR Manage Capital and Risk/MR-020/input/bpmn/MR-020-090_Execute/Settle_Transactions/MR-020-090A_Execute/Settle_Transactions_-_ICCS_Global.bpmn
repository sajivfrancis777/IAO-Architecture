      <textAnnotation id="sid-550E2A99-B802-4B9C-A8FB-61322525ACDD" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Payment Program generates the payment data </text>
      </textAnnotation>
      <textAnnotation id="sid-318FB526-F849-4172-B097-6597DDF5C08F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Invoices are created in IF/IP systems and imported them to CFIN system </text>
      </textAnnotation>
      <textAnnotation id="sid-A811B855-C58C-4985-8A44-9BDA31A82010" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Sent by MBC </text>
      </textAnnotation>
      <textAnnotation id="sid-DB3F25F3-0F90-48AF-A338-E1DCECBF869D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP Connector monitor (Tcode /BSNAGT/MONITOR is used to monitor your incoming as well as outgoing files send or received via MBC</text>
      </textAnnotation>
      <textAnnotation id="sid-4F00BECB-76C2-4F2E-BBFE-FBE6AFE26E2A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Received by MBC </text>
      </textAnnotation>
      <textAnnotation id="sid-EC6315A0-75A8-4A88-AE6E-C40785D5D904" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Payment Files  (Pain001/MT210/CAMT.057) are created here</text>
      </textAnnotation>
      <textAnnotation id="sid-8D55DE34-1890-414D-840A-6A369A46D499" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Bank NACK will be handled by OET Analyst at Banking portal</text>
      </textAnnotation>
