      <textAnnotation id="sid-3D1CA5D0-7D0B-4457-A194-ACA5758C9E5E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Rejected</text>
      </textAnnotation>
      <textAnnotation id="sid-9CE2C3A7-B9FA-4A74-9819-2C4694ABF433" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
