      <textAnnotation id="sid-3D1CA5D0-7D0B-4457-A194-ACA5758C9E5E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Rejected</text>
      </textAnnotation>
      <textAnnotation id="sid-C7B44793-5186-4EC2-A851-5B2BEA6E1C34" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
