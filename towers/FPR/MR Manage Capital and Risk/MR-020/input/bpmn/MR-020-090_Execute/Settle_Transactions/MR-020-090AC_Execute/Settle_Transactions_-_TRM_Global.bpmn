         </extensionElements>
         <text>SAP S/4HANA (cFIN)</text>
      </textAnnotation>
      <textAnnotation id="sid-F1181545-33E4-4B15-8DED-15F5DF84FCA7" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/465881c7891247ff91b3be4b55e5a6d1</signavio:dictionaryLink>
