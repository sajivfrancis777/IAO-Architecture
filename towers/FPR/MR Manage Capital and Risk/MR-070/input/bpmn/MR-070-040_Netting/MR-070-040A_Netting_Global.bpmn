         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>In the event of not sufficient time to resolve the issue, manual journal entry is required to perform monthly cross period cashless settlement</text>
      </textAnnotation>
