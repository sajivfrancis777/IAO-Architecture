         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>AP - Accounts Payable
AR - Accounts Receivable</text>
      </textAnnotation>
      <textAnnotation id="sid-467D00DB-3691-49D4-B53F-ABCE6737CD0E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Items are blocked for lack of supporting or other reason we don’t want to settle.</text>
      </textAnnotation>
