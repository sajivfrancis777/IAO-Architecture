      <textAnnotation id="sid-F575CAFD-7472-4926-8688-3D0A3805308F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>System does the posting</text>
      </textAnnotation>
      <textAnnotation id="sid-9096A67F-ACBD-46EB-B9CC-3B8EB6FF061D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Reverse the payment request</text>
      </textAnnotation>
      <textAnnotation id="sid-AB54D34E-F5B7-478F-B54F-C044D5C4F702" signavio:alignment="left">
         <extensionElements>
