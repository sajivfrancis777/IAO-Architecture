            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffff"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Intercompany Accountant</text>
      </textAnnotation>
      <textAnnotation id="sid-5B6DC550-AB6A-4ECF-BC4C-1A7BEE0B6176" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Superusers will have access to reverse the transactions</text>
      </textAnnotation>
      <textAnnotation id="sid-28AF5D04-6144-4B0E-A0D2-DE4904DA815C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>If its IC Accountant Payment, the team will reach out to the TR team for Bank</text>
      </textAnnotation>
