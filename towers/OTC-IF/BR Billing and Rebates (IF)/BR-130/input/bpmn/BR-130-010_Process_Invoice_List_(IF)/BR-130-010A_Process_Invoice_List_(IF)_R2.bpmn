      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: OTC-Order To Cash
Process Group: BR-Billing and Rebates
Process Name: BR-130-010A Process Invoice List (IF)_R2</text>
      </textAnnotation>
      <textAnnotation id="sid-85E38A83-5DDA-436B-909C-947B538BBC84" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-7D83AD4D-1E09-4967-B5A0-7AEEC71E540B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Individual billing documents will be created at a Payer Level</text>
      </textAnnotation>
      <textAnnotation id="sid-6C9423C6-FF0B-4817-9A1B-E99A1F1F5F05" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Billing Document will be created by Billing Due List batch Job
2. Manage billing document app can be used for the posting status monitoring 
3.IT ticket can be raised to resolve the billing batch job issue
4.Invoice list will be generated with individual billing documents</text>
      </textAnnotation>
      <textAnnotation id="sid-5780C413-581A-4268-8378-0278B6295C84" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Summary page followed by individual billing documents combined in one single PDF.</text>
      </textAnnotation>
      <textAnnotation id="sid-1C64CC4E-25AE-402A-949C-144C2175A647" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Prerequisite:
 output condition record to be maintained</text>
      </textAnnotation>
   </process>
