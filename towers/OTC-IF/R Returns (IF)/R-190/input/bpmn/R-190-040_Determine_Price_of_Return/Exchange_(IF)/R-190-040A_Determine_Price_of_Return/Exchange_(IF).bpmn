      <textAnnotation id="sid-D164E123-B8EC-4A01-BC38-8883C14B4F1C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Sales Area (Sales organization,
Distribution channel, Division) should be available during sales order creation
2. Customer Pricing Procedure will be derived from "Sold to Party"
3. Pricing Procedure will be derived from Sales Order type</text>
      </textAnnotation>
