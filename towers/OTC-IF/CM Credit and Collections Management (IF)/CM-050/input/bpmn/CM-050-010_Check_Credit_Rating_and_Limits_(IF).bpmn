   <collaboration id="sid-6a168b90-037f-4e9d-9476-62c9652a6538">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="This process explains the three (3) main credit checks performed on Sales Orders:  &#10;1) Credit check triggered at time of Order Create/Change based on Customer Credit Line availability, Customer Credit Line Valid To/Expiry Date and Customer Payment Performance Check rules.  &#10;2) Credit check triggered when Sales Orders entering the 14 days horizon window.  &#10;3)  Credit Check triggered automatically for blocked Sales Orders considering changes to Customer Payment info.  During credit checks, system takes into account customer available credit line as well as their total credit exposure which includes the cumulative value of the sales order backlog, deliveries, open billings &amp; outstanding receivables"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Nguyen, Linda Y linda.y.nguyen@intel.com, Monfared, Shahin &lt;shahin.monfared@intel.com&gt;&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="12/08/24"/>
