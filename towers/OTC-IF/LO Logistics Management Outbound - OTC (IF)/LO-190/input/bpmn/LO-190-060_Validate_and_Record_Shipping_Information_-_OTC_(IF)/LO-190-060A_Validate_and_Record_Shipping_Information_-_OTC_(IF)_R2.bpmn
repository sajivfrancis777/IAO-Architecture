         </extensionElements>
         <text>Process Tower: Order To Cash
Process Group: LO Logistics Management Outbound
Process Name: LO-190-060A Validate and Record Shipping Information</text>
      </textAnnotation>
      <textAnnotation id="sid-0B7C81AC-D684-45FB-AB79-E01449D35437" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>
Can Generate report for:-
Freight Unit​
Freight Order / Booking​
Freight Settlement
Transportation Execution​
Transportation Network​
Carrier Rate​
Manage Transportation Requirement​
Planning Transportation ​
</text>
      </textAnnotation>
