      <textAnnotation id="sid-01F555F1-C9A1-428D-84D3-754F4F4662E6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process tower: OTC-Order To Cash
Process Group: O-Order Management
Process: O-020-100B Create Standard Order PO-SO (IF)_R3</text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening outside of O-020-100B Create Standard Order PO-SO (IF)_R3  and are covered in subsequent L3s</text>
      </textAnnotation>
      <textAnnotation id="sid-F176F356-BB71-4673-981F-35A147C3B957" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. FSCM stands for Financial Supply Chain Management
</text>
      </textAnnotation>
