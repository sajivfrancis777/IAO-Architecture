      <textAnnotation id="sid-D7034E6F-9D70-4D4B-98C7-C77B8237E762" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Price Changes due to Price Override will be considered during price calculation</text>
      </textAnnotation>
      <textAnnotation id="sid-874328BC-3695-4CA2-BBE5-A657C7E12CA7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IMO orders will be created 
with IMO item category. 
The Item category 'ZTD2'
will have default billing block. 
This billing block will be 
removed manually by 
the CBA once masking 
services have been rendered</text>
      </textAnnotation>
      <textAnnotation id="sid-7869ABD5-551B-4F22-AE09-AE6DCFBC3AD6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
