      <textAnnotation id="sid-D7034E6F-9D70-4D4B-98C7-C77B8237E762" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Price Changes due to Price Override will be considered during price calculation</text>
      </textAnnotation>
      <textAnnotation id="sid-14246900-55CA-43E7-80BD-13D5F4C37343" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Update Plant Based On Customer Direction</text>
      </textAnnotation>
      <textAnnotation id="sid-874328BC-3695-4CA2-BBE5-A657C7E12CA7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IMR orders will be created 
with IMR item categories: 
ZRRS - Repairs Service Resources
ZRRE - Return for Repairs
ZRAL  - Repair Goods Delivery</text>
      </textAnnotation>
      <textAnnotation id="sid-7869ABD5-551B-4F22-AE09-AE6DCFBC3AD6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Document Type ZRA</text>
      </textAnnotation>
