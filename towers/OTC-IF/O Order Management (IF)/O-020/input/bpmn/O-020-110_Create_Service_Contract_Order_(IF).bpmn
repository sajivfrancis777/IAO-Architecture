      <textAnnotation id="sid-5F4AA0FA-A234-483F-BAA2-7C4F64FEA446" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. MMID stands for Material ID and CPN stands for Customer Part Number</text>
      </textAnnotation>
      <textAnnotation id="sid-39A7702F-C1B2-4D76-A61E-3BCF98FED836" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
