      </textAnnotation>
      <textAnnotation id="sid-E0965BF1-7E08-4158-A4D2-7052DEA12A11" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. No inventory check, credit check will be performed for Service Contract Orders.</text>
      </textAnnotation>
      <textAnnotation id="sid-5963163B-BF0C-4B16-B2BD-825351E5B9F7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Call-off orders will be created referencing Service Contract Order
2. Call-off Order will follow Standard Order process</text>
      </textAnnotation>
