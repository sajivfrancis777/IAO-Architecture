   <collaboration id="sid-b9cce66a-0eaf-4bf5-8868-559270e6d634">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="An inter-company business transaction is where sales transactions (sales orders and billing documents) for the sale of materials are carried out in a company code different from that used for the storage, production, and delivery of those materials. E.g., Company code A orders goods through its sales organization A from Plant B belonging to Company code B. It is imperative that both Plants A &amp; B should contain master data records for the materials ordered by the customer. In other words, the material is created for both the Plants A and B and their respective storage locations"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;ajay.pandurangi@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="26/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Reopened, Approved Again on 5th November 2024. &#10;Mail: IF_R3_PO-SO Process Flows Advanced Intercompany Updates in the PO-SO Process Flows.msg"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Evidence&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared%20Documents/General/Implementation/04.%20OTC%20-%20Intel%20Foundry/4%20Design%20Working%20Documents/Approvals%20IMR%20Signavio/EXT%20RE%20IF-POSO%20Capture%20order%20Process%20Flows%20%20Review%20%20R3%20Sprint%206.msg?csf=1&amp;web=1&amp;e=BvdSoc&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="2a1caf50cabd4dd9b4586a5a2dcad860"/>
      </extensionElements>
