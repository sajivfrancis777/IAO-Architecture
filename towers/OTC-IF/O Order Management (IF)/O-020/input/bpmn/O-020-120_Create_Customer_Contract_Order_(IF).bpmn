      <textAnnotation id="sid-5F4AA0FA-A234-483F-BAA2-7C4F64FEA446" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. MMID stands for Material ID and CPN stands for Customer Part Number</text>
      </textAnnotation>
      <textAnnotation id="sid-39A7702F-C1B2-4D76-A61E-3BCF98FED836" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-E0965BF1-7E08-4158-A4D2-7052DEA12A11" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. No inventory check, credit check will be performed for Customer Contract Orders.</text>
      </textAnnotation>
      <textAnnotation id="sid-5963163B-BF0C-4B16-B2BD-825351E5B9F7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Call-off orders will be created referencing Customer Contract Order
2. Call-off Order follow Standard Order process</text>
      </textAnnotation>
      <textAnnotation id="sid-FAD370C0-A305-4211-8400-C498F64666C8" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-3A3F6449-C7EB-424A-8BAF-90E15F4D175D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Customer Contract have requirements for Products and Services.</text>
      </textAnnotation>
