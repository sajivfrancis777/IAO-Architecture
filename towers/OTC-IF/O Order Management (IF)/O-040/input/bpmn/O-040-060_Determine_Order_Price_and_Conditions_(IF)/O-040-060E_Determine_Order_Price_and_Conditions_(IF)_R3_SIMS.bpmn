         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-6E2C70DF-995D-4694-905C-54A42956AA35" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-02FC5D9D-0347-427E-97C7-0024F729E6EA" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-AC7A228F-0859-475F-BE7A-F85985E72FDA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Order Type : ZSI3</text>
      </textAnnotation>
      <textAnnotation id="sid-7FA8893F-4263-43B6-9D27-49DD22FBEAC5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. MMID stands for Material ID and CPN stands for Customer Part Number</text>
      </textAnnotation>
      <textAnnotation id="sid-B61F77A6-2D82-449D-9229-BED69C66B8BE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. FSCM stand for Financial supply chain Management</text>
      </textAnnotation>
      <textAnnotation id="sid-59FC854F-E4F4-4D9C-8513-E3A848CFFED2" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1)SIMS Process with IP and External Customer
 2)Cost from Material master is loaded to Condition ZPRS 
Mark up ZMRK will be added taking the cost as the Basis
OR
If ZCPR (Customer price) available - The same is prioritized 
3)Mark Up is loaded by Price analyst</text>
      </textAnnotation>
      <textAnnotation id="sid-E67AC940-817D-4C1C-BEB1-A53CA6D60FF9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="18.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="18.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>1)IF To IF Internal Sales : Cost +Mark up Model
2)Cost from Material master is loaded to Condition ZPRS 
3)Mark up ZMUP will be added taking the cost as the Basis .Mark up is loaded by Intercompany Finance team</text>
      </textAnnotation>
      <textAnnotation id="sid-01F555F1-C9A1-428D-84D3-754F4F4662E6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process tower: OTC-Order To Cash
Process Group: O-Order Management
Process: O-040-060E Determine Order Price and Conditions (IF)_R3_SIMS</text>
      </textAnnotation>
   </process>
