      <textAnnotation id="sid-E67AC940-817D-4C1C-BEB1-A53CA6D60FF9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="18.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="18.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>1)IF To IF Internal Sales : Cost +Mark up Model
2)Cost from Material master is loaded to Condition ZPRS 
3)Mark up ZMUP will be added taking the cost as the Basis .Mark up is loaded by Intercompany Finance team</text>
      </textAnnotation>
   </process>
