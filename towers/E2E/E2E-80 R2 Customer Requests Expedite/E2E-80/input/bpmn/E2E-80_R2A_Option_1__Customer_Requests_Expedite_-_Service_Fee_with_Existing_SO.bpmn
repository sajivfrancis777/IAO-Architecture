      <textAnnotation id="sid-813B9249-8623-4877-9AA2-BA5191AEFF60" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Cascading feed to prioritize the order</text>
      </textAnnotation>
      <textAnnotation id="sid-05382191-19B3-4D17-838C-72C97EB8C70B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Factory &amp; Related Apps: Scheduler, Kitting, MES, CIBR, ISET, MPL, Prospal, Spectrum, Waybill, Ship Memo 

2. Refer Manufacturing E2E-74 flow and Architecture Diagram to understand detailed level interfacing

</text>
      </textAnnotation>
      <textAnnotation id="sid-B022CE2C-B9FD-48DB-9C5D-3EFAC12F73D8" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>ECA</text>
      </textAnnotation>
      <textAnnotation id="sid-63830BBF-464B-41F6-BDF3-B4C19700D9E7" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Hana</text>
      </textAnnotation>
      <textAnnotation id="sid-1B16C55B-C940-4F2E-A65F-4E7480763FAA" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SPAN</text>
      </textAnnotation>
      <textAnnotation id="sid-0A5679D6-5BFD-46CA-8F17-5A3E5847174A" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Planning Engine
(XTO)
</text>
      </textAnnotation>
      <textAnnotation id="sid-9F160B5E-9E5F-4049-A879-D7B9879A375C" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Factory &amp; Related
 Boundary Apps</text>
      </textAnnotation>
      <textAnnotation id="sid-EFDEC2F5-7F43-43A0-BDB0-0696815A4142" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Assessment Based on As-Is process</text>
      </textAnnotation>
      <textAnnotation id="sid-DEA90186-8CAC-4D93-958D-32E5F4171D3D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual registration of expedite request from Customer to CBA/Marketing Team</text>
      </textAnnotation>
      <textAnnotation id="sid-EC4DB2D7-5E95-4042-8CB0-AD6D365350A0" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual Assessment by CBA/Marketing Team on feasibility of request from customer based on inputs from Factory </text>
      </textAnnotation>
      <textAnnotation id="sid-6EA023B1-F6EB-4E37-80A1-0BC6FBC7F675" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>(Complete or Partial expedite based on agreement with customer)</text>
      </textAnnotation>
      <textAnnotation id="sid-1F680808-5F84-4041-AC11-8B6B7B16A122" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Decision to create new Sales Order or update existing SO with service line item
</text>
      </textAnnotation>
      <textAnnotation id="sid-9BF367D4-4026-4A29-878B-BD44E58B8EF3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Preloaded condition types</text>
      </textAnnotation>
      <textAnnotation id="sid-58EAA548-FBEA-4A6A-BB0D-08F9F1B56423" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>On new RDD on existing line item</text>
      </textAnnotation>
      <textAnnotation id="sid-7B3201F1-8433-48A4-9E55-89720977DAA5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. New CDD (CBA can be override CDD manually)
2. CBA to communicate revised CDD and expedite fee
</text>
      </textAnnotation>
      <textAnnotation id="sid-EDD4F10C-692A-49D1-8E85-733212160A28" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual Vs automatics pricing condition types
</text>
      </textAnnotation>
      <textAnnotation id="sid-2B295CF9-CA3F-4D33-A022-92880D84C3E5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> DR: Customer (Account Receivable}
CR:  Sales Revenue
Cr . Taxes (if applicable)</text>
      </textAnnotation>
      <textAnnotation id="sid-640D18AE-3283-40F9-86CB-821D90C56AB6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This entry will be technically cleared based on IDOC process</text>
      </textAnnotation>
      <textAnnotation id="sid-F398FCBB-10A8-4419-994C-4E4EF48A4C08" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>can be shipped to customer against sales order</text>
      </textAnnotation>
      <textAnnotation id="sid-26A53B09-2EEF-481B-B904-9023BF365E0B" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Trade 
Compliance</text>
      </textAnnotation>
      <textAnnotation id="sid-A9FFFAB5-9B2F-4961-B5A5-655739EF102A" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Check</text>
      </textAnnotation>
      <textAnnotation id="sid-C28B1EE3-D328-4117-B0C0-27DB05CA030E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>CIBR</text>
      </textAnnotation>
      <textAnnotation id="sid-9F960073-89A8-4756-BA4C-AEA169B80DA9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> DR: Customer (Account Receivable}
CR:  Sales Revenue
Cr . Taxes (if applicable)</text>
      </textAnnotation>
      <textAnnotation id="sid-15831149-47A8-4C17-B140-72B6D8CD8E9B" signavio:alignment="left" textFormat="text/plain">
