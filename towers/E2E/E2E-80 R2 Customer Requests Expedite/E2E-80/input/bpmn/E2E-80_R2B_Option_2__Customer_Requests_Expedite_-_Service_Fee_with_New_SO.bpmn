            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>ECA</text>
      </textAnnotation>
      <textAnnotation id="sid-63830BBF-464B-41F6-BDF3-B4C19700D9E7" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
