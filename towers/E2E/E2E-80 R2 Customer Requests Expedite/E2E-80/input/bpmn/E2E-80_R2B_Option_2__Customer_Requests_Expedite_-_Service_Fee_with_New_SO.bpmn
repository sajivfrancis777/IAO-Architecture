         <text>Planning Engine
(XTO)
</text>
      </textAnnotation>
      <textAnnotation id="sid-9F160B5E-9E5F-4049-A879-D7B9879A375C" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Factory &amp; Related
 Boundary Apps</text>
      </textAnnotation>
      <textAnnotation id="sid-EFDEC2F5-7F43-43A0-BDB0-0696815A4142" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Assessment Based on As-Is process</text>
      </textAnnotation>
      <textAnnotation id="sid-DEA90186-8CAC-4D93-958D-32E5F4171D3D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual registration of expedite request from Customer to CBA/Marketing Team</text>
      </textAnnotation>
      <textAnnotation id="sid-EC4DB2D7-5E95-4042-8CB0-AD6D365350A0" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual Assessment by CBA/Marketing Team on feasibility of request from customer based on inputs from Factory </text>
      </textAnnotation>
      <textAnnotation id="sid-6EA023B1-F6EB-4E37-80A1-0BC6FBC7F675" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>(Complete or Partial expedite based on agreement with customer)</text>
      </textAnnotation>
      <textAnnotation id="sid-1F680808-5F84-4041-AC11-8B6B7B16A122" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Decision to create new Sales Order or update existing SO with service line item
</text>
      </textAnnotation>
      <textAnnotation id="sid-A37E7133-A16B-41B4-B272-5B9B9BD05547" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Alignment of expedite fee post goods issue based on Actual Delivery date &amp; T&amp;Cs</text>
      </textAnnotation>
      <textAnnotation id="sid-375895DE-7C22-4E95-82F4-32F8797AF306" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual Vs automatics pricing condition types</text>
      </textAnnotation>
      <textAnnotation id="sid-B07C45BF-6EC6-4374-B496-797BC5136528" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Review original expedited order to confirm shipment of Goods to customer and remove hold on order
</text>
      </textAnnotation>
      <textAnnotation id="sid-2B295CF9-CA3F-4D33-A022-92880D84C3E5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> DR: Customer (Account Receivable}
CR:  Sales Revenue
Cr . Taxes (if applicable)</text>
      </textAnnotation>
      <textAnnotation id="sid-640D18AE-3283-40F9-86CB-821D90C56AB6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This entry will be technically cleared based on IDOC process</text>
      </textAnnotation>
      <textAnnotation id="sid-C773C334-6FBE-43BA-B5AF-DF31E142D338" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Create Separate Order with “Expedite fee” as a MMID tagged to Service Item with Manual reference to Original SO in Free Text Field 
</text>
      </textAnnotation>
      <textAnnotation id="sid-7810DDCB-937E-42E6-9157-539FDF7B0386" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual check by CBA</text>
      </textAnnotation>
      <textAnnotation id="sid-26A53B09-2EEF-481B-B904-9023BF365E0B" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Trade 
Compliance</text>
      </textAnnotation>
      <textAnnotation id="sid-9F960073-89A8-4756-BA4C-AEA169B80DA9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> DR: Customer (Account Receivable}
CR:  Sales Revenue
Cr . Taxes (if applicable)</text>
      </textAnnotation>
      <textAnnotation id="sid-15831149-47A8-4C17-B140-72B6D8CD8E9B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>DR: Main Bank Account
CR:  Customer (Accounts Receivable)</text>
      </textAnnotation>
      <textAnnotation id="sid-5E06C6E2-C6B8-41E1-B267-26C295A2A288" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>DR: Customer (Accounts Receivable)
CR:  Customer (Account Receivable)</text>
      </textAnnotation>
