         </extensionElements>
         <text>Component issued for Subcontracting Manufacturing Operation​</text>
      </textAnnotation>
      <textAnnotation id="sid-2F1C1B70-C3F4-4C32-BA42-02B9F1F4151E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT: 541​
GI to Subcon Stock​
No Accounting Entrie</text>
      </textAnnotation>
      <textAnnotation id="sid-7C22DAC8-0113-4B7A-9F58-0BD017DF164A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT : 543 ​
Cr. Subcon stock​
Dr. Consumption of components</text>
      </textAnnotation>
      <textAnnotation id="sid-05C684EC-0D10-463D-8562-BB09121964B5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT 641 (In-Transit)​
Cr  Stock Account​
Dr  Transit A/c​</text>
      </textAnnotation>
