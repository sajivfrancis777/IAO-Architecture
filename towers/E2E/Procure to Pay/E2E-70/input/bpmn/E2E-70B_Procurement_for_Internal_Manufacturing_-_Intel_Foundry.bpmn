            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="32.0" y="-9.0"/>
         </extensionElements>
         <text>ECA (Enterprise Cloud Analytics)</text>
      </textAnnotation>
      <textAnnotation id="sid-CDC7D9B0-0A39-4B8C-9939-B3C4B2A6F1DB" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>If Transport is managed by Intel
</text>
      </textAnnotation>
      <textAnnotation id="sid-7CA0594E-3719-48F3-B984-D5186BD8D9DF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. Inventory
Cr. GR/IR Account
</text>
      </textAnnotation>
      <textAnnotation id="sid-68DCD5CC-C6A1-4743-B171-C07BB634EFB9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. GR/IR Acc.
Dr. Input Taxes (if applicable)
Cr. Accounts payable/ Vendor
</text>
      </textAnnotation>
      <textAnnotation id="sid-D5B24E0A-4CF3-4B19-A0F4-DDAC0DD1C66C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>3-Way match not applicable for ERS
</text>
      </textAnnotation>
      <textAnnotation id="sid-24600082-E09E-4077-A94C-817C065D396D" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Compliance check 
"SPL, EMB  Triggered</text>
      </textAnnotation>
      <textAnnotation id="sid-273730BD-9D15-4B6B-99F6-521D8AC0A095" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Screening at PO Creation</text>
      </textAnnotation>
      <textAnnotation id="sid-E3DF10EE-E2F1-4F3C-A8C9-06E8F845CDB2" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>In case No ASN, 3PL to do GR against PO</text>
      </textAnnotation>
