            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Service provider will act as MRP controller to update MRP parameters in material master
</text>
      </textAnnotation>
      <textAnnotation id="sid-761C9DE0-BE98-4EC8-A9C4-D16993111C8F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Inventory Report, Min Max/ROP data will be shared with service provider periodically - RICEFW
</text>
      </textAnnotation>
      <textAnnotation id="sid-DE8DA541-C158-492D-93B4-B64104F417E7" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS compliance SPL &amp; EMB
</text>
      </textAnnotation>
      <textAnnotation id="sid-4D177C63-B435-441F-B343-22A628D8FE53" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IBD with House Air Waybill Number
</text>
      </textAnnotation>
      <textAnnotation id="sid-159D3176-1AD7-4FAC-837D-89CE85E6A20A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Service provider will act as CW Buyer for monitoring PO
</text>
      </textAnnotation>
   </process>
