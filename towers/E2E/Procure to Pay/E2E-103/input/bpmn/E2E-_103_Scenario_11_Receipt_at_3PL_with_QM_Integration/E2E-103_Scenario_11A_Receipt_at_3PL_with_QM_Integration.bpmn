            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. Inventory
Cr. GR/IR Account
</text>
      </textAnnotation>
      <textAnnotation id="sid-46E1F7F6-AF13-487D-BCD8-DF1D87423E24" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. GR/IR Acc.
Dr. Input Taxes (if applicable)
Cr. Accounts payable/ Vendor

</text>
      </textAnnotation>
      <textAnnotation id="sid-B07AC1B4-7887-4283-953E-DF6A35A270AA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Refer MQCS table at the time of IBD for Stock Type
</text>
      </textAnnotation>
      <textAnnotation id="sid-A17465E5-6FDB-43AF-AAA7-21D8CE50A0EE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Based on Inventory Update Program Stock type change may happen from Unrestricted and Blocked to QI .(Refers MQCS data and moves the stock)
</text>
      </textAnnotation>
      <textAnnotation id="sid-CA004BF5-47FE-4E8B-B7A2-451B1DB68692" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
