      <textAnnotation id="sid-A0421866-7B48-49ED-B984-69EE047B0429" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Cash settlement – Actual movement of funds between bank accounts enabled via F110 run, APM, Payment batching and SAP MBC to send the payment files to the IC Vendor
</text>
      </textAnnotation>
