      <textAnnotation id="sid-A4038C71-4157-47BE-A259-77B14C3D5ED8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Financial Posting will be replicated realtime from individual S4 box to CFIN system
</text>
      </textAnnotation>
      <textAnnotation id="sid-4758C15A-AC54-4470-9CC7-4F8FB9AC65B3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>For Control Countries (e.g., India, China, Vietnam) Mandatory for CASH Settlement
For Non-Control Countries: Company Codes which do not have inhouse bank relationship
</text>
      </textAnnotation>
