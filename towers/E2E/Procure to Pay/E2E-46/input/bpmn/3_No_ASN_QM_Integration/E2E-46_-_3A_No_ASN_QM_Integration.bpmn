      <textAnnotation id="sid-E979DC65-618C-401F-9B3C-4E0078FB304B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>In case of No ASN – IBD to be created 36 hours prior to GR expected. 
</text>
      </textAnnotation>
