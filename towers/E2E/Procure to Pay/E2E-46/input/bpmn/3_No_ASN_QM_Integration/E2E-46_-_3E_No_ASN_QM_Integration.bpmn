      <textAnnotation id="sid-2364DEBB-6F35-4AC4-8328-891C44298484" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/af14dd1bb55f4a9e827b729a65864025</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="21.0" y="-20.0"/>
         </extensionElements>
         <text>ECA (Enterprise Cloud Analytics)</text>
      </textAnnotation>
      <textAnnotation id="sid-B07AC1B4-7887-4283-953E-DF6A35A270AA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>For MQCS Enable MMID
</text>
      </textAnnotation>
      <textAnnotation id="sid-21C44672-6DB2-4BA2-84D0-EAA48D87D6F3" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Trade Compliance
</text>
      </textAnnotation>
      <textAnnotation id="sid-FA0B93AE-E78B-4E30-AE7D-5CD881832FD9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. Inventory
Cr. GR/IR Account

</text>
      </textAnnotation>
      <textAnnotation id="sid-AB00F804-64E3-4BDE-952C-49E95F8ECC29" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>In case of No ASN – IBD to be created 36 hours prior to GR expected. 
</text>
      </textAnnotation>
      <textAnnotation id="sid-F25E41CA-90E5-492A-BF85-0443F23B5CA7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>If Transportation owned by Intel
</text>
      </textAnnotation>
      <textAnnotation id="sid-AA770F25-D4A4-41E6-A2FE-D962EC27CC64" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Based on Inventory Update Program Stock type change may happen from Blocked (Refers MQCS data and moves the stock)
</text>
      </textAnnotation>
      <textAnnotation id="sid-48FF910B-4628-4AA1-9339-312D25747691" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Physical Count and Verification which may affect in exception process
</text>
      </textAnnotation>
   </process>
