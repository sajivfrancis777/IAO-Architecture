      <textAnnotation id="sid-F52475F1-A5C6-4FFC-A903-12C0BAD95D1C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Supplier commitment to provide Lot/component after rework. E2E-59 Rework Process to be followed.
</text>
      </textAnnotation>
      <textAnnotation id="sid-FA7B2EBE-EB17-40BC-A971-813986D54577" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Please refer E2E-59 R3 Rework Re-localization in Factory​ 
(all splits) </text>
      </textAnnotation>
      <textAnnotation id="sid-40EA4814-FE6E-4DF2-9021-DDA919AF899D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Replacement against Scrap item to be received via FOC Purchase Order
</text>
      </textAnnotation>
