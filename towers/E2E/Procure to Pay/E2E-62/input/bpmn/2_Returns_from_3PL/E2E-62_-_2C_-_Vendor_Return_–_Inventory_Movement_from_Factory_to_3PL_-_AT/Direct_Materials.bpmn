      <textAnnotation id="sid-71AB3180-DFC4-4E73-AD04-9D7DCD6D440B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Refer MQCS table at the time of IBD for Stock Type
</text>
      </textAnnotation>
      <textAnnotation id="sid-71A44B99-3C91-4B26-AA1C-F55B045B0D7A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Based on Inventory Update Program Stock type change may happen from Unrestricted and Blocked to QI .(Refers MQCS data and moves the stock)
</text>
      </textAnnotation>
      <textAnnotation id="sid-578CA823-8F8F-406B-9C90-2AF015E78D14" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>In case No ASN, 3PL to do GR against replacement PO
</text>
      </textAnnotation>
