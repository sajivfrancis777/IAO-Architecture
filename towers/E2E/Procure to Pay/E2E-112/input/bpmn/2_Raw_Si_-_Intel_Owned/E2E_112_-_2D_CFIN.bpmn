      <textAnnotation id="sid-FAA3257C-17D1-4373-B3BC-6B4283E08134" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/bbc49ec54070449497b97b5eb213d6f6</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="32.0" y="-9.0"/>
         </extensionElements>
         <text>Quantum</text>
      </textAnnotation>
      <textAnnotation id="sid-3D048823-EACE-4F2B-8851-7AA4558A915C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>To Reconcile/Track the Payments, these apps are used</text>
      </textAnnotation>
      <textAnnotation id="sid-2C9DF3C6-003D-4303-A1F8-0D8EA9C65FBC" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Electronic Bank statement via Multi Bank Connectivity (MBC)</text>
      </textAnnotation>
      <textAnnotation id="sid-15FD623B-C789-48EC-9DBF-8CF8E7E8324E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>File transfer through MBC</text>
      </textAnnotation>
      <textAnnotation id="sid-AB0DAD7C-F047-43C9-88CC-B81DDDBB47AE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>WebSuite Payment Tracker/ SAP Business Network / OpenText
</text>
      </textAnnotation>
      <textAnnotation id="sid-982B2095-D0EB-4672-947C-62EC98F0A629" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>If Reprocessing can not be done - Reversal  is Chosen
</text>
      </textAnnotation>
      <textAnnotation id="sid-9AC04D09-C33D-42AC-A2BC-8EAB35C298EE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Once Outbound payment order is processed payment file gets created 
</text>
      </textAnnotation>
      <textAnnotation id="sid-4B4CB61E-5CED-4952-9408-637A384998EB" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>APM- Advance Payment Management</text>
      </textAnnotation>
      <textAnnotation id="sid-B517032E-2755-4D17-8FCB-C775CB57270D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>BCM- Bank Communication Management</text>
      </textAnnotation>
      <textAnnotation id="sid-CA3E0EF8-EAB3-4A63-A965-C5F1A9060C9E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Once Outbound payment order is processed payment file gets created 
</text>
      </textAnnotation>
      <textAnnotation id="sid-51BBEB24-5745-4566-AD8B-6E37E606BDBA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Reprocessing </text>
      </textAnnotation>
      <textAnnotation id="sid-88CBFF9A-9EF0-454B-9BE5-100FFCA8277C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Incoming Payment Order gets Created</text>
      </textAnnotation>
      <textAnnotation id="sid-9D922BEE-F17F-499A-AF93-FEC2BFB02D56" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. Accounts Payable/Vendor
Cr.  Bank Clg account
</text>
      </textAnnotation>
      <textAnnotation id="sid-016862FF-9CA9-4FDC-830D-369426443A02" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Incase of bank payment rejection 
</text>
      </textAnnotation>
