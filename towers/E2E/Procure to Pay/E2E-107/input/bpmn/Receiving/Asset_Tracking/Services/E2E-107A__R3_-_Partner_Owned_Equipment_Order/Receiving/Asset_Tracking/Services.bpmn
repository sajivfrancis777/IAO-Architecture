      <textAnnotation id="sid-DF65CBBD-B78D-4218-B30B-6C5CD7929221" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Documentation attached interfaced to Alfresco
</text>
      </textAnnotation>
      <textAnnotation id="sid-1C80708E-FDB8-48B1-9133-AA354A1A93A5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>With Reference to Customer PO
UoM – Quantity/Hour Based</text>
      </textAnnotation>
      <textAnnotation id="sid-9131812B-0146-4BAE-90B7-F8D1E2610A75" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Contract : Order can be 1:1 or 1:N depending on Intel business process for invoicing to customer based on contract.
</text>
      </textAnnotation>
