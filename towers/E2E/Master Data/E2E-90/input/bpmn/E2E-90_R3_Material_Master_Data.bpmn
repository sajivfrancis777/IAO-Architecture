         </extensionElements>
         <text>IP PLM Translator</text>
      </textAnnotation>
      <textAnnotation id="sid-23E0A74A-1D80-413A-B7FC-25CB45252C00" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Material master data sent/received
from ECC/Speed via IP PLM</text>
      </textAnnotation>
      <textAnnotation id="sid-250380C8-2919-4443-A7F4-4B27B93EBC0C" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="32.0" y="-9.0"/>
         </extensionElements>
         <text>NEW SAP MDG</text>
      </textAnnotation>
      <textAnnotation id="sid-D82E1537-4096-4A82-BF9B-19A1B57FBA17" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MDG Creates new MM ID and legacy MM ID

MDG stores the legacy material number in MARA-BISMT
</text>
      </textAnnotation>
      <textAnnotation id="sid-F8533B16-76E0-491C-9DC9-5936AFDEB6CD" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="11.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="11.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>

Other Non-PLM related Materials will be requested in MDG.
</text>
      </textAnnotation>
      <textAnnotation id="sid-83E5F1C8-6FE0-4A46-A6ED-99A51ECE4C16" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
