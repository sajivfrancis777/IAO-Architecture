            <signavio:signavioLabel ref="text_name" valign="middle" x="30.0" y="81.0"/>
         </extensionElements>
         <text>Other Boundary 
Applications</text>
      </textAnnotation>
      <textAnnotation id="sid-57FBA328-8292-4054-8AD4-0FAC141F3089" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IF PLM</text>
      </textAnnotation>
      <textAnnotation id="sid-1A8AF0E3-1852-4665-8FA4-F3A527778F82" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="11.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="11.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>
1.  PLM-related materials are requested in SPEED System

2.  PLM integration layer translates SPEED data before sending to the New MDG

3.  Request is sent to MDG.
</text>
      </textAnnotation>
      <textAnnotation id="sid-3E97FCF2-2D94-45D9-BDDA-7CE5770F8A47" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/5643f05c48fa401d9605162d12316f70</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="32.0" y="-9.0"/>
         </extensionElements>
         <text>IP PLM</text>
      </textAnnotation>
