      <textAnnotation id="sid-700DA984-7D1B-4B61-90D2-6A11ABC3B899" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP TM
Embedded 
</text>
      </textAnnotation>
      <textAnnotation id="sid-5D95B40A-4E8B-4924-94A7-B73C62D7DBB9" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Trade Compliance</text>
      </textAnnotation>
      <textAnnotation id="sid-A45892E6-C5D9-408A-B1BF-BC05503E0603" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Initiate Return to Customer process in-case of discrepant/unacceptable / no remedy / out of warranty product and customer agreed for return instead of waster processing at Intel Site</text>
      </textAnnotation>
      <textAnnotation id="sid-B7F2241A-43E4-4962-B98A-91F75136BE3A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Approved 
Request with any return order reason for remedy with require location for receipt
</text>
      </textAnnotation>
      <textAnnotation id="sid-BDCD66F8-77DF-4D2B-9D35-9868EE95C159" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT Type :  657 
Cr. COGS
Dr. Inventory Account
</text>
      </textAnnotation>
      <textAnnotation id="sid-B1FE9847-8C6F-44EC-80E2-15CB89B0E036" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Performed Docking Qty for Returned Material : Qty, UOM and Damage status manually. Update Reason Code with pictures if needed.</text>
      </textAnnotation>
      <textAnnotation id="sid-5AD34B5A-84FA-488F-B32E-17343901BE92" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Discrepant status updated against which RMA sub-line fetch price details from Salesforce</text>
      </textAnnotation>
