      <textAnnotation id="sid-D937B4E8-757D-4922-9A6C-1684EF8E06CE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>The R4C boundary app create an RMA for repairs with remedies and order reasons used to identify.
Fraud Detection in SFDC
</text>
