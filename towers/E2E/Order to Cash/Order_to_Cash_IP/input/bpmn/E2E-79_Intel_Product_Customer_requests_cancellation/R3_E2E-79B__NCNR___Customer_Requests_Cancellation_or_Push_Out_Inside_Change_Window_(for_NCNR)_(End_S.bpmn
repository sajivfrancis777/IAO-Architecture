      </textAnnotation>
      <textAnnotation id="sid-94C609BC-65E0-4E03-9183-9B354EF4229A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SPL
