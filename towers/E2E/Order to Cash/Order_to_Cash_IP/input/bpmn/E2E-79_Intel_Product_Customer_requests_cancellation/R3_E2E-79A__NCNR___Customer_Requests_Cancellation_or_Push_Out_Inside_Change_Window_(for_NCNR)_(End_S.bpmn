      <textAnnotation id="sid-A1A30566-9C40-4A38-AFA9-D88572BE8AE2" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Orders from B2B customer through EDI/RNET

