      <textAnnotation id="sid-EF6D43CA-B8D6-4B19-AC6F-557BDF21B6FD" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>DR: Main Bank Account
CR: Clearing Account

</text>
      </textAnnotation>
      <textAnnotation id="sid-CC010E65-2845-43B8-ACA6-27F2B734C92B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>DR: Clearing Account
CR:  Other income
</text>
      </textAnnotation>
      <textAnnotation id="sid-83F04735-6F61-4A56-9045-307B8C3F17A9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>DR: Accumulated Depreciation
CR : Fixed Assets - Acquisition Production Cost (APC)  
Dr/Cr: Gain/Loss on sale of asset
</text>
      </textAnnotation>
      <textAnnotation id="sid-87284A0A-7336-464B-89DF-B6F67502487A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Follow standard AMT write off process
</text>
      </textAnnotation>
