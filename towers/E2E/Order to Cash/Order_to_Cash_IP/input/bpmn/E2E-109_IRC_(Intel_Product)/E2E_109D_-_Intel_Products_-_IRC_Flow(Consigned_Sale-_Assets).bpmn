      <textAnnotation id="sid-EE210969-1A76-4658-B9B9-7752C90029FF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Use ISM to generate document to Ship out Inventory to Customer 
</text>
