      <textAnnotation id="sid-6A1A16C9-3766-4F50-8488-A2700E2A9512" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>BY CDP will be used for NPI Product Demand and Publish.
IBP will go away with Release 2.
</text>
      </textAnnotation>
      <textAnnotation id="sid-405D4EA8-0CDA-473D-866B-69A59C00E35E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>All NPI materials will be manually created in SPEED.
Profisee not in Scope.  
</text>
      </textAnnotation>
