      </textAnnotation>
      <textAnnotation id="sid-20C4C343-9487-4E59-868B-B02740EEC1F5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. Account Receivables
Cr. Revenue (Sales)
Cr. Taxes (if applicable)
</text>
      </textAnnotation>
      <textAnnotation id="sid-B95388DE-6873-41C2-A712-5D81EBFFF519" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>AR entry will be technically cleared as per standard SAP functionality
</text>
      </textAnnotation>
      <textAnnotation id="sid-B042E32B-7913-4EBA-B890-1D2143CB00BA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. Contra Revenue (Rebates)
Cr. Accrual/Reserve GL (balance sheet)
</text>
      </textAnnotation>
      <textAnnotation id="sid-509431D4-4BAB-49B0-B77A-3D2FB89FF81E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>For MY, Vietnam, China</text>
      </textAnnotation>
