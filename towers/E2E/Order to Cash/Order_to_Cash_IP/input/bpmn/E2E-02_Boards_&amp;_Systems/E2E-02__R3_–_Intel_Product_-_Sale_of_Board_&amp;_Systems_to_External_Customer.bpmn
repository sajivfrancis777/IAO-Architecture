            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. IC  Expense
Cr. IC Account Payables
Dr. Taxes (if applicable)
</text>
      </textAnnotation>
