      <textAnnotation id="sid-E23CB579-3824-4798-8A2F-B67953B2D68F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff9900" fontFamily="" fontSize="24.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff9900" fontFamily="" fontSize="24.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Inventory is still at LE778 Physically. Only, virtually issues to LE798 and further to IP for invoicing
</text>
      </textAnnotation>
