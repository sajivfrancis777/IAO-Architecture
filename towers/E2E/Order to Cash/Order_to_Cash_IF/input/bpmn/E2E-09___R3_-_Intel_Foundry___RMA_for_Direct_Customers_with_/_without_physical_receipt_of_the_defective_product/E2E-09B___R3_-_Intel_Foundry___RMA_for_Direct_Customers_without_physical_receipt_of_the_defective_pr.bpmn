      <task completionQuantity="1" id="sid-65634A0B-C2DE-4C1D-8562-496E361AE314" isForCompensation="false" name="Outside SAP" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#FFFFFF"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
