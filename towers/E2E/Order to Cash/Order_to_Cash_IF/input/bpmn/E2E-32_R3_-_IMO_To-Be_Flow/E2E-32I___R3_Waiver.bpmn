      <textAnnotation id="sid-A1E4511E-01ED-4DCD-B924-55A3280D60F6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT type: 641 (In-Transit)
Dr. COGS
Cr. Inventory
</text>
      </textAnnotation>
      <textAnnotation id="sid-ABD218A7-1285-496C-A40F-87E6316B4046" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT : 501
Dr. Inventory
Cr. Expense GL A/c
</text>
      </textAnnotation>
      <textAnnotation id="sid-0DEAAACE-217F-4B7C-9CCF-E35D5D087F84" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="32.0" y="-9.0"/>
         </extensionElements>
         <text>SAP TM </text>
      </textAnnotation>
      <textAnnotation id="sid-6703F4E9-748C-46F3-9CE0-75F4508B3A49" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Goods Issue to Cost Center
MVT :  201
Dr. Expense GL A/c 
Cr. Inventory A/c
</text>
      </textAnnotation>
      <textAnnotation id="sid-877BAA75-AC78-4C82-9AF6-6E818FA24CEF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr.  Account Receivables
Cr. IC Sales
Cr. Taxes (if applicable)
</text>
      </textAnnotation>
      <textAnnotation id="sid-9B058C32-425C-40CC-BAB2-66FE0E20D2AD" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="32.0" y="-24.0"/>
         </extensionElements>
         <text>SAP TM</text>
      </textAnnotation>
      <textAnnotation id="sid-F7C364D6-44B0-48B2-907B-BE8FE505B18B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>If the replacement is required , STO will be triggered again to induct stock post manufacturing  followed by IC .Customer Order &amp; Invoicing will follow  the same process as linked next</text>
      </textAnnotation>
      <textAnnotation id="sid-DA42A8D7-63A2-42ED-BDBE-CC01347E2016" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT 101
Dr. Inventory
Cr. GR/IR
</text>
      </textAnnotation>
      <textAnnotation id="sid-0481CD91-F233-4B9B-A778-E1F9810DCF85" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>RCXX SLOC
Where XX is numeric
</text>
      </textAnnotation>
      <textAnnotation id="sid-4C3B8BA4-FFC2-4D47-BB69-CD39BE47A4A7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr.  GR/IR
Cr. IC Account Payables
Dr. Taxes (if applicable)
</text>
      </textAnnotation>
   </process>
