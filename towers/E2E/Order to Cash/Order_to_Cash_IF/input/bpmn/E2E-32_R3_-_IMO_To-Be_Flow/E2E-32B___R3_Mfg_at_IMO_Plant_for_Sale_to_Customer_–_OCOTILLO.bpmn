      <textAnnotation id="sid-9F1E0FBC-8922-45A8-9594-DCF081B41C60" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Goods Issue to Cost Center
MVT :  201
Dr. Expense GL A/c 
Cr. Inventory A/c
</text>
      </textAnnotation>
      <textAnnotation id="sid-7359158B-55FE-4476-A8FF-4981F7F6BB98" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>after sto creation </text>
      </textAnnotation>
      <textAnnotation id="sid-9DBC3F41-E0CE-402C-AEA4-BDE00E46011F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT: 501
Dr. Inventory
Cr. Expense GL A/c
</text>
      </textAnnotation>
      <textAnnotation id="sid-93E41490-E902-4986-86F8-B9FDD3738318" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT type: 641 (In-Transit)
Dr. COGS
Cr. Inventory</text>
      </textAnnotation>
      <textAnnotation id="sid-1D5CD656-2EE8-412B-BC43-FD3063598665" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
