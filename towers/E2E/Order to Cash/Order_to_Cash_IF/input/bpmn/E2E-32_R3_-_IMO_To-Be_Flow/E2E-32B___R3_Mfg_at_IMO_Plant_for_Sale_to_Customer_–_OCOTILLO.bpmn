            <signavio:signavioLabel ref="text_name" valign="middle" x="74.0" y="69.0"/>
         </extensionElements>
         <text>SAP TM </text>
      </textAnnotation>
      <textAnnotation id="sid-67CEC748-6E4E-426A-8B6A-8F01BC12168D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>RCXX SLOC
Where XX is numeric
</text>
      </textAnnotation>
      <textAnnotation id="sid-20DD1453-3340-47BC-8031-046342EB1FCE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS check are applied on PO, STO, Inbound Delivery, Outbound delivery
</text>
      </textAnnotation>
