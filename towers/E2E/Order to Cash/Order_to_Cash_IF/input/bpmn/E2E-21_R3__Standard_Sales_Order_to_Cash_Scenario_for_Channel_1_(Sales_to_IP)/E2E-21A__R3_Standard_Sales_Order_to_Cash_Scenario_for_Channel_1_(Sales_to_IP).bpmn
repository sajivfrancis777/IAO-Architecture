         <text>GTS Trade 
Compliance</text>
      </textAnnotation>
      <textAnnotation id="sid-6CFE0DF5-6D6A-474D-9555-AA7763F1EA80" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Pricing details will be loaded in SAP directly
</text>
      </textAnnotation>
      <textAnnotation id="sid-F2C56F1D-ACED-4AF2-AF6A-6F4895B469BA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Partial Commit Allowed by Customer
</text>
      </textAnnotation>
      <textAnnotation id="sid-8FD1A502-AF12-45D7-9817-3946B61A4A8B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>On Virtual Plant</text>
      </textAnnotation>
      <textAnnotation id="sid-955C5D46-CD8D-4347-8848-6DCFB260E8B3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This entry will be technically cleared as per standard SAP functionality
</text>
      </textAnnotation>
      <textAnnotation id="sid-59E87B87-9D83-484A-B9A7-80657A901A9E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Sold to : Customer 
Ship to : Customer/OSAT
</text>
      </textAnnotation>
      <textAnnotation id="sid-DFC72B3A-C6C8-47D5-AC0E-2FC1B6A348E5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This entry will be technically cleared as per standard SAP functionality
</text>
      </textAnnotation>
      <textAnnotation id="sid-08E3E4BF-0C32-483B-91DC-E18FE52FEFEE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>ABR Document Reference to SO Line Item 
(via RNET 7B5)  - 1:1 with SO Line Item
ABR will be mandatory step for successful order creation [if customer is EDI enabled, it will be automatic otherwise Manual]
</text>
      </textAnnotation>
      <textAnnotation id="sid-E6537F91-005D-4B12-95BF-E11665D40EAD" signavio:alignment="left" textFormat="text/plain">
