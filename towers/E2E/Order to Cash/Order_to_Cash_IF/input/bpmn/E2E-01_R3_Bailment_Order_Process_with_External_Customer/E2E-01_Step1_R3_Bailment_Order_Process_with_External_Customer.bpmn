         <text>SAP MDG</text>
      </textAnnotation>
      <textAnnotation id="sid-581C436B-8F06-409E-A011-DDD8E98D7446" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>ZBAI for capturing Customs Value and support commercial invoice generation
GRWR will be used for statutory reporting
</text>
      </textAnnotation>
      <textAnnotation id="sid-37BDB81C-588C-4196-86BB-8A5B723CD67B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Embargo and SPL Screening Only
</text>
      </textAnnotation>
      <textAnnotation id="sid-35FB05B1-8C56-4460-A7DE-B0641F96FE6A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This purchase order will not have any payments associated or  impact to GL.
</text>
      </textAnnotation>
      <textAnnotation id="sid-0EF2A77F-50B8-4EB8-B983-30A61963C207" signavio:alignment="left">
