      <textAnnotation id="sid-CEAA7FAF-2726-4167-880B-51B1FFC6B06C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This flow assumes that we will assign part numbers to masks and track them as inventory until either put into service (expensed) or sold to the customer.</text>
