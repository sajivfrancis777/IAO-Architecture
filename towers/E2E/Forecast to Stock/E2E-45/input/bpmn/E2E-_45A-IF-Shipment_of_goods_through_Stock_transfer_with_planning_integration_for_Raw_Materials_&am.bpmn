         <text>ECA
</text>
      </textAnnotation>
      <textAnnotation id="sid-2A169DF7-75A5-4307-BC2A-9E79B704237F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>With Planned Orders, STRs will be generated
Or triggered by FSCO in frozen horizon
</text>
      </textAnnotation>
      <textAnnotation id="sid-5FFD5977-8EC2-4D38-9C91-D1C95EA2A43E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
