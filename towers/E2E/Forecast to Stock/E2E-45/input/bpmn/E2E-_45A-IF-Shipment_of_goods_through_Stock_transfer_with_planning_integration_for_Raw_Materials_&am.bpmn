         </extensionElements>
         <text>Via PDH</text>
      </textAnnotation>
      <textAnnotation id="sid-53CE012D-5629-4F12-8E5E-C8406909DECF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Receiving SLoc
</text>
