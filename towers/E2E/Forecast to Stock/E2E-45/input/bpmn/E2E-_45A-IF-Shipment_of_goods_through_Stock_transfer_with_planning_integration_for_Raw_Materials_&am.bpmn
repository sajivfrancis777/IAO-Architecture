         </extensionElements>
         <text>Supplying SLoc
</text>
      </textAnnotation>
      <textAnnotation id="sid-CE7357C8-D9D8-4092-A850-8210BF17FEC0" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT type: 641
Dr. Receiving Inventory
Cr. Sending Inventory
</text>
      </textAnnotation>
      <textAnnotation id="sid-8A5AE6A1-EE93-4580-9EBF-763B0591F74A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS check are applied on OBD</text>
      </textAnnotation>
