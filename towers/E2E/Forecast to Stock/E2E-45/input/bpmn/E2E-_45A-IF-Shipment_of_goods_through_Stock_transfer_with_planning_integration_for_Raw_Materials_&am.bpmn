            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>BY/
FSCO 
</text>
      </textAnnotation>
      <textAnnotation id="sid-C424C626-49C1-464F-A400-B06D080265D8" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
