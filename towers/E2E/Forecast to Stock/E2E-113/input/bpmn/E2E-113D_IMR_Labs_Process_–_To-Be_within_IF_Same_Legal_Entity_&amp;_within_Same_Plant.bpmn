      <textAnnotation id="sid-E353B0CF-3A38-41D0-B637-51585B8C5F59" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>To transfer Repaired or MFG Part
</text>
      </textAnnotation>
      <textAnnotation id="sid-2F5A8993-8C9F-4DA0-91EC-F3821BEAD4CC" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS check are applied on PO, SO, STO, Inbound Delivery, Outbound Delivery
</text>
      </textAnnotation>
      <textAnnotation id="sid-B587DAE1-A2ED-4167-B5A3-5D3CAB8A3C6A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Applicable in case of repair only to transfer defective part</text>
      </textAnnotation>
      <textAnnotation id="sid-F89F43F8-1E57-4887-A0E6-9ED0906F0C0F" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IMR Repor ts
SQL PathFinder</text>
      </textAnnotation>
      <textAnnotation id="sid-0AA51EF0-987B-4920-AE5E-1414766A816F" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="91.0" y="80.0"/>
         </extensionElements>
         <text>IRIS – Non-Standard
Request</text>
      </textAnnotation>
      <textAnnotation id="sid-05EBAAEF-0934-4E48-BABD-839E4C8303BC" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="59.0" y="77.0"/>
         </extensionElements>
         <text>SAP ME</text>
      </textAnnotation>
      <textAnnotation id="sid-E263777B-4F2F-4340-B699-3D8929E6A1E8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>User to select object type PM Repair
order/Prod. Order based on biz
process/MMID and type of Request
(Repair/New Manu. Exa: 3D Print</text>
      </textAnnotation>
      <textAnnotation id="sid-297CDC72-841D-448B-9B86-FB939AA118BA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Additional Components for Repair or Manu.
to be added manually to PM Repair Order
and Prod. Order Respectively</text>
      </textAnnotation>
   </process>
