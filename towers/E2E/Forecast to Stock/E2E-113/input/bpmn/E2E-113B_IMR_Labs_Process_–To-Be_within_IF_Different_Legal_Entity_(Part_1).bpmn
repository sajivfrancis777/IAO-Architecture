      <textAnnotation id="sid-2A4A85E5-F0DE-4ED1-B985-2207BB6D9802" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS check are applied on PO, SO, STO, Inbound Delivery, Outbound Delivery
</text>
      </textAnnotation>
      <textAnnotation id="sid-6FE6CD5C-A764-43F0-B085-4D148FB2C94C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Applicable in case of repair only to transfer defective part
</text>
      </textAnnotation>
      <textAnnotation id="sid-F89F43F8-1E57-4887-A0E6-9ED0906F0C0F" signavio:alignment="left">
         <extensionElements>
