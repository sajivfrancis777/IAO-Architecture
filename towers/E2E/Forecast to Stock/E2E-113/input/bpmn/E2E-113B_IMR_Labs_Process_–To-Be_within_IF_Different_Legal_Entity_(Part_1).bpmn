            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IMR Repor ts
SQL PathFinder</text>
      </textAnnotation>
      <textAnnotation id="sid-0AA51EF0-987B-4920-AE5E-1414766A816F" signavio:alignment="left">
         <extensionElements>
