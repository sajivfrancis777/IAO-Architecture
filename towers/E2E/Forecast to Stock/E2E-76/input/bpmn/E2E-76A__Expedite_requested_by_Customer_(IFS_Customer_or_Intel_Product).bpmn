      <textAnnotation id="sid-219EEE14-589E-4F69-96E0-79EF3EDD6C6C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Preloaded condition types
</text>
      </textAnnotation>
      <textAnnotation id="sid-0AAA5459-6ADC-406A-A8BD-757D84D921F7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Financial Posting Replication
</text>
      </textAnnotation>
      <textAnnotation id="sid-BC33EA9C-9D68-42BC-91A0-92DD8C9A049F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>DR: Customer (Account Receivable}
CR:  Sales Revenue
Cr . Taxes (if applicable)
</text>
      </textAnnotation>
      <textAnnotation id="sid-C1FBB590-16DA-46D1-987E-EF5ADA839B00" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This entry will be technically cleared as per standard SAP functionality
</text>
      </textAnnotation>
      <textAnnotation id="sid-20D15EE7-4E63-4B0B-9473-9D98159D71E4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>On new RDD on existing line item
</text>
      </textAnnotation>
      <textAnnotation id="sid-0BC0726F-9DEC-4EFD-B66F-DC852EB7BD21" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>New CDD (CBA can be override CDD manually</text>
      </textAnnotation>
      <textAnnotation id="sid-3F578E67-3EE2-4298-8384-F806C144B32A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>N: Alignment of expedite fee post goods issue based on Actual Delivery date &amp; T&amp;Cs
</text>
      </textAnnotation>
      <textAnnotation id="sid-6A83D9B5-60A5-4CE1-A982-6822FD5AC031" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="50.0" y="72.0"/>
         </extensionElements>
         <text>OP</text>
      </textAnnotation>
      <textAnnotation id="sid-30269B6B-012C-4A73-A069-039EDB4BE7F6" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="5.0" y="71.0"/>
         </extensionElements>
         <text>ESP</text>
      </textAnnotation>
      <textAnnotation id="sid-BB930381-54BF-47BD-962C-6CAE8CFBA62B" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> MPL, Spectrum</text>
      </textAnnotation>
      <textAnnotation id="sid-1D8E5DBB-38A3-4355-83DA-79F04A009159" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> And override CDD in Sales order based on communication from Factory</text>
      </textAnnotation>
      <textAnnotation id="sid-18123420-A26F-47D4-81E4-F571D88E99A7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>CBA to communicate revised CDD and expedite fee
</text>
      </textAnnotation>
      <textAnnotation id="sid-2F227E0C-44F4-40CC-8C4A-F4EB6C35CDFA" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>
Scheduler</text>
      </textAnnotation>
      <textAnnotation id="sid-F5C8C279-2E24-485F-A719-FCB756DD25AC" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
