      <textAnnotation id="sid-16178F52-CF28-422B-8210-FA5FF28F0C1A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. Account Receivables
Cr. Sales
Dr. Taxes (if applicable)
</text>
      </textAnnotation>
      <textAnnotation id="sid-91548AE9-FF3D-4A1F-B9F0-43525B9DD4FD" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Cancellation Request
</text>
      </textAnnotation>
      <textAnnotation id="sid-ED838273-1516-4A54-A303-A54B98D141B9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Existing order
</text>
      </textAnnotation>
      <textAnnotation id="sid-C2E09D7D-85D8-4A74-80F7-3A189FA3AD9C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Feed of confirmed sales order to communicate rescheduling and prioritization of other production orders
</text>
      </textAnnotation>
      <textAnnotation id="sid-80AF21C8-097E-4EE8-BA83-E9537644469A" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS IT</text>
      </textAnnotation>
      <textAnnotation id="sid-18123420-A26F-47D4-81E4-F571D88E99A7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Statement of Supply &amp; Planned Order outside SAP confirming Sales Order. Decision can be keyed in manually In s/4 to confirm sales order
</text>
      </textAnnotation>
      <textAnnotation id="sid-6A83D9B5-60A5-4CE1-A982-6822FD5AC031" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="50.0" y="72.0"/>
         </extensionElements>
         <text>OP</text>
      </textAnnotation>
      <textAnnotation id="sid-30269B6B-012C-4A73-A069-039EDB4BE7F6" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="5.0" y="71.0"/>
         </extensionElements>
         <text>ESP</text>
      </textAnnotation>
      <textAnnotation id="sid-1D8E5DBB-38A3-4355-83DA-79F04A009159" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> And override CDD in Sales order based on communication from Factory</text>
      </textAnnotation>
      <textAnnotation id="sid-ABDCADD6-D1D3-415A-95EC-4E50BDD20860" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Reports can be based on S/4, ECA, Planning Engines
</text>
      </textAnnotation>
      <textAnnotation id="sid-37F0F171-A2FF-420C-8E79-C3AF35E767B1" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Cascading feed to prioritize others order by freeing existing capacity
</text>
      </textAnnotation>
      <textAnnotation id="sid-4BE8670B-1DF5-42A3-887E-1F92EE206DB5" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MES </text>
      </textAnnotation>
      <textAnnotation id="sid-DBF045CD-D505-4766-80EE-E1AEE230A9B8" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MES</text>
      </textAnnotation>
      <textAnnotation id="sid-2D5CA2C8-D2D5-472D-BA9D-A1E0EB192335" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MES</text>
      </textAnnotation>
      <textAnnotation id="sid-32DD0BE6-E2AD-4A4A-9155-3A5E4FC47821" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Assessment Based on As-Is process (e.g. production started or not , order in cancellation window or not)
</text>
      </textAnnotation>
      <textAnnotation id="sid-09A10C94-B6E2-4132-82E2-9B54EA2709D4" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/2fc17169f4464e4b8608f1669c86945f</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
