      <textAnnotation id="sid-4F7F10A4-C8F4-4D89-943F-B73FC95307F7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Update LE778 Shell Plant as final Delivery Plant
</text>
      </textAnnotation>
      <textAnnotation id="sid-DC29EEF2-B0D2-46EB-ABF7-DB9555DAB294" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Refer E2E-22 for full steps
</text>
      </textAnnotation>
      <textAnnotation id="sid-81F881A5-C965-4A4D-993B-72982F242B40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MVT 101
Dr. Inventory
Cr. GR/IR Account

</text>
      </textAnnotation>
      <textAnnotation id="sid-86186433-18EF-4B2C-B22F-D8131BB98DE8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Receive Inventory on records
</text>
      </textAnnotation>
      <textAnnotation id="sid-45760017-FBC0-41D4-ABFA-052F662B208B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. IC Expense
Cr. IC Account Payables
Dr. Taxes (if applicable)
</text>
      </textAnnotation>
      <textAnnotation id="sid-6605A575-56FB-4747-8A43-A7F12D947BCE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dependent on partial or full qty delivery
</text>
      </textAnnotation>
      <textAnnotation id="sid-FCC0AB2E-9236-4F9F-BD24-D69B0159BE04" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Sold to : Customer 
Ship to : Customer/OSAT
</text>
      </textAnnotation>
