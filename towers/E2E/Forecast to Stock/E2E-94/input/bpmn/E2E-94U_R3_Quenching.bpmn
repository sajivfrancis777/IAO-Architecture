      <textAnnotation id="sid-596738DC-350D-4101-A28F-E782186CDC9B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>User selects a quench-specific S.Loc in Plant Maintenance​
</text>
      </textAnnotation>
      <textAnnotation id="sid-82FE72FC-5E09-4414-932E-ABEA0DA820A5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Based on material master  quench flag, factory portal prompt technician to select quench return reason code​</text>
      </textAnnotation>
      <textAnnotation id="sid-B0B75A57-995A-42FE-9BAB-8C558F584453" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Email notification of Quench kit sent to warehouse operators​</text>
      </textAnnotation>
      <textAnnotation id="sid-8D9D1A68-B9C2-4498-9EE7-F0B9AE76D7BF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS check are applied on PO, SO, STO, IIBD, OBD​</text>
      </textAnnotation>
      <textAnnotation id="sid-E1FAF05A-6E1A-49AF-A7CE-C11BF51D42C5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Items with Quench return reason have a different warehouse SLA. </text>
      </textAnnotation>
      <textAnnotation id="sid-3312070F-C8CE-4282-A939-2D5E3086655D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>We have dedicated S.Locs that represent these docks​</text>
      </textAnnotation>
      <textAnnotation id="sid-D658C343-81ED-4FA6-810C-F24674ABCA65" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Perform GI &amp; Pickup happen simultaneously (meet driver)
</text>
      </textAnnotation>
