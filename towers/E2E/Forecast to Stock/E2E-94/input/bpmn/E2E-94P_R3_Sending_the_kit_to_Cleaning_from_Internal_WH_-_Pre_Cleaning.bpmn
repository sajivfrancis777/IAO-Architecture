      <textAnnotation id="sid-AEABE063-C5AE-4DB1-9D5D-AE449152A41B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Mvmt: 541</text>
      </textAnnotation>
      <textAnnotation id="sid-8E4D12CD-18A6-478D-B9C5-0350AF1AEF1F" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="32.0" y="-20.0"/>
         </extensionElements>
         <text>GTS check are applied on PO, OBD</text>
      </textAnnotation>
      <textAnnotation id="sid-90512C52-C2FC-4E1E-AEDC-C6CA9BC555BF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Upon Physical Order 
Dr. Stock account​
Cr.GR/IR Account​</text>
      </textAnnotation>
      <textAnnotation id="sid-AB1CF85A-F606-4CCD-9F9B-B7E456E18EBF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. GR/IR Acc.​
Dr. Input Taxes (if applicable)​
Cr. Accounts payable/ Vendor​</text>
      </textAnnotation>
      <textAnnotation id="sid-1619A3D1-73B4-44CC-9355-651633DBE6D4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>When item can’t be received in against a PO, a QN is created pre-GR</text>
      </textAnnotation>
