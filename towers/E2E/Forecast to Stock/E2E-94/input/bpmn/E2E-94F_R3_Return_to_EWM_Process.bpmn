      <textAnnotation id="sid-E4523B75-8C25-4600-B8E5-5AC5A95E7FA3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Return Process to EWM with reason code  to decide to send it to Warranty claim/Repair/Scrap​</text>
      </textAnnotation>
      <textAnnotation id="sid-02092FD9-B615-4FE8-A3DB-B4ED377EC456" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Mvmt type:262
Determine SLoc: EWM</text>
      </textAnnotation>
      <textAnnotation id="sid-EF183B52-B033-4242-9C6B-E634DA22E32E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Mvmt type: 551​
Dr. Scrap A/c​
Cr. Inventory A/c​</text>
      </textAnnotation>
      <textAnnotation id="sid-21FADDFA-C0F8-4F21-AC97-BB6CF7CF91CE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Reason Codes
RETURN UNOPENED ITEM TO STOCK
RETURN USED/OPENED ITEM TO STOCK</text>
      </textAnnotation>
      <textAnnotation id="sid-CB0F7613-B08C-4B1F-9F18-E9C166503F98" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Reason Codes
RETURN UNOPENED ITEM TO QUALITY/HOLD INVENTORY
RETURN USED/OPENED ITEM TO QUALITY/HOLD INVENTORY</text>
      </textAnnotation>
