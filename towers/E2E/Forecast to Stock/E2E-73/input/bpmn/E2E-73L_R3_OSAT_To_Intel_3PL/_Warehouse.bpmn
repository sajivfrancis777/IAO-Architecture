            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="9.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>MVT 641
Cr. Inventory Account (Issuing Plant)
Dr. Inventory Account (Receiving Plant) 
</text>
      </textAnnotation>
      <textAnnotation id="sid-5C5B3F4F-FC38-4FEA-9339-08154CD87700" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="9.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="9.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Records debits and credits to be posted to ledger accounts for transactions between two subsidiaries
</text>
      </textAnnotation>
