      <textAnnotation id="sid-555D10CE-B7DF-4F35-9C0F-96636E30D937" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Quality Check and Operations</text>
      </textAnnotation>
      <textAnnotation id="sid-7AC4DDC4-60A3-49AC-80F6-61E8F0B51A10" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Quality Inspection (3rd Party)</text>
      </textAnnotation>
      <textAnnotation id="sid-791337A0-22A1-4DAB-90E2-45E08FFA0254" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Consume the Component and Update Inventory </text>
      </textAnnotation>
      <textAnnotation id="sid-6A69A160-FB12-48D6-9D21-88E98459A8E9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Special Customs Regimes /any requirements FTZ/Bonded Warehouses  will be managed by a DFC (Duty Free Compliance) team 
</text>
      </textAnnotation>
      <textAnnotation id="sid-9FA98FE8-52C5-446E-B554-A8BD5E7D3334" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>B1 (Wafer Fabrication) &amp; B1.1  (BUMP), B1.2 (Die Prep) will have separate prod order in Internal Manufacturing and gets executed recursively in similar fashion
</text>
      </textAnnotation>
