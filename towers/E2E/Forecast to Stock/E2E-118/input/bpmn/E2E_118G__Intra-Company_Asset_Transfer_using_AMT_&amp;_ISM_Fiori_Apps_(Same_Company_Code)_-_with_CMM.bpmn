      <textAnnotation id="sid-7EF6FEFA-DADE-43D1-AC5C-3C83B9624C13" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Approval
(no Integration with CMMS)
</text>
      </textAnnotation>
      <textAnnotation id="sid-B390D261-3B0F-46D8-B672-56B011D968BF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>API Call to S/4 AMT(Enhancement for Material, Serial no,  etc. required)
</text>
      </textAnnotation>
      <textAnnotation id="sid-869FC66D-C060-4193-9254-7784EFE99021" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Fields to be Entered;
Asset Number/Sub Number
Transfer Date
Receiving Company Code
Transfer Variant
</text>
      </textAnnotation>
      <textAnnotation id="sid-4CCE3559-6DAC-4200-A1C2-AB4A49B579A9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Enter Material where there is no API call for AMT creation
</text>
      </textAnnotation>
      <textAnnotation id="sid-12FF7496-6C19-4885-97EA-82AD17FEE516" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Compliance Check
</text>
      </textAnnotation>
      <textAnnotation id="sid-C2C5D4D2-DC54-42CD-92FA-1754EC7E9B4E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>GTS Compliance Check
</text>
      </textAnnotation>
      <textAnnotation id="sid-9A5886AC-46FD-4EE8-B91A-EA96F7EF450D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Cr. Asset Account
Dr. Asset Clearing/Receivable A/c

Dr. Accumulated Depreciation A/c
Cr. Asset Account

Dr/Cr. Gain/Loss on Transfer of Asset
</text>
      </textAnnotation>
      <textAnnotation id="sid-CF2B44BB-2162-453D-BF8B-D1A39A920A4E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dr. Asset Account
Cr. Asset Clearing/Payable A/c

Dr. Asset A/c (for additional costs)
Cr. Expense/Asset Offset Account
</text>
      </textAnnotation>
