      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Formally execute work on a Production Order by: conducting pre-operation work, preparing set-up, scheduling operations, converting material into finished product or WIP, collecting process and quality data, delivering to stores, performing tool design operation, etc. Examples of business requirements for executing production orders include: &#10;Ability to access historical data by serial number (BOM, test data, etc.) &#10;Capacity to generate electronic quality characteristic results &#10;Ability to provide 'real time' status on material in-transit  &#10;Ability to provide streamlined data collection processes that facilitate work flow &#10;Ability to provide 'real time' promise dating &#10;Capability to provide visibility of WIP in transit between facilities &#10;Ability to show on-line work instructions, and machine and order status &#10;Ability to release all components for a production order and/or to release components by operation &#10;Ability to apply KANBAN where required &#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Shilpa Chandra&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
