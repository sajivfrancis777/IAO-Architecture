      <textAnnotation id="sid-32336A1E-C50B-414C-912E-191BC10865E2" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Disconnected from Prod Order Start
Triggered  by BY based on Lead time OR need to move from TRDI to next stage
</text>
      </textAnnotation>
