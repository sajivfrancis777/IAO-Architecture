<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-a63ad7e9-a538-4128-8b9c-07322cf5d066" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-fcabffee-143e-4c6f-9197-a52d9c6f6af8">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Complete all operations on production order and enable all production costs (assembly, test, tooling, etc.) to be linked to the order. Examples of business requirements for reconciling production orders include: &#10;&#10;Ability to ensure that financial data is captured &#10;Ability to block settlement if an order operation(s) is not completed &#10;Ability to correct charge and cost to proper work center &#10;&#10; &#10;&#10;&#10;The information in the production order is often adjusted when incorrect information was entered either manually or automatically (as with backflushing). Once the data is corrected, the production order is closed and no more data can be added or changed. As soon as an order is closed, it is also settled. During order settlement, the balance between debit postings to the order (e.g., external labor and completion confirmations debited to the order) and credit postings to the order (caused by receipts in stock) are calculated. The order account is then debited or credited accordingly. &#10;&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Shilpa Chandra&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="26/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Evidence IP Sprint6 &quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/08. FTS - Intel Products/03. Final Deliverables/Build/Signavio Flows/Process Flow Approval evidence/Approval Evidence IP R3Sprint6.msg?csf=1&amp;web=1&amp;e=wRHqp9&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="30c9d7d4e323456aa1770a2acd99bc6b"/>
      </extensionElements>
