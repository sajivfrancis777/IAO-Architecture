   <collaboration id="sid-83ff30cd-1753-4645-995f-83bbce8e975b">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Once the production order is released, goods are issued to fulfill requirements of the production order. Once this is done, the goods are unavailable for use in other requirements. Types of goods issue includes bulk, package, manual, backflush or electronic . The physical movement of the items to the production floor will follow the goods issue. A materials management process will exist (push or pull) to provide the required materials on time and will include an availability check. Requesting materials includes issuing material to an operation and assigning a tracking number (serial number, lot number, etc.) to a production order.   "/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Michael Alpha&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
