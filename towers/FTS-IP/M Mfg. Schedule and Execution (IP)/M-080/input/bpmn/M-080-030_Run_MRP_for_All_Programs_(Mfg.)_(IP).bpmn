   <collaboration id="sid-2252f3f2-7452-4171-8bb0-26655aaf1323">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Process Materials Requirements Plan (MRP) for all programs. This involves 1) a daily net change run to generate a new, efficient schedule for all parts 2) a weekly MRP run for all programs in order to generate a new schedule and capacity load. Specific business requirements for MRP should be identified and implemented. Some examples of requirements include: &#10;&#10;·               Daily and weekly net change runs &#10;&#10;·               Defined lot-sizing techniques &#10;&#10;·               MRP netting material capabilities, etc. &#10;&#10;·               Flexible reporting capabilities &#10;&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Michael Alpha&quot;,&quot;Matt Katzorke&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="18/06/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;M-080 Approval Evidence &quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/08. FTS - Intel Products/03. Final Deliverables/Build/Signavio Flows/Process Flow Approval evidence/M-080 Perform Material Requirement Planning (IP)/Approval Evidence IP M-080.msg?csf=1&amp;web=1&amp;e=4UbcpZ&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="f7318e48dbf54786bed077250bc8b8f6"/>
      </extensionElements>
