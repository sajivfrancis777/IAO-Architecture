<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_02f2aded-e056-492b-b293-ac759f45fe13" name="M-080-010_Run MRP for All Materials" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-aa20f6c6-0564-4b77-a065-18e040e6b3a3">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Applicable for ALPS &#10;&#10;Process Materials Requirements Plan (MRP) for all materials in all plants in a pre-defined sequence. This involves 1) a daily net change run in order to generate a new, efficient schedule for all parts 2) a weekly MPS/MRP run for all materials in all plants in order to generate a new schedule and capacity load. Specific business requirements for MRP should be identified and implemented. Some examples of requirements include: &#10;·               Daily and weekly net change runs &#10;&#10;·               Defined lot-sizing techniques &#10;&#10;·               Flexibility to incorporate variable time buckets within the planning horizon &#10;&#10;·               MRP netting material capabilities, etc. &#10;&#10;·               Flexible reporting capabilities &#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Shilpa Chandra&quot;,&quot;Michael Alpha&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="12/03/25"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Reapproved on 12/03/2025 &#10;Old Approval : Approval Evidence IP Sprint3.msg"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Evidence IP &quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared%20Documents/General/Implementation/08.%20FTS%20-%20Intel%20Products/03.%20Final%20Deliverables/Build/Signavio%20Flows/Process%20Flow%20Approval%20evidence/M-080%20Perform%20Material%20Requirement%20Planning%20(IP)/FW%20FTS%20IP%20Signavio%20Approval_3_13.msg?csf=1&amp;web=1&amp;e=najB4l&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="ad68c2a3383f44adbf759c0d8decf142"/>
      </extensionElements>
