   <collaboration id="sid-8a8dd602-5acf-4cc9-ad78-f0330de414b5">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Analyze the results of the MRP run and identify alternative schedule possibilities. Determine the changes that need to be made to MRP and prepare to implement changes. Need to identify critical business requirements to support this activity. Some examples of business requirements for determining MRP changes include: &#10;&#10; Ability to     reschedule past-due orders into the future. &#10; Develop exception     messages selection criteria that are meaningful and valid. &#10; Ability to buffer     (maintain safety stock) at component level. &#10; Ability to trace     requirement to its origin (the higher-level assembly causing the dependent     requirement) &#10;&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Shilpa Chandra&quot;,&quot;Michael Alpha&quot;,&quot;Matt Katzorke&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="12/03/25"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Reapproved on 12/3/2025&#10;Old Approval Link : Approval Evidence IP Sprint3.msg"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;M-080 Approval Evidence &quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/08. FTS - Intel Products/03. Final Deliverables/Build/Signavio Flows/Process Flow Approval evidence/M-080 Perform Material Requirement Planning (IP)/Approval Evidence IP Sprint3.msg?csf=1&amp;web=1&amp;e=dGHRmn&quot;}]"/>
