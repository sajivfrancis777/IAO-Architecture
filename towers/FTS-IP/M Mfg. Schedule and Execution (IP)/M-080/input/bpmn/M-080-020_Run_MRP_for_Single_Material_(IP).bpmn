<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_4dbe9962-1cb6-4bd3-9e1f-d1348894254a" name="M-080-020_Run MRP for Single Material" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-1c4f6e74-e763-449d-8849-a00143e3256d">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Process Materials Requirements Plan (MRP) for a single material. This involves 1) a daily net change run in order to generate a new, efficient schedule for all parts 2) a weekly MPS/MRP run for a single program in order to generate a new schedule and capacity load. Specific business requirements for MRP should be identified and implemented. Some examples of requirements include: &#10;&#10;&#10;Daily and weekly net change runs&#10;&#10;Defined lot-sizing techniques                &#10;&#10;Flexibility to incorporate variable time buckets within the planning horizon.&#10; MRP netting material capabilities, etc. &#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Michael Alpha&quot;,&quot;Matt Katzorke&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="18/06/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;M-080 Approval Evidence &quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/08. FTS - Intel Products/03. Final Deliverables/Build/Signavio Flows/Process Flow Approval evidence/M-080 Perform Material Requirement Planning (IP)/Approval Evidence IP M-080.msg?csf=1&amp;web=1&amp;e=4UbcpZ&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="8e3c365c941348fdb6066a545fa4c51e"/>
      </extensionElements>
