   <collaboration id="sid-37be5877-0020-463a-a5aa-09b45397d7f7">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Initiate the conversion from planned orders to production orders. A planned order should exist for each and every production order that hits the production floor. The timing for creation of a production order should be standardized to some time prior to the schedule start date. This will create real load on the production floor, reserve resources and materials, and allow time to resolve any resource shortages. Some examples of business requirements include: &#10;&#10;Ability to specify an alternate routing when converting an order. &#10;Capability to capture 'actual' costing when converting production order using the proper order type. &#10;Ability to select multiple orders for conversion based on criteria (MRP controller and/or specific start date) &#10;Ability to convert planned orders manually based on material availability and capacity. &#10;Ability for system to automatically convert planned orders based on the release date (BOM and routing effectivity must be considered when converting planned orders) &#10;&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Michael Alpha &quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="31/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Evidence IP Sprint5&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/08. FTS - Intel Products/03. Final Deliverables/Build/Signavio Flows/Process Flow Approval evidence/EXT RE Signavio Process Flow R3 Sprint 5 FTS IP.msg?csf=1&amp;web=1&amp;e=H2vd9L&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="bf07823c9b294d9988a70c3fd010628f"/>
      </extensionElements>
