<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-7cdf1fac-e808-4de3-90ef-50cc1bfeecf9" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-39770004-b8e0-471e-8122-554cffb55598">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="A work center is an organizational unit where work is performed-- generating output. A cost center is assigned to the work center. A work center has a finite capacity and activities performed have a specific charge rate. Create, maintain, replace, display and archive work center data using a user-friendly system with minimal manual data entry. Each work center is to be defined within the selected system according to the functional data necessary to support related business activities. Examples of business requirements include: &#10;&#10;Ability to create work center data to support simulation capability. &#10;Ability to mass-change work center master data &#10;Capability to report work centers actual/used capacity vs. estimated capacity. &#10;Ability to convert work center data from current system to new system. &#10;Ability to develop a standard work center process across the entire organization. &#10;Ability to develop work center processing that contribute to improvements such as enhanced workflow, paperless workplace, etc. &#10;Ability to ensure work center data integrity. &#10;&#10; &#10;&#10;&#10;INDUSTRY SPECIFIC: &#10;&#10;&#10;Create, maintain, replace, display and archive work center data using a user-friendly system with minimal manual data entry. Each work center is to be defined within the selected system according to the functional data necessary to support related business activities. Examples of business requirements include:* Ability to create work center data to support simulation capability* Ability to mass-change work center master data* Capability to report work centers actual/used capacity vs. estimated capacity* Ability to convert work center data from current system to new system* Ability to develop a standard work center process across the entire organization* Ability to develop work center processing that contribute to improvements such as enhanced work flow, paperless work place, etc.* Ability to ensure work center data integrity &#10;&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Michael Alpha&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="08/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;M-090-280-Approval Evidence&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/08. FTS - Intel Products/03. Final Deliverables/Build/Signavio Flows/Process Flow Approval evidence/M-090-280, M-090-290/FW R3 FTS IP- Security Role Workshop- Mfg. Schedule and Execution Supply Chain Planning Quality Management .msg?csf=1&amp;web=1&amp;e=AoBbH2&quot;}]"/>
