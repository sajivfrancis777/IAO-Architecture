      <textAnnotation id="sid-CA997A59-E00D-4077-84F9-D0956B18B9ED" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>In case delivery in system is not available or delivery is available but cannot be identified due to damaged labels, Shipping paperwork</text>
      </textAnnotation>
      <textAnnotation id="sid-A3D1B32F-2E9D-4C6B-B520-AF7CC62DF853" signavio:alignment="left">
