            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MQCS relevance will be checked from the (Supplier+ plant Custom Table )created in the S/4 system-QI-130-010</text>
      </textAnnotation>
