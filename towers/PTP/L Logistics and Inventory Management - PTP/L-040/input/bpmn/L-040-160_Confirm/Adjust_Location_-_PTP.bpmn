      <textAnnotation id="sid-1B764F74-AE75-4A6A-8E5B-97C76FF5E497" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Notify the warehouse that the stock type has been changed </text>
      </textAnnotation>
      <textAnnotation id="sid-84FE5314-9431-40B4-8673-E30127F10090" signavio:alignment="left">
         <extensionElements>
