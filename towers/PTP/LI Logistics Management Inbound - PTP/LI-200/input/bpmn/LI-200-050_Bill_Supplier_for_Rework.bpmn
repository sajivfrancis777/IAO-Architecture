      <textAnnotation id="sid-13655F3D-43E7-4C7F-A209-75F18DEFBE72" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
