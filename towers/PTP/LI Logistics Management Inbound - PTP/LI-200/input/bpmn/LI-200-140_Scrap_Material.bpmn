         <text>Process Tower: Procure To Pay
Process Group: Logistics Management Inbound
Process: LI-200-140 Scrap Material
</text>
      </textAnnotation>
      <textAnnotation id="sid-6CA9DEE1-3F09-4AA1-9DFE-F5D5D0F0DF0D" signavio:alignment="left" textFormat="text/plain">
