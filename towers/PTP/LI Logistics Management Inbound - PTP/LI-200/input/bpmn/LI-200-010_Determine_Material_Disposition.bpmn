            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci170436614738196523502"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="Once buyers receive the details of damage or exception during from warehouse, buyers need to align with supplier on what should be the correct disposition for that materials. This would be performed with email sent from buyers to suppliers. The possible disposition could be return the material for credit or replacement, scrap the material or accept the material."/>
