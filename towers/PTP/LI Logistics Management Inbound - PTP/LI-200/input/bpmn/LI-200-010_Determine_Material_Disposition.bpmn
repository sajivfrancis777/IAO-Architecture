   <collaboration id="sid-380f1602-3553-480b-b499-4665eaa979da">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Once the material has been defined as non-conforming, disposition (send) it to the appropriate reject/non-conforming warehouse with the appropriate 'Rejected Material' tags. Identify potential corrective action options including in-house rework/repair, return to supplier, waiver issuance, send to scrap, etc. Analyze the results of the inspection and determine a use for the unacceptable received material."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;lisa.vaughan@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="14/10/24"/>
