      <userTask completionQuantity="1" id="sid-0099C285-7F55-4130-A269-5A73FA5BFAB0" implementation="##WebService" isForCompensation="false" name="LI-200-010-010 Identify Discrepant Materials" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-jobprofile" metaValue="/glossary/f64dc96a613c449fa0a878deb229658c"/>
            <signavio:signavioMetaData metaKey="meta-screenfloriapps" metaValue="[&quot;/glossary/ff6cf640a7a94114a9e7fe2fa8c8465c&quot;,&quot;/glossary/30519e20ff7c455d8e1f24a2045ddb1f&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-system" metaValue="[&quot;/glossary/87e190e5800648088193185674a9aceb&quot;,&quot;/glossary/99ed2fb6879346238999fda867d77df1&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-securityrole" metaValue="[&quot;/glossary/0af18b18579145fb95aa518625246c52&quot;,&quot;/glossary/9dc611cc7dfa438aadf8dafa8799ef8c&quot;,&quot;/glossary/db65bfad7b7c40d2bf76a40dc839b944&quot;,&quot;/glossary/4be6e3d45c444a27b54bf764ecc503b9&quot;,&quot;/glossary/2078982966af4b1fb18d1e3ed3c4f117&quot;,&quot;/glossary/3a4c753087404289b0d375172991a703&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci170436614738196523502"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="  Once  warehouse receives a shipment from supplier there might be some exceptions  for example - the package is damaged, or the plant code is incorrect etc. For  all these exceptions, warehouse cannot proceed with goods receipt and inform  buyers about the discrepant Materials. "/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/f6d8ca83167e4975b0a785eae90f4d34&quot;,&quot;/glossary/aacdd2d442004dbf98224a8c62414d20&quot;]"/>
         </extensionElements>
         <incoming>sid-9214FCB2-A280-4E8D-8FE7-37B3413AC55B</incoming>
         <outgoing>sid-A7FCC1DB-99A0-4309-8104-481F2E7B398A</outgoing>
      </userTask>
      <userTask completionQuantity="1" id="sid-351F5FA5-912F-4600-95A2-0D4B977FF2AA" implementation="##WebService" isForCompensation="false" name="LI-200-010-020 Notify Procurement Discrepancies" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-jobprofile" metaValue="/glossary/f64dc96a613c449fa0a878deb229658c"/>
            <signavio:signavioMetaData metaKey="meta-screenfloriapps" metaValue="[&quot;/glossary/84bcb166c64448ac8a507eb799124bbf&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-system" metaValue="[&quot;/glossary/87e190e5800648088193185674a9aceb&quot;,&quot;/glossary/99ed2fb6879346238999fda867d77df1&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-securityrole" metaValue="[&quot;/glossary/f86e941de6604f41bdeabfc6db072085&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci170436614738196523502"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="  Once  the received material has been defined as damaged or with any  exception(incorrect Material, plant etc.) Warehouse personnel need to inform  this to Procurement buyer responsible. This would be performed with email  mechanism from warehouse to buyers."/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/f6d8ca83167e4975b0a785eae90f4d34&quot;,&quot;/glossary/aacdd2d442004dbf98224a8c62414d20&quot;]"/>
         </extensionElements>
         <incoming>sid-A7FCC1DB-99A0-4309-8104-481F2E7B398A</incoming>
         <outgoing>sid-176AA473-5A51-4BB5-BA0E-07C47E10FB9C</outgoing>
      </userTask>
