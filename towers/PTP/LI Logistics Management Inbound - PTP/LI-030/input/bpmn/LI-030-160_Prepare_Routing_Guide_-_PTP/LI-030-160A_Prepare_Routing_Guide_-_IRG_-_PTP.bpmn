         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Information Exchange/Transformation
Respective
system will
request for
Carrier to SAP
TM. TM will send
back carrier and
Charges
information.
Respective
system will
process the data
sent by TM</text>
      </textAnnotation>
      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: PTP Procure To Pay
Process Group: LI_Logistics Management Inbound
Process: LI-030-160A Prepare Routing Guide - IRG - PTP</text>
      </textAnnotation>
      <textAnnotation id="sid-A77344F2-91CF-4A28-80E2-E6184AB82DD6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
