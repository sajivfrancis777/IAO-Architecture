         </extensionElements>
         <text>Process Tower: Procure to Pay (PTP)
Process Group: LI Logistics Management Inbound
Process: LI-120-100 Receive Material Against Purchase Order</text>
      </textAnnotation>
      <textAnnotation id="sid-90531109-088A-4C0A-8C38-0E8FFA7F2FA0" signavio:alignment="left">
