      <textAnnotation id="sid-7CD34A51-155E-4380-98AC-83F364D5F0B1" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/3bf2b5dedfe147338262f10057b0bfb2</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
