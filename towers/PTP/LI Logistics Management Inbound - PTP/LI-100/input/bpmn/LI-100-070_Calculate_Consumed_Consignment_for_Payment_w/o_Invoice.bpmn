   <collaboration id="sid-7d4be96a-d4c1-4631-88e4-7334b17c2d37">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Consuming consignment stock, requires the user identify the vendor whose stock is being consumed. This is done to assign to the issue, that vendor’s price for the item. Receive consignment stock with the same procedure as for purchased stock. It is, however, assigned a special stock type of 'K'. This causes the stock to be counted within the ERP inventory database but separately from 'owned' stock and it is not valuated for the plant."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;krishna.subramanian@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="30/05/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/LI-100-070 Approval.msg?csf=1&amp;web=1&amp;e=y50Zso&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="e6d48856af654298bb7ac4a80fb4447b"/>
      </extensionElements>
