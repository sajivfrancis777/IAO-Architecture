      <textAnnotation id="sid-BA3B8684-AC03-475F-AB15-2CC141A73674" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Service provider will request MDG team to update MRP parameters in Material Master.</text>
      </textAnnotation>
      <textAnnotation id="sid-49EEB8EA-DA60-4AEA-A1BF-C02AEC6CFB89" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Inventory Report, Min Max/ROP data will be shared with service provider periodically</text>
      </textAnnotation>
