      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="  Establishing  a contract for consignment stock differs from a contract for purchased stock  in three ways:&#10;    - the Vendor/Material consignment relationship must be set-up in  advance&#10;    - use a different Item Category for the line item (category differs by ERP  system)&#10;    - no price may be entered for the line item"/>
