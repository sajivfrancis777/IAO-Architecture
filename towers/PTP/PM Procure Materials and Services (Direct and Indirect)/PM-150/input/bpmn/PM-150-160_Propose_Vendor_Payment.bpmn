      <textAnnotation id="sid-125532BB-8129-445E-AE57-A8DA46EF2146" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Accounts payable team will initiate the payment process in T Code - F110</text>
      </textAnnotation>
      <textAnnotation id="sid-7003A5C3-69B0-4B06-A582-57A0346DA1A3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Parameters has to be inputed for payments</text>
      </textAnnotation>
      <textAnnotation id="sid-2E6F2A23-B10D-471F-8176-321D30A7FDD8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. System will pick all the due invoices as per the parameters </text>
      </textAnnotation>
      <textAnnotation id="sid-561708F2-A404-435C-AA77-FB20035DDD9C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. During the Proposal Run Changes to the Proposal can be done. Ex: Block payment for an invoice, PM change</text>
      </textAnnotation>
      <textAnnotation id="sid-B8733DE9-B085-4DC0-89AF-F63B464647A7" signavio:alignment="left">
         <extensionElements>
