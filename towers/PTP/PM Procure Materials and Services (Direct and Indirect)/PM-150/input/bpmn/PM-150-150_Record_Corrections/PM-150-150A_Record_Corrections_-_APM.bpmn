         <text>Quantum</text>
      </textAnnotation>
      <textAnnotation id="sid-E240488C-D40F-443F-8BDA-7524433DF443" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Payment may comprise of one or multiple invoices</text>
      </textAnnotation>
      <textAnnotation id="sid-F3E1A287-50B1-46E5-91E0-1617BE02F36C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Perform review using Monitor Payments Fiori App</text>
      </textAnnotation>
      <textAnnotation id="sid-06F1513E-C7D0-4C41-9AFE-8F6943C1348E" signavio:alignment="left">
         <extensionElements>
