      <textAnnotation id="sid-EE167457-F6F3-4C96-AD3B-22264C3B4BEE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>FB8U for Cross co. document
Required auto reversal :RICEFW needed
FBRA / FB08 Reset Cleared Items, Reversal of document </text>
      </textAnnotation>
      <textAnnotation id="sid-C5BE9D34-14B6-4F28-A8D2-2A32263DFD7D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Re-Batch the payment through T Code - FBPM1</text>
      </textAnnotation>
