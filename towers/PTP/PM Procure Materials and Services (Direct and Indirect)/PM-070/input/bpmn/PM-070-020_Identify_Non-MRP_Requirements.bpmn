      <textAnnotation id="sid-E54F6707-FC00-424D-A5CC-52F24CCDFB35" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Requirements  are captured via emails and telephones</text>
      </textAnnotation>
      <textAnnotation id="sid-E50EB340-1BC5-4F55-8183-C061C806550E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-93D813AC-D272-4D7B-91C0-89874A7AC55E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Price is derived from material master</text>
      </textAnnotation>
      <textAnnotation id="sid-DA52DC2E-C67C-409E-B567-63960600A7B9" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/cb1bd05cc3f24476b880a54ab8407814</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Email</text>
      </textAnnotation>
      <textAnnotation id="sid-4CA08B58-F4A0-47FE-A34E-96A4EF706CEB" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Indirect purchase requisition is created and price is populated from Ariba Contract Terms document or manually entered into the PR by the shopper</text>
      </textAnnotation>
      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: PTP - Procure To Pay
Process Group: PM - Procure Materials and Services (Direct &amp; Indirect)
Process:PM-070-020 Identify Non-MRP Requirements</text>
      </textAnnotation>
      <textAnnotation id="sid-70C12645-BA26-485D-B3ED-7C503C2CB1EA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Note: 
1. Cluster Definitions:
   a) Cluster 1: Materials and Indirect Procurement (Fab, Spares, AT, SIMs, Equipment materials and Indirect)
   b) Cluster 2: Subcontracting (OSAT, Foundry, ODM, Box CPU)
   c) Cluster 3: Capital and Construction (Construction, Equipment)
2. This process is applicable for all 3 clusters</text>
      </textAnnotation>
      <textAnnotation id="sid-199D5E5A-E554-4C59-A386-7D3CC825A11A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform the process steward Tung, Alfie Him Yeong &lt;alfie.him.yeong.tung@intel.com&gt; and BPM Champions D'Elia, Traci &lt;traci.delia@intel.com&gt;,Newman, Jennifer &lt;jennifer.newman@intel.com&gt;of any design changes that occur within the flow moving forward. This will enable us to reflect those changes in the BIC and WIKI business process documentation.</text>
      </textAnnotation>
