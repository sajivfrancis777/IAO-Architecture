      <categoryValue id="sid-15a99406-3fed-4309-bedd-ff73198c55be" value="These steps are part of managing the tendering process i.e. PM-050-060 Manage Tendering Process"/>
   </category>
   <collaboration id="sid-1b450909-6b05-48cc-ade9-6d3d48a350c8">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Tendering is a formal procedure that has probably been established at a company-wide/ strategic level. Ensure that the process is carried out effectively and in line with official guidelines.  A good tendering process will:&#10;- ensure price competition between suppliers&#10;- have a RFQ ’Request for Quotation’ that states conditions of contract, schedule for pricing, and a technical specification&#10;- evaluation of the bids should be carried out by at least two people&#10;- technical and pricing evaluations should be carried out by different departments&#10;- safeguard against fraud&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;rohan.nageswaran@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="31/05/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-050-060 %26 050-30 Approval.msg?csf=1&amp;web=1&amp;e=d1mlFu&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="ba9e79b273f54dd296a0b080e9dedd0e"/>
      </extensionElements>
