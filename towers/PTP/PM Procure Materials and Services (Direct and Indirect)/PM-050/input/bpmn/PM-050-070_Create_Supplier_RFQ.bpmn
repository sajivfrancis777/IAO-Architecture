   <collaboration id="sid-af326dd8-2027-43c9-bf45-6daa88cd9c51">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="  Develop  a request for quotation (RFQ) for production goods or services, using the  standard template. The RFQ should incorporate all specifications (e.g.  technical drawings, special requirements, forecasted quantities, 'need' cost,  etc.) and additional terms of purchase, including quotation response  deadlines.  Identify candidate  suppliers, freeze its specifications and release it for distribution to the  suppliers. RFQs are for a quantity of items and a specified period of time.  RFQ should also be used for the procurement of recurrent services (e.g.  harvesting services, freight services, road maintenance and construction  services, etc.)  The RFQ should also  specify the quality requirements and the terms and conditions for additional  government, agency or union fees."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;rohan.nageswaran@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="19/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-050-010,PM-050-070,090-040%26PM-090-050 Approval.msg?csf=1&amp;web=1&amp;e=iJJmbu&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="1291bbb664d442e4b5707fdb473b01ac"/>
      </extensionElements>
