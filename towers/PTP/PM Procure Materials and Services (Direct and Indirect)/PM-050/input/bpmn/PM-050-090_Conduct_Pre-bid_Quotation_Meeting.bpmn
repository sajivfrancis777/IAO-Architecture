      <textAnnotation id="sid-3C127E3B-E44F-47CD-8061-15DE7F656BF8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Agenda, Technical aspects, Specifications and Unique Project Details, Scope of Work</text>
      </textAnnotation>
      <textAnnotation id="sid-64615B51-1B34-4A7B-ACB0-A38C4D3D1D76" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Supplier Summit - Conduct Summit to Share, Goal of RFx, Expectations, Comprehensive Specs

2.Share bid Evaluation Rules and Timelines, Submissions Procedures</text>
      </textAnnotation>
      <textAnnotation id="sid-EE4D89E7-4FC1-4283-9F2F-3FE06ECE1405" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
