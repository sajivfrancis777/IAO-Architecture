      <textAnnotation id="sid-1CABA5A7-1B2B-4771-9D7D-C3DCEAAC878A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Review Supplier Capabilities and Identify New/Incumbent Suppliers to Invite for RFx Event

