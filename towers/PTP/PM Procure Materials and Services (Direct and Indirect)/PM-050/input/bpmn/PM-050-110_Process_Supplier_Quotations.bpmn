   <collaboration id="sid-2b966042-8dbd-48d6-a475-4aa54655f365">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="  Document  the quotation information received from the supplier for production goods or  services.  Receive information from  suppliers and analyze it by entering the data into the SAP system. Utilize  SAP functionality to aid in the analysis. This process offers the opportunity  to work as a team rather than having one group make decisions without  involving others with a interest in the project. Your ERP package may have  functionality to evaluate quotes. Enter the data into the software and  utilize the software functionality to perform part of the analysis.  Alternatively, this may be done manually or  with some form of spreadsheet application.   Rank quotations received according to preferred supplier(s) and  prepare for negotiations.&#10;     &#10;    Variations:&#10;    A. Analysis to be performed by the procurement team of people (cost,  product and engineering responses)&#10;    B. Analysis requires input and review of stakeholders in addition to  procurement group.&#10;    "/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;rohan.nageswaran@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="22/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-150-110 Approval.msg?csf=1&amp;web=1&amp;e=W8anFP&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="48cb2328d1be4fb9815bbbda69b385fe"/>
      </extensionElements>
