      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: PTP - Procure To Pay
Process Group: PM - Procure Materials and Services (Direct &amp; Indirect)
Process: PM-050-030 Establish Material Profile</text>
      </textAnnotation>
      <textAnnotation id="sid-BCB918A1-6E34-4674-87AE-0E7BB2FE7567" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>*Material profile is created in MDG and replicated in S4 for existing items.
*For new items the material profile needs to be created in MDG and then sourcing event starts.
*Optional- Definition of material profile will be free text for NPI without material master created.</text>
      </textAnnotation>
      <textAnnotation id="sid-5EAAC73A-265F-4F16-BECD-07C571ABD5AE" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/dbb3746f43bc4d218e7c0835b8d8fe3b</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP MDG</text>
      </textAnnotation>
      <textAnnotation id="sid-A9E69CF0-8540-4EC5-9A66-8A27C39FDCF4" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
