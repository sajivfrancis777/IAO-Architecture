      <textAnnotation id="sid-09EA5D01-992F-4829-992F-EB865F0A5F03" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>*PLM is source of material specifications for MDG
*The material specifications should be added manually as part of the template in Ariba
*Specifications and classifications can be attached as a file in the quote. </text>
      </textAnnotation>
      <textAnnotation id="sid-5380B016-C369-4C4D-AD13-D400EFB2493F" signavio:alignment="left">
