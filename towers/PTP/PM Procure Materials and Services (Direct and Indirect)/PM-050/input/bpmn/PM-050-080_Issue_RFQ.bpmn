      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="  Fully  specify the request and identify candidate suppliers, then freeze the  requests’ specification and release it for distribution to the  suppliers.  Respond to any questions  regarding the RFQ, including: quantities, delivery time, product  specifications, etc.&#10;    Variants:&#10;    - Send paper copy to supplier via postal service&#10;    - Send Fax to supplier&#10;    - Send EDI to supplier &#10;    - Phone supplier&#10;    - Internet"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;rohan.nageswaran@intel.com&quot;]"/>
