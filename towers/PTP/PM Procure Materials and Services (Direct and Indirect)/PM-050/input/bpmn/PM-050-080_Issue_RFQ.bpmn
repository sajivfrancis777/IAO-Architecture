      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: PTP - Procure To Pay
Process Group: PM - Procure Materials and Services (Direct &amp; Indirect)
Process: PM-050-080 Issue RFQ</text>
      </textAnnotation>
      <textAnnotation id="sid-B7F6DEA6-AD41-4D77-84AB-357B55B1ADF8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This step is optional and suppliers can directly communicate with engineering for design specifications</text>
      </textAnnotation>
      <textAnnotation id="sid-E5B08467-1143-425C-A0C1-542BE023DF12" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>For major changes in material requirements the MM Master will be replaced</text>
      </textAnnotation>
