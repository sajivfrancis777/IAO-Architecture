   <collaboration id="sid-c5b42651-96c6-458f-a807-8779b852b9f4">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Identify ways to reduce the number of suppliers used and buy more items from existing suppliers (to generate economies of scale). Typically, pareto analysis of the supply base will show that most purchasing spend is concentrated with a few key suppliers and most suppliers (perhaps 80%) represent the minority of spend (perhaps 20%). There is a high administrative overhead concerned with using and maintaining suppliers on an occasional basis and for low value items. Typical solutions are to reduce the number of suppliers or consider outsourcing opportunities.&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;russell.a.hensley@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="01/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-040-030,050 %26 PM-050-040,050 Approval.msg?csf=1&amp;web=1&amp;e=01LPwh&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="fa1d56cd573240db91ebc0b01dbdf137"/>
      </extensionElements>
