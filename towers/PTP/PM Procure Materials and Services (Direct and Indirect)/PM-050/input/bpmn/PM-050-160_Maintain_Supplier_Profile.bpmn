      <textAnnotation id="sid-0D64C698-38FD-4E28-A16B-DCDED168B48C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>L3 Definition:
Based on supplier selection decision update the supplier profile and master data which will then support in maintaining the source list and add supplier to overall commodity list that supports supplier rationalization efforts.</text>
      </textAnnotation>
      <textAnnotation id="sid-069E59B0-A764-4145-96E8-A2A979BEA61E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
