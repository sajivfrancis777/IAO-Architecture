      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Sometimes the subcontractor will provide corrected component stock consumed figures subsequent to the delivery of the finished product/assembly. These will be processed:&#10;-- as partial reversals to the goods receipt-consumption of the components against the subcontracting purchase order  for overstatements &#10;--as supplemental receipt-consumptions to the goods receipt-consumption of the components for understatements"/>
