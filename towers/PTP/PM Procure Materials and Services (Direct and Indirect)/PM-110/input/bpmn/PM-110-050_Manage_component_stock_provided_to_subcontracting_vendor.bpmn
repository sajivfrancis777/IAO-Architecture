<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:caseagile="http://caseagile.com/schema/BPMN/20170414/MODEL" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="https://www.ecma-international.org/publications/standards/Ecma-334.htm" id="_1a842b8b-9e5d-43c0-8e9f-92564424da79" name="PM-110-050_Manage component stock provided to subcontracting vendor" targetNamespace="http://caseagile.com/schema/BPMN/20170414/MODEL" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-254f81cc-c8bb-4fb5-a9fd-a7609b61d522">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Isolate the stock delivered to or set aside for the subcontractor in a special stock status so that it will not be considered available for use in any other production plan. Stocks at Vendor’s Site- In subcontracting, the components mentioned in a subcontract purchase order which are required to manufacture the end product by the subcontractor needs to be provided to the subcontractor in the ratio/quantity determined by the system or via a bill of materials already available into the system. These components to the subcontractor can be supplied by the business or by any third party vendor. The quantities of Stock of Material Provided to Vendor are entered and are available at vendor’s site until it is completely consumed."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Dhanwantry, Kalyan R &lt;kalyan.r.dhanwantry@intel.com&gt;&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="28/08/24"/>
