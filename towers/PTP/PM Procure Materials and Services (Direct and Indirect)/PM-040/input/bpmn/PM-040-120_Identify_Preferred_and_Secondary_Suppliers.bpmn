   <collaboration id="sid-e0c23157-ffef-455b-9394-82926c3f3a44">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Identifying preferred and secondary suppliers is a strategic process in supply chain management where businesses categorize vendors based on their performance, reliability, cost-effectiveness, and strategic importance to the company. This categorization helps in optimizing procurement strategies and ensuring supply chain resilience. Preferred suppliers are those that have consistently demonstrated high performance in delivering goods and services. They often meet or exceed the company’s requirements for quality, reliability, price, and service. Secondary suppliers are alternate vendors that a company uses when preferred suppliers are unable to meet the full demand either due to capacity issues, logistical challenges, or when seeking to mitigate risk and avoid dependency on a single supplier."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;russell.a.hensley@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="30/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-040-120 Approval.msg?csf=1&amp;web=1&amp;e=4uK6QN&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="73a96b8a996140f48094c3e05711808f"/>
      </extensionElements>
