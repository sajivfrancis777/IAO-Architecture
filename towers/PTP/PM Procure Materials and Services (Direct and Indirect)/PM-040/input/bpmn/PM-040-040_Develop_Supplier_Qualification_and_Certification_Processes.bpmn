<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-a94ceaee-258e-49ef-a87d-af8857285fe6" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-ece49024-c05e-4b8f-8505-45c75f9ee921">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Establish procedures for evaluating the supplier's performance, specify qualification as a supplier, and determine procedures and frequency for auditing compliance. This includes procedures which are be used by the company's employees (e.g, inspection criteria, delivery information recorded by receiving personnel) in order to certify vendors, satisfy financial checks (i.e annual reports and credit checks), provide satisfactory responses to a supplier self evaluation (i.e covering quality control, industrial relations history, organization structure, health and safety, etc) and conduct a successful inspection of the supplier premises. Other possible criteria for supplier assessment are : past performance, reputation , visit and appraisal), third party certification, evaluation of sample products."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;russell.a.hensley@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="25/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-040-040 Approval.msg?csf=1&amp;web=1&amp;e=JHBDWd&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="12b96dd92e8247809e3d732a7ff4055b"/>
      </extensionElements>
