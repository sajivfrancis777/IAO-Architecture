   <collaboration id="sid-8d1aa746-6825-4a93-a1fe-f747f4203f75">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Establish performance standards for suppliers in line with overall quality requirements and specific product specifications.  Develop procedures and policies for certification (e.g. how does a supplier become certified; what is the certification process) of vendors/suppliers. With each RFQ and contract, establish standards for, but not limited to, these factors:&#10;- Pricing scale and effective period&#10;- Material/service quality standards&#10;- Material/service availability&#10;- Delivery timeliness&#10;- Acceptable variance on quantities received&#10;- Use of supplier’s quantity shipped in lieu of company-generated information&#10;- Labeling&#10;- Advance shipment notification&#10;- QS 9000 certification&#10;- Adherence to ethical practices&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;russell.a.hensley@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="11/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-040-010 Approval.msg?csf=1&amp;web=1&amp;e=7s1nHV&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="50308dbcaa0042a7aa62755ae6869fe0"/>
      </extensionElements>
