   <collaboration id="sid-19759b8c-c00d-42c2-81e1-0784a62b3451">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Enhance and develop on-going supplier relationships and provide timely feedback of performance data to suppliers. This feedback could be about their performance in assessment programs or in an ongoing supply of goods/services. For established suppliers, involve both superior and sub-standard performers in the communication. Reward outstanding performance, if only through annual recognition with a letter of commendation. Elicit corrective action through this feedback to sub-standard performers."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;russell.a.hensley@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
