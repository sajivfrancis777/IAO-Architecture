<?xml version="1.0" encoding="UTF-8"?><definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:i18n="http://www.omg.org/spec/BPMN/non-normative/extensions/i18n/1.0" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:signavio="http://www.signavio.com" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Signavio Process Editor, http://www.signavio.com" exporterVersion="26.10.0-20260311103619+6e2d3ac" expressionLanguage="http://www.w3.org/TR/XPath" id="sid-3037a602-b0a3-415e-a3aa-6d52a5b98321" targetNamespace="http://www.signavio.com" typeLanguage="http://www.w3.org/2001/XMLSchema" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd">
   <collaboration id="sid-7bca6604-c27f-4575-9765-d3101fc3e344">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="  This  process is intended to ascertain the supplier’s ability to consistently meet  quality standards in a predictable and repeatable manner.  Determine a supplier’s capability to  manufacture and distribute a quality product which meets the company’s  business and commercial needs. Factors involved in this assessment would  include the supplier’s production capacity, location, business technology  environment, financial strength, percentage of business our orders would be  of their total, distribution network, ability to provide technical  support,  loyalty to the company, etc.  Included here is the company’s technical assessment of how  well the supplier’s product works in the  company’s processes.  This assessment  may include the actual purchase of samples and testing of their suitability  for use in products. Suppliers of equipment, and service suppliers must also  be included in this approval process.   The supplier assessment should be formal in nature and not subjective.  Communications with respect to this assessment process should include  approval and denial/recommended actions documentation. &#10;    &#10;    Variants:&#10;     - Raw Material Suppliers &#10;     - Equipment &amp; Supply  Suppliers&#10;     - Service Suppliers"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;russell.a.hensley@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="20/07/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-040-020 %26 PM-040-080.msg?csf=1&amp;web=1&amp;e=5g1Cdb&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="4813c9b3d39f483383e56163e94848ad"/>
      </extensionElements>
