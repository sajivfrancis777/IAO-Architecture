      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Procure To Pay
Process Group: Procure Materials and Services (Direct &amp; Indirect)
Process: PM-040-070 Qualify/Disqualify Existing Suppliers
</text>
      </textAnnotation>
      <textAnnotation id="sid-5B90EB8A-A1D0-411E-A7F3-F33619FF8DC7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This Includes no change, blocking or inactive supplier</text>
      </textAnnotation>
      <textAnnotation id="sid-B56D7183-0D2A-450C-95F1-138DF31F93A1" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This is for specific selection of supplier for sourcing event.</text>
      </textAnnotation>
      <textAnnotation id="sid-328C28AE-33C0-470F-B673-794407C04293" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>L3 Description- 
Apply the qualification standards agreed upon for this purchasing relationship to each candidate supplier. Attempt to determine the supplier's capability to manufacture and distribute a quality product which meets the company's business and commercial needs.</text>
      </textAnnotation>
      <textAnnotation id="sid-74B73949-0719-4B9F-A1C8-0BC22B4B4B30" signavio:alignment="left">
         <extensionElements>
