   <collaboration id="sid-2450ac7e-e871-446d-8ab8-5971e5d019e2">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Meet with supplier(s) and review any information regarding the contract/quotation that may not be clear. Communicate specific needs (i.e. price, delivery time, etc.) that are not being satisfactorily met per the supplier’s quotation. Reach agreement on all outstanding issues with suppliers. Input from Legal may be required.  Details of information to review, include: terms of sale, duration, description/scope, service level commitments, quality level - payment of union fees, agency fees and crown dues (if applicable),mailing &amp; official notification addresses, identities of key contacts, etc. The strategy for negotiation should not be the same with major suppliers and secondary (part of the contingency plan) suppliers.   &#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;rohan.nageswaran@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="03/09/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/06. PTP/3 Final Deliverables/1. Design/O. Process Approval Evidence/PM-090-030 Approval.msg?csf=1&amp;web=1&amp;e=tNeAWO&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="5e48c3b72a71409b9f38390437f1214d"/>
      </extensionElements>
