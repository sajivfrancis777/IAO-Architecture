      <textAnnotation id="sid-8FD9E26D-093D-4F79-BB54-3E5CAD0DAA07" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Neg Plan is a pre-requisite to get contract approved in ICI</text>
      </textAnnotation>
      <textAnnotation id="sid-77AE05DA-EC28-4CF1-BDDC-955FB2A5664D" signavio:alignment="left">
