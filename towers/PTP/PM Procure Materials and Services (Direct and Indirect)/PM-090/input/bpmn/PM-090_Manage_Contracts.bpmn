      <textAnnotation id="sid-5D10D755-185E-4C0C-8089-6FF60ADEDC4C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Normal spares to be tackled under Create Service agreement L3​

