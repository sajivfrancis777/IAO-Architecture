      <userTask completionQuantity="1" id="sid-402F0D09-F1F7-44FE-A44D-361F38EC97C7" implementation="##WebService" isForCompensation="false" name="PM-080-140-020&#10;Verify Terms and Conditions  with New Supplier&#10;" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-jobprofile" metaValue="/glossary/a0bbe1b7709e46ee88407842de0cad52"/>
            <signavio:signavioMetaData metaKey="meta-screenfloriapps" metaValue="[&quot;/glossary/407f839e0e65420cb3b2d723a9b30fff&quot;,&quot;/glossary/320e6365242d42998e4b5a43355da4a4&quot;,&quot;/glossary/ac2e103749e645869886e013eca27a4e&quot;,&quot;/glossary/ee0973a0bb4e45a2bc89b2226835d8e3&quot;,&quot;/glossary/bf5b717d13934563abf330f9d60cd719&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-system" metaValue="[&quot;/glossary/87e190e5800648088193185674a9aceb&quot;,&quot;/glossary/26348bf3c2d7489aa4b9b12403db5e92&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-securityrole" metaValue="[&quot;/glossary/ac24120fb4224426ac3b642db65fee01&quot;,&quot;/glossary/453c52247c3840a99298c28b5e967411&quot;,&quot;/glossary/dcea50094e0342f5b370a4062bb791fc&quot;,&quot;/glossary/b76b3be370c642548c7f6e0e4afb861e&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci1704366147381296654580"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="Present, discuss and verify with the new Supplier the information necessary to conduct business with your company. This will include Terms and Conditions, quantity, dates, prices, packaging, carrier assignment, etc.  It must be a formal process where the supplier accepts, in writing, the standards and requirements under which they agree to conduct business.  Upon agreement and understanding being reached, add Supplier to the Qualified Supplier List.&#10;&#10;Communicate standards, qualification, evaluation, and auditing procedures for the requested purchase(s), to the new suppliers. This is an on-going process, whereby suppliers are educated about the company’s standards and requirements.  These communications would include the commercial aspects of the relationship as well as volumes, price, purchase order specifications, etc. It must be a formal process where the supplier accepts, in writing, the standards and requirements under which they agree to conduct business.&#10;"/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/f6d8ca83167e4975b0a785eae90f4d34&quot;,&quot;/glossary/aacdd2d442004dbf98224a8c62414d20&quot;]"/>
         </extensionElements>
         <incoming>sid-5C69AE46-46EB-4045-BFBD-B857F2F68F94</incoming>
         <outgoing>sid-36B30026-ECAA-48C2-B932-A5EC4D456160</outgoing>
