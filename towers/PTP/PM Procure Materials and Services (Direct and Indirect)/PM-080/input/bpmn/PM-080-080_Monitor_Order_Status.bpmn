   <collaboration id="sid-3fd195cc-5fab-40f1-9295-805e23cc57ef">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="  Open  purchase order status is monitored by the buyer or purchasing agent  responsible for the vendor delivery performance. Monitor order status for any  discrepancies (price, delivery date, order quantity) between the Order  Acknowledgement and the original Purchase Order. Resolve differences between  the buyer and the supplier. This can be done by system-generated reports, ad  hoc queries or by PO specific inquiries into the materials system.  Monitor order status for any discrepancies  (price, delivery date, order quantity) between the Order Acknowledgement and  the original Purchase Order. Resolve differences between the buyer and the  supplier."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;richard.w.taylor@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
