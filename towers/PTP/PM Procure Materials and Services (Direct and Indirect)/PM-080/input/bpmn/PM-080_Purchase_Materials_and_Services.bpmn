      <userTask completionQuantity="1" id="sid-3413AB50-79E1-4CAC-9228-D1719ED25551" implementation="##WebService" isForCompensation="false" name="PM-080-070-010&#10;Receive Order Acknowledgment​" startQuantity="1">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#ffffcc"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioMetaData metaKey="meta-jobprofile" metaValue="/glossary/a0bbe1b7709e46ee88407842de0cad52"/>
            <signavio:signavioMetaData metaKey="meta-system" metaValue="[&quot;/glossary/87e190e5800648088193185674a9aceb&quot;]"/>
            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci170436614738196523502"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="Based on the alignment with supplier Supplier can send the Order confirmations. The supplier can send the acknowledgement for partial order i.e. some line items not all. Based on acknowledgement business can resolve order issues with the supplier and modify the Order as required. If resolution cannot be made, cancel the original purchase order and repeat the supplier selection process. May require order acknowledgements for specific items, such as one-time purchases of a unique/critical piece of equipment."/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/f6d8ca83167e4975b0a785eae90f4d34&quot;,&quot;/glossary/aacdd2d442004dbf98224a8c62414d20&quot;]"/>
         </extensionElements>
         <categoryValueRef>sid-87bdeec5-3860-44ba-8025-ddfbc492bc7e</categoryValueRef>
         <incoming>sid-35CD0904-16B3-4BBB-91CD-A102AAB0DD81</incoming>
         <outgoing>sid-489E3F76-1B6D-472B-AB2E-B50BDE69DF08</outgoing>
      </userTask>
