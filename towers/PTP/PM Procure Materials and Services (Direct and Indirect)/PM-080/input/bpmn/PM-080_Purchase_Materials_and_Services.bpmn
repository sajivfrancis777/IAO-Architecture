            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci1704366147381571714331"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="Based on the alignment with supplier Supplier can send the Order confirmations. The supplier can send the acknowledgement for partial order i.e. some line items not all. Based on acknowledgement business can resolve order issues with the supplier and modify the Order as required. If resolution cannot be made, cancel the original purchase order and repeat the supplier selection process. May require order acknowledgements for specific items, such as one-time purchases of a unique/critical piece of equipment."/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/f6d8ca83167e4975b0a785eae90f4d34&quot;,&quot;/glossary/aacdd2d442004dbf98224a8c62414d20&quot;]"/>
