            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>MQCS</text>
      </textAnnotation>
      <textAnnotation id="sid-318906C0-9995-47AA-AB20-8FDFC7D37883" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>The Order status will be monitored while this task is being performed</text>
      </textAnnotation>
      <textAnnotation id="sid-B0C1E869-2DA0-4E72-939D-240AED5D1A80" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>The Order status will be monitored while this process is being executed.</text>
      </textAnnotation>
      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Procure To Pay
Process Group: Procure Materials and Services (Direct &amp; Indirect)
Process: PM-080-160 Manage Advanced Shipping Notifications
</text>
      </textAnnotation>
      <textAnnotation id="sid-F79B3C37-DE7F-497C-895A-224D2E401CCD" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Supplier creates ASN using E2Open, Web Suite (WEB-ASN) and Open Text</text>
      </textAnnotation>
      <textAnnotation id="sid-BD18922B-8305-43BC-87AE-E3AA3AB0DDF6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform the process steward Sherman, Wendy S &lt;wendy.s.sherman@intel.com&gt;, Kasturi, Sri Harisha Sai &lt;sri.harisha.sai.kasturi@intel.com&gt; and BPM Champions D'Elia, Traci &lt;traci.delia@intel.com&gt;,Newman, Jennifer &lt;jennifer.newman@intel.com&gt;of any design changes that occur within the flow moving forward. This will enable us to reflect those changes in the BIC and WIKI business process documentation.</text>
      </textAnnotation>
   </process>
