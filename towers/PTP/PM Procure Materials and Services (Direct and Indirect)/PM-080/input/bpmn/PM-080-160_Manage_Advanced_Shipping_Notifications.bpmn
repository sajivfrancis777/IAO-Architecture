      <textAnnotation id="sid-1C7E2607-3A76-4D35-A80A-69975B11D0F6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>In Case of CofA rejection following actions can be taken:
1. Resubmission of CofA with the correct fields OR
2. Rejection of the batch</text>
      </textAnnotation>
      <textAnnotation id="sid-689F0C68-67D6-4566-AED8-8F98B3FBEC38" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>TM Relevant- Freight Unit Creation</text>
      </textAnnotation>
      <textAnnotation id="sid-B8ABB8B6-303A-4F47-B50A-4644E8DE9480" signavio:alignment="left">
         <extensionElements>
