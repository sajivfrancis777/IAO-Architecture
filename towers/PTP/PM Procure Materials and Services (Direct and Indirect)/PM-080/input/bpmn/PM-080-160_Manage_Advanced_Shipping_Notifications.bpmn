            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue=" Manually enter ASNs received via mail or fax.  ASNs received via EDI should automatically update the Purchase Order in the system.  This will assist in scheduling of receiving dock operations, aid in production planning/delivery to point of use material operations.&#10;&#10;Receive Shipping Notification from supplier. The following information is required:  Ship date, ship quantity, supplier’s lot number, and tank car/container number.&#10;Note: This can also be manually maintained at the PO schedule line w.r.t. a Confirmation Category (LA Inbound Delivery).&#10;"/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/f6d8ca83167e4975b0a785eae90f4d34&quot;,&quot;/glossary/aacdd2d442004dbf98224a8c62414d20&quot;]"/>
         </extensionElements>
