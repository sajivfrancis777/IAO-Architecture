      <textAnnotation id="sid-F822FA74-7172-427E-9815-7F9DCE2EB5D9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Supplier creates ASN
2. Supplier Collaboration – E2Open, SIRFIS, Web Suite
</text>
      </textAnnotation>
