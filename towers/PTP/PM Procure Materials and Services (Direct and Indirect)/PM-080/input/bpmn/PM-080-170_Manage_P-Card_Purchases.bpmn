      <textAnnotation id="sid-314A14A9-8B31-44C4-84A0-6244022B61EF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>CPC users reclassify the spends</text>
      </textAnnotation>
      <textAnnotation id="sid-B521238D-9859-40AF-9047-89F38DB8FAE5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Tool is used to reconcile or reallocate transactions to the appropriate code (GL/cost center)​</text>
      </textAnnotation>
      <textAnnotation id="sid-445824C4-084A-416E-9023-4CF532E26868" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Actualization is done using Non-PO Tool</text>
      </textAnnotation>
      <textAnnotation id="sid-D805C19E-A3CB-4243-8B66-BCB3F1A1D21A" signavio:alignment="left">
         <extensionElements>
