      <textAnnotation id="sid-D4E8D838-FB79-4817-BB06-AEE9B871D701" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Option 1: Provide S4 access to CW Buyer for monitor PO.
Option 2: System generate automatic few reports to provide PO data to CW Buyer for monitoring Purchase Order</text>
      </textAnnotation>
      <textAnnotation id="sid-6D4F7842-F05F-4320-A45E-B911C142F13D" signavio:alignment="left">
