      <textAnnotation id="sid-88D6E546-5208-4155-9974-04AB2A06B023" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Service Provider Will act as CW buyer For Monitoring  Purchaser Order</text>
      </textAnnotation>
