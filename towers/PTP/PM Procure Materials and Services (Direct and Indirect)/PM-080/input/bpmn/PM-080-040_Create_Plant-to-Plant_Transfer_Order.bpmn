      <textAnnotation id="sid-89837583-0BE4-4F82-8FBD-0440F39AA1FB" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>In case of Inter Company STO, the price will be derived from receiving plant  </text>
