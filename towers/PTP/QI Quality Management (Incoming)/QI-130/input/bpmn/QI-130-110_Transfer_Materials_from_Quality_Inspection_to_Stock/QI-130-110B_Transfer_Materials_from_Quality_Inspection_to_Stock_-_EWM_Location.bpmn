      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Procure To Pay
Process Group: Quality Management (Incoming)
Process: QI-130-110B Transfer Materials from Quality Inspection to Stock - EWM Location</text>
      </textAnnotation>
      <textAnnotation id="sid-6C70E2A4-8971-4782-A1AD-302D6E6394FF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform the process steward Vaughan, Lisa &lt;lisa.vaughan@intel.com&gt; and copy BPM Champion Liu, Vivian &lt;vivian.liu@intel.com&gt; of any design changes that occur within the flow moving forward. This will enable us to reflect those changes in the BIC and WIKI business process documentation.
 </text>
      </textAnnotation>
   </process>
