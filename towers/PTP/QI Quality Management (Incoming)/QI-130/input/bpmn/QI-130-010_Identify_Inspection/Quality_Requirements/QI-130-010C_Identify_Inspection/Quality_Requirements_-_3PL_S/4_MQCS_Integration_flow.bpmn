         <text>3PL (Third Party Logistics)</text>
      </textAnnotation>
      <textAnnotation id="sid-E70A3FBC-827E-41EC-B747-DFACBFD9DBFC" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Additionally Stock type change/Batch expiry change in 3PL gets reflected in SAP S/4
 
</text>
      </textAnnotation>
      <textAnnotation id="sid-79A86A53-5B33-48D6-9E87-58EA1BDA431C" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/1c7aa3aa610d4fddb8bd1e1401c0b82b</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>3PL (Third Party Logistics)</text>
      </textAnnotation>
      <textAnnotation id="sid-F03510E8-EF1A-479B-9778-419147915288" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/1c7aa3aa610d4fddb8bd1e1401c0b82b</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>3PL (Third Party Logistics)</text>
      </textAnnotation>
      <textAnnotation id="sid-1BEAD97A-342F-4ADB-B172-863772D47B78" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Inventory Adjustment happens on the received stock ( due to Damage/Inventory count difference/batch expired)</text>
      </textAnnotation>
      <textAnnotation id="sid-6C70E2A4-8971-4782-A1AD-302D6E6394FF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform the process steward Vaughan, Lisa &lt;lisa.vaughan@intel.com&gt; and copy BPM Champion Liu, Vivian &lt;vivian.liu@intel.com&gt; of any design changes that occur within the flow moving forward. This will enable us to reflect those changes in the BIC and WIKI business process documentation.
 </text>
      </textAnnotation>
   </process>
