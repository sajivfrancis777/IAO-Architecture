      <textAnnotation id="sid-5142449E-CE8F-4199-A6C9-1C1383926255" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: OTC Order To Cash (IP)
Process Group: GT Global Trade (IP)
Process: GT-030-100 Notify responsible process owner to proceed with transaction or cancel the order (IP)</text>
      </textAnnotation>
      <textAnnotation id="sid-2A62FDD3-4284-4963-A650-B66606C50919" signavio:alignment="left" textFormat="text/plain">
