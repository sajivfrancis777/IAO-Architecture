         </extensionElements>
         <text>Process Tower: OTC Order To Cash (IP)
Process Group: GT Global Trade (IP)
Process: GT-040-040 Maintain new licenses (IP)</text>
      </textAnnotation>
      <textAnnotation id="sid-2A62FDD3-4284-4963-A650-B66606C50919" signavio:alignment="left" textFormat="text/plain">
