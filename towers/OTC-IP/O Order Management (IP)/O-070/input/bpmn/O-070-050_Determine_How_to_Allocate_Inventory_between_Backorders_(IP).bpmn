         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1) From Change order - (assumptions) if there was a previous  commit it will remain 
2) From Create order - no sales order generated</text>
      </textAnnotation>
      <textAnnotation id="sid-DDA0C807-4EEA-46F6-A68D-C61BAFF5123A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Only available in Manual ATP"</text>
      </textAnnotation>
      <textAnnotation id="sid-8BAFFFF7-3050-461F-8DC5-887EFAF306E3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>For VMI Pull (KE) - must resolve reconciliation to help confirm KE</text>
      </textAnnotation>
      <textAnnotation id="sid-BD695AE8-7558-4CFE-8076-BDC96F6A0716" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Invoice Only Order</text>
      </textAnnotation>
      <textAnnotation id="sid-D0B9BCCA-B219-452D-946D-D56E8AF8CE5B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1) From Change order - (assumptions) if there was a previous it commit will remain 
2) From Create order - no sales order generated</text>
      </textAnnotation>
