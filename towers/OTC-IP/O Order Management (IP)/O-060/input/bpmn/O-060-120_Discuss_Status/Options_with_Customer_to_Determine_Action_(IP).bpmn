      <textAnnotation id="sid-6090C52D-BE9F-47F8-A607-DA3F21ACCB3E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Hold/blocks could be applied at Line item and/or Header level 
2. As more holds/blocks are decided and how they behave we will continue to add to the flow</text>
      </textAnnotation>
