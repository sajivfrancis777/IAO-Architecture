         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower : OTC -Order to Cash
Process Group: O_Order Management
Process: O-060-130_Create Backorder (Delinquent?)


</text>
      </textAnnotation>
      <textAnnotation id="sid-5AABB5F7-F14F-467A-92C9-DFDE12FD03A4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
