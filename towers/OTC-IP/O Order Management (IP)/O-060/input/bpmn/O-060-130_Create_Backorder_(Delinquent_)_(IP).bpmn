      <textAnnotation id="sid-C5CF545E-C030-4BEF-935D-80844D1691F7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>All product except Samples QSPEC, VMI KE, IRC model (TBC) and invoice only item categories will go to BYOP for Supply and allocation</text>
      </textAnnotation>
      <textAnnotation id="sid-38762821-1EC7-4885-9DE2-7CBA45D8F8EB" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
