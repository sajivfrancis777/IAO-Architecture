      <textAnnotation id="sid-0130A5DA-9640-4B06-8EEF-49A4ADD79614" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Obtain CBA Managers approval (offline approval) for Manual Price Override</text>
      </textAnnotation>
      <textAnnotation id="sid-A0D00426-93AD-4092-8BB0-97868022FAFE" signavio:alignment="left">
         <extensionElements>
