      <textAnnotation id="sid-2788A9AB-A662-4A6D-81A7-B8B3D1309D20" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.WWPO validates the price tier calculations within IPAR are administering the correct values, into the correct price conditions.
2.Update the correct Price in case of any discrepancies</text>
      </textAnnotation>
      <textAnnotation id="sid-68259DE4-9193-4A70-A107-EDE3A42C74F3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Create, Change and expirations will be taking place</text>
      </textAnnotation>
      <textAnnotation id="sid-33307F1C-C386-44DE-9BA2-EAD6EB425DB0" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/e9945c9938454c5d8c92e48e6ea45d1c</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>IPAR</text>
      </textAnnotation>
      <textAnnotation id="sid-AABDB5BE-A50F-4BB8-B71A-67F987D9FDA8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1 Review the Price components loaded  for each Prod BU and perform necessary Price Updates and sync the same to IP SAP System 
2.Perform the Manual price update by Fiori App in case of Non accessibility of Boundary Apps.</text>
      </textAnnotation>
      <textAnnotation id="sid-2FC801FE-4146-456E-932D-29D0328C4BC0" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.Expedite Charges
2.Cancellation charges
3.Manual price override</text>
      </textAnnotation>
