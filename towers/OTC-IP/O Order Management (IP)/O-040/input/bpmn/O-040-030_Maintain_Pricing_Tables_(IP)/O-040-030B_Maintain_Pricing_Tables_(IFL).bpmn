      <textAnnotation id="sid-E667B012-2227-4ADE-9DBB-73E7DDCA722E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.Manual Upload takes place when the Boundary Apps are facing downtime.
2.Create, Change and expirations will take place.</text>
      </textAnnotation>
      <textAnnotation id="sid-B6B7FCD6-2A2E-413F-83DB-E1F031F6E287" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower : OTC  Order to Cash
Process Group: O Order Management
Process: O-040-030B Maintain Pricing Tables (IFL)

</text>
      </textAnnotation>
      <textAnnotation id="sid-F1999967-043A-4BAA-8DD6-5984FD6B37B5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="24.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="24.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>No specific requirement for IFL</text>
      </textAnnotation>
