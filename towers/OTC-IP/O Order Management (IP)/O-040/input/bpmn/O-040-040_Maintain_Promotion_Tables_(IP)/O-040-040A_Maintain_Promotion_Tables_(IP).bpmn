   <collaboration id="sid-d1dc2cc7-d01a-40ad-96b0-3c943e88c82f">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Maintain the system tables that control promotion table pricing.  Promotion table normally run for a short time period; the special pricing indicated is valid for corresponding short time periods only.  Negotiate a promotion with the customer by the sales department and record the pricing information and forward it  to customer services personnel to set-up on the system.  Arrange promotion using these tables (designated by customer and product code) for specific dates.  They could be percentages or values per product or product group. These promotional prices will override normal pricing for the duration of the promotion"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;1. nuria.galceran@intel.com&quot;,&quot;2. melissa.pruden@intel.com&quot;,&quot;3. teresa.mcnicol@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="14/06/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Approval Mail&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/05. OTC - Intel Products/6 Detail Design Workshops/IP_Order Management/IP_OM_Pricing_Flows_Approval/14 June_ IP I Calculate Order Price I Signavio Process Flows Review.pdf?csf=1&amp;web=1&amp;e=h8pgcP&quot;}]"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="c736e97f2b224afe9e3246777bb6d966"/>
      </extensionElements>
