      <textAnnotation id="sid-90FE5DB1-A462-482A-9800-A3D127C6681B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.Manual Upload takes place when the Boundary Apps are facing downtime.
2.Create, Change and expirations will be taking place</text>
      </textAnnotation>
      <textAnnotation id="sid-199F92C3-4D21-4D6A-AA9F-E2E278F4ABA9" signavio:alignment="left">
         <extensionElements>
