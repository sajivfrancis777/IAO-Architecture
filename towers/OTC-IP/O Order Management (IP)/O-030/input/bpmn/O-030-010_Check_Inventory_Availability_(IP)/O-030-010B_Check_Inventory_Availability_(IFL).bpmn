      <textAnnotation id="sid-E7292F15-A3D6-41BB-B76E-7AD2BB0E5013" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower : OTC-Order To Cash
Process Group: O-Order Management
Process: O-030-010B Check Inventory Availability (IFL)</text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening outside of O-030-010 and are covered in subsequent L3s</text>
      </textAnnotation>
      <textAnnotation id="sid-E9F429CD-B4B7-4B0D-AEBB-98E3FDCE7884" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#FFCC00"/>
            <signavio:signavioLabel bold="" fill="#ffcc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ffcc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening in BY</text>
      </textAnnotation>
      <textAnnotation id="sid-B7FD0341-EA0B-4479-B4D6-7D566AB87E1E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> This Master flow will represent O-030-030B / O-030-010B / O-030-020B / O-030-100 / O-070-050</text>
      </textAnnotation>
      <textAnnotation id="sid-BBB0CD24-0E8E-4108-9A14-2B2B359FD15E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/04b83b1aa5da43179b6ed26475955f26</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel align="right" bottom="false" left="true" ref="text_name" right="false" top="false" valign="middle" x="-7.0" y="29.0"/>
         </extensionElements>
         <text>Blue Yonder
 SPM</text>
      </textAnnotation>
      <textAnnotation id="sid-91892B6C-8407-43AD-9FD1-D144C81DFB7D" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel align="left" bottom="false" left="false" ref="text_name" right="true" top="false" valign="middle" x="68.0" y="29.0"/>
         </extensionElements>
         <text>SAP 
S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-388A93FC-7F6D-40B0-B236-2357354BDD68" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Update the sales order  with respect to MMID, quantity, delivery date, plant,etc. automatically based on Dassian updates (flow down)
2 All customers marked for complete/ full delivery</text>
      </textAnnotation>
      <textAnnotation id="sid-1690425D-C717-4E66-925D-3C5DE15FE35E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP 
S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-597B3AD0-7C66-4219-80EF-7D086DF9F3AE" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Check Supply and check allocation both are happening in the same call  in BY</text>
      </textAnnotation>
      <textAnnotation id="sid-232701A8-7F00-4C49-9EDA-1D4E594544F4" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP 
S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-EDD313B9-CEF4-498D-996F-ECA2CB2C20C2" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP 
S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-F9D2ECED-B70D-4F40-AD0E-A7B6DC07CC9A" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-56FCDE19-966F-466F-BF25-D96DE33DD1BA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.Only applies to real time ATP
2 Real CMAD received from BY then calculation will be CMAD + TPT = CDD 


</text>
      </textAnnotation>
      <textAnnotation id="sid-9CDA570A-2C2E-4FE1-9151-E86826108759" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP 
S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-C5CF545E-C030-4BEF-935D-80844D1691F7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Assumption is that all products have to go to BYOP for inventory and allocation checks. (Opens on Federal, Intel Resale, Samples QSPEC, Consignment and Forward stage inventory)
2. This process is not relevant to current business process - All Products expect VMI KE and invoice only item categories will go to BYOP for Supply and Allocation</text>
      </textAnnotation>
      <textAnnotation id="sid-2EB696B0-25CF-4BC8-9B82-517529539D82" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>BY relevance check more related to Master data
 </text>
      </textAnnotation>
      <textAnnotation id="sid-BF0F3C1B-F8E8-4A7C-B5EE-FD82EBC1EFE9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>If connection error between BYOP and S4, then user will get an error message in ATP screen, error will be logged in report</text>
      </textAnnotation>
      <textAnnotation id="sid-6A37FB48-286A-4510-9AA2-14C9B586DFFD" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Sales Order line item is unconfirmed</text>
      </textAnnotation>
      <textAnnotation id="sid-439A030A-FFFF-4A7A-9691-FC704FB67311" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP 
S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-9E94297B-5956-407B-876A-0964BA7E952D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1) From Change order - (assumptions) 
if there was a previous it commit will remain 
2) From Create order - no sales order generated</text>
      </textAnnotation>
      <textAnnotation id="sid-6E3F6371-4BA5-44DB-9701-E98F405EFAEF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1) From Change order - (assumptions) if there was a previous it commit will remain 
2) From Create order - no sales order generated</text>
      </textAnnotation>
      <textAnnotation id="sid-79523B0B-1EC7-4943-A560-D2E6A7CD031D" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Product &amp; Location sub is disabled for Intel Federal </text>
      </textAnnotation>
      <textAnnotation id="sid-89B91DB2-5D71-49E1-B06A-D6AF9BCF83D1" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/f304934a2cda4988bf97484658f73148</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Dassian - S/4 HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-49807D9D-3B96-4B12-90E8-CA4DFE9677A9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SO2 process also applies</text>
      </textAnnotation>
      <textAnnotation id="sid-1805393A-2917-4338-9620-536DB77B395C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SO2 could be created up to 13 days prior to SO1 CMAD</text>
      </textAnnotation>
      <textAnnotation id="sid-877C00DF-5F50-497F-9673-FC4DCB6543FB" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
