            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Blue Yonder
 SPM</text>
      </textAnnotation>
      <textAnnotation id="sid-7547F01B-43AC-45B5-8BCA-3AED47AAC798" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Logistics wrapper program will apply for 2DN model</text>
      </textAnnotation>
      <textAnnotation id="sid-A51BAA52-57B1-4438-9F65-0CCE1431BBD8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This process is not relevant to current business process</text>
      </textAnnotation>
      <textAnnotation id="sid-65410961-1074-4FBB-92AF-FBD21E0433A6" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-9229B504-7ACC-4750-ADF3-BA6C97BA8F5B" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/04b83b1aa5da43179b6ed26475955f26</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
