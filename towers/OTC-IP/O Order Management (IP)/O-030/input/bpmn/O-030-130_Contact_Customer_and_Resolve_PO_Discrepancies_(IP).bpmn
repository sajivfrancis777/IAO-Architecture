      <textAnnotation id="sid-E7292F15-A3D6-41BB-B76E-7AD2BB0E5013" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower : OTC-Order To Cash
Process Group: O-Order Management
Process: O-030-130 Contact Customer and Resolve PO Discrepancies (IP) </text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening outside of Process Order and are covered in subsequent L3s</text>
      </textAnnotation>
      <group categoryValueRef="sid-4aebc163-0821-471b-a79f-4379530b7bdb" id="sid-CAFC35B9-3635-4281-9FD2-4C34ED0F2C0C">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </group>
      <textAnnotation id="sid-B7FD0341-EA0B-4479-B4D6-7D566AB87E1E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> This Master flow will represent O-030-100 &amp; O-030-130</text>
      </textAnnotation>
      <textAnnotation id="sid-01B4C3B1-F992-4264-90F7-5B9C9BFEA474" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="24.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="24.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform Process Steward: Sandhu, Anita &lt;anita.sandhu@intel.com&gt;, and BPM Champion: Rebeca, Meza Redondo &lt;rebeca.meza.redondo@intel.com&gt; of any changes that occur within the flow from now onwards so that changes can be accurately reflected within BIC</text>
      </textAnnotation>
   </process>
