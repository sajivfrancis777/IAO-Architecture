            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Web Order Management</text>
      </textAnnotation>
      <textAnnotation id="sid-7EE36088-2837-441E-B740-B1036E007438" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Capture Order Flow defines whether the Order confirmation is required or not</text>
      </textAnnotation>
      <textAnnotation id="sid-8C16C0C0-2701-4B06-8196-CF40330305D3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Customer receives electronic acknowledgment based on some significant changes regardless if order is confirmed or unconfirmed</text>
      </textAnnotation>
      <textAnnotation id="sid-D6BFFB3D-61B3-4D66-BDB8-81D23093D0D2" signavio:alignment="left">
         <extensionElements>
