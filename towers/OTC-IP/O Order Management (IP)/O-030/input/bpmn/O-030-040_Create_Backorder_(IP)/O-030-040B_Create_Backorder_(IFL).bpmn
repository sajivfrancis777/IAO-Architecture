      </textAnnotation>
      <textAnnotation id="sid-7547F01B-43AC-45B5-8BCA-3AED47AAC798" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Logistics wrapper program will apply for 2DN model</text>
      </textAnnotation>
      <textAnnotation id="sid-A51BAA52-57B1-4438-9F65-0CCE1431BBD8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This process is not relevant to current business process</text>
      </textAnnotation>
      <textAnnotation id="sid-65410961-1074-4FBB-92AF-FBD21E0433A6" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-5AABB5F7-F14F-467A-92C9-DFDE12FD03A4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening outside of O-030-130 and are covered in subsequent L3s</text>
      </textAnnotation>
      <textAnnotation id="sid-E9F429CD-B4B7-4B0D-AEBB-98E3FDCE7884" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#FFCC00"/>
            <signavio:signavioLabel bold="" fill="#ffcc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ffcc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening in BY</text>
      </textAnnotation>
      <group categoryValueRef="sid-d395effa-8f3e-4397-9528-84aa6027ab52" id="sid-575C6C5B-365B-4065-82A2-3E196091919D">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </group>
      <textAnnotation id="sid-8ADC96A0-E337-485D-BE7F-A278E38EB324" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>This flow will be master flow and represent O-030-040 &amp; O-060-040 </text>
      </textAnnotation>
      <textAnnotation id="sid-01B4C3B1-F992-4264-90F7-5B9C9BFEA474" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="36.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="36.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform Process Steward: LeBlanc, Brian &lt;brian.leblanc@intel.com&gt;, and BPM Champion: Rebeca, Meza Redondo &lt;rebeca.meza.redondo@intel.com&gt; of any changes that occur within the flow from now onwards so that changes can be accurately reflected within BIC</text>
      </textAnnotation>
   </process>
