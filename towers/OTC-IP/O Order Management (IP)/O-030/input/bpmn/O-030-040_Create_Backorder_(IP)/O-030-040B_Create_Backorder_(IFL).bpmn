            <signavio:signavioLabel align="right" bottom="false" left="true" ref="text_name" right="false" top="false" valign="middle" x="-7.0" y="29.0"/>
         </extensionElements>
         <text>Blue 
Yonder 
SPM</text>
      </textAnnotation>
      <textAnnotation id="sid-2EBF908D-CCBF-4DD5-B7FB-5446253CE71F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. This step will be part of batch run only
2.  Production Planner to communicate delays in supply to relevant business stakeholders via email</text>
      </textAnnotation>
      <textAnnotation id="sid-571A3F01-E501-4FD9-A12A-6502BFAAE447" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual task for CBA in real time only</text>
      </textAnnotation>
      <textAnnotation id="sid-B120F9F1-5F09-4ABF-89C3-57FAF947F062" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual task for CBA in real time, for batch run will be default "yes"</text>
      </textAnnotation>
      <textAnnotation id="sid-A09DA050-288A-48D9-A773-BECB1AF739C9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual task for CBA in real time, for batch run will exit only</text>
      </textAnnotation>
      <textAnnotation id="sid-7FED9197-B259-4ECE-8D9C-120656D706EB" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>BY relevance check more related to Master data</text>
      </textAnnotation>
      <textAnnotation id="sid-38647DFA-81F6-4A06-9AC3-244C6FBFB731" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Sales order line item is unconfirmed</text>
      </textAnnotation>
      <textAnnotation id="sid-BF0F3C1B-F8E8-4A7C-B5EE-FD82EBC1EFE9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>If connection error between BYOP and S4, then user will get an error message in ATP screen, error will be logged in report</text>
      </textAnnotation>
      <textAnnotation id="sid-49807D9D-3B96-4B12-90E8-CA4DFE9677A9" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SO2 process also applies</text>
      </textAnnotation>
      <textAnnotation id="sid-1805393A-2917-4338-9620-536DB77B395C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SO2 could be created up to 13 days prior to SO1 CMAD</text>
      </textAnnotation>
      <textAnnotation id="sid-877C00DF-5F50-497F-9673-FC4DCB6543FB" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
