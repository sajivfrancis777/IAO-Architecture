            <signavio:signavioLabel align="right" bottom="false" left="true" ref="text_name" right="false" top="false" valign="middle" x="-7.0" y="29.0"/>
         </extensionElements>
         <text>SAP 
S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-C5CF545E-C030-4BEF-935D-80844D1691F7" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.DPAS Rating captured on the SOLI to be sent to BY
2.Assumption is that all products have to go to BYOP for inventory and allocation checks. (Opens on Federal, Intel Resale, Samples QSPEC)
3. This process is not relevant to current business process - All Products expect VMI KE and invoice only item categories will go to BYOP for Supply and Allocation</text>
      </textAnnotation>
      <textAnnotation id="sid-38762821-1EC7-4885-9DE2-7CBA45D8F8EB" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="32.0" y="-9.0"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-56FCDE19-966F-466F-BF25-D96DE33DD1BA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.Only applies to real time ATP
2 Real CMAD received from BY then calculation will be CMAD + TPT = CDD 


</text>
      </textAnnotation>
      <textAnnotation id="sid-EA8CF624-3CF2-4F77-96A5-1A259340F359" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="32.0" y="-9.0"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-D1A6E756-5F20-4A97-B332-E3F9763792C9" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
