            <signavio:signavioMetaData metaKey="meta-degreeofautomation" metaValue="ci1704366147381296654580"/>
            <signavio:signavioMetaData metaKey="meta-taskdescription" metaValue="As an OM CBA, I want to see any issues or discrepancies that should arise from order creation to the manufacturing and shipping of the orders. These discrepancies will be raised to the customer and depending on the nature of the issue, I should be able to clarify or resolve it with the customer. Resolution may include requesting for PO update, new PO, order change, addendum, etc. I should also be able to hold or block the   order at any point as a result of the issue/discrepancy or an authorized user have ask ed us to hold the order. I should be able to choose from pre -determined list of reasons."/>
            <signavio:signavioMetaData metaKey="meta-instance" metaValue="[&quot;/glossary/aacdd2d442004dbf98224a8c62414d20&quot;]"/>
            <caseagile:model xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:semantic="http://www.omg.org/spec/BPMN/20100524/MODEL">
