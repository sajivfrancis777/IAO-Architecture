      <textAnnotation id="sid-72F76591-F313-4EA8-BAEF-CAF87EC614CA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Release confirmed Quantity from S/4 to Blue Yonder</text>
      </textAnnotation>
      <textAnnotation id="sid-36A39F6F-FE4B-4047-A82C-022AC4F1554E" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
