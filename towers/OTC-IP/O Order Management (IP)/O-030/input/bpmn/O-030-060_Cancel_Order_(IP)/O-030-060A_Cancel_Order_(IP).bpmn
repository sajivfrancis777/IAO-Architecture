            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bottom="false" left="false" ref="text_name" right="false" top="true" valign="bottom" x="32.0" y="-9.0"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-1E9FA119-F263-4FF9-ADF8-1850C2BF227F" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-CABE3F0B-91D8-4AD1-9869-FCB80AF06B8E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Rejection Reason=
Customer Cancellation</text>
      </textAnnotation>
      <textAnnotation id="sid-81A16A05-0E21-4EDA-862B-2B6F008BA4BF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="10.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="10.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>1. Prior to sending cancellation for approval, CBA checks if Sales Order Line item (SOLI) has a delivery note created &amp; where it is in processing. 
2.If delivery note for SO1 or SO2 is created no manager approval should be sought as cancelation not allowed.
3. Cancellation push back should be worked with field, BU and Operations and customer should be informed that charges may apply if this request is sent for Manager Approval. 
4.If customer persists approval is requested to appropriate manager</text>
      </textAnnotation>
      <textAnnotation id="sid-F80D6210-2218-430A-8A19-32D6D99736F4" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-DCBB522A-A89F-4BA4-8B0A-1A8F14524E39" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/5c0c65a2540c438eadc4d41423e3ef0e</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>My Samples 
(Future of Samples)</text>
      </textAnnotation>
      <textAnnotation id="sid-92752339-F564-4A3A-95EC-383AD0E08098" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Customer informed that cancellation 
request has been rejected via email. No change is made to Sale Order Line item in S4'</text>
      </textAnnotation>
      <textAnnotation id="sid-D73F29F8-2F7A-41C1-980B-4934062D39F0" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Cancelation to also be recorded in change log report</text>
      </textAnnotation>
      <textAnnotation id="sid-51373F0F-793B-4128-B39C-556B03A0513F" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Either this activity can be done manually or automatically</text>
      </textAnnotation>
      <textAnnotation id="sid-E7292F15-A3D6-41BB-B76E-7AD2BB0E5013" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower : OTC - Order To Cash
Process Group: Order Management
Process: O-030-060A Cancel Order (IP)</text>
      </textAnnotation>
      <textAnnotation id="sid-E9F429CD-B4B7-4B0D-AEBB-98E3FDCE7884" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#FFCC00"/>
            <signavio:signavioLabel bold="" fill="#ffcc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ffcc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening in BY</text>
      </textAnnotation>
      <textAnnotation id="sid-B7FD0341-EA0B-4479-B4D6-7D566AB87E1E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>  This flow is master and it will cover O-030-060 and O-060-180 L3s</text>
      </textAnnotation>
      <group categoryValueRef="sid-a1de4204-e4f9-4b54-bd1c-1815cca27598" id="sid-575C6C5B-365B-4065-82A2-3E196091919D">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </group>
      <textAnnotation id="sid-01B4C3B1-F992-4264-90F7-5B9C9BFEA474" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="36.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="36.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform Process Steward: Anita Sandhu &lt;anita.sandhu@intel.com&gt;, and BPM Champion: Rebeca, Meza Redondo &lt;rebeca.meza.redondo@intel.com&gt; of any changes that occur within the flow from now onwards so that changes can be accurately reflected within BIC</text>
      </textAnnotation>
   </process>
