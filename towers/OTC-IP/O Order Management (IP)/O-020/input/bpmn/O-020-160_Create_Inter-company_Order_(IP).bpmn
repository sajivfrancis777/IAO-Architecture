   <collaboration id="sid-9c75e5bc-7883-436d-b283-8b94ac043d9b">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="An inter-company business transaction is where sales transactions (sales orders and billing documents) for the sale of materials are carried out in a company code different from that used for the storage, production, and delivery of those materials. E.g., Company code A orders goods through its sales organization A from Plant B belonging to Company code B. It is imperative that both Plants A &amp; B should contain master data records for the materials ordered by the customer. In other words, the material is created for both the Plants A and B and their respective storage locations"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;nuria.galceran@intel.com&quot;,&quot;teresa.mcnicol@intel.com&quot;,&quot;anita.sandhu@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="25/03/24"/>
