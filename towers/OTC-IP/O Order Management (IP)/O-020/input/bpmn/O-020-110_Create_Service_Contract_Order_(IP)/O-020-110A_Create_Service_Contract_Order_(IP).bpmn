      <textAnnotation id="sid-3C16F60A-C576-4EDB-A682-00DA60BE3A0D" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-9A9D1C7F-CE27-4D4E-B6B6-788D08E14312" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-F7C014E8-23F7-4C03-91C4-A374E73FCDFB" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-E0965BF1-7E08-4158-A4D2-7052DEA12A11" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. No inventory check,  will be performed for Service Contract.
2. Price will be entered manually by CBA</text>
      </textAnnotation>
      <textAnnotation id="sid-B5244D92-3469-4F3B-8FA0-2D9A7DDE2AF6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Fix exception</text>
      </textAnnotation>
      <textAnnotation id="sid-776D6346-2AF7-4D28-BBAD-720B39075885" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.Mat-Rel Value contract will be created.
2.Intangible products like Professional Services, Installation of Material, Training, etc., will be booked for the total amount of the Service Value.</text>
      </textAnnotation>
      <textAnnotation id="sid-02160FE1-A14D-499D-AE04-AA17FE8E64B4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Determine ZWK2 Order Type</text>
      </textAnnotation>
      <textAnnotation id="sid-692E1B1D-7C3D-4F20-919A-4D2BC796DC07" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. FSCM stands for Financial Supply Chain Management</text>
      </textAnnotation>
      <textAnnotation id="sid-BD390474-21FB-4467-A6CA-9206743A465B" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-3D3D0252-5466-45A7-9907-3E5F93D9A570" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>User status will be configured in the event of any error, CBA can manually put the order on hold</text>
      </textAnnotation>
      <textAnnotation id="sid-755A715B-F93B-4517-B1B0-42B2659D1691" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-21147E5D-145D-4FA4-BFB6-C729C037AE59" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Perform system checks that ensures customer is not on the denied country or party list</text>
      </textAnnotation>
      <textAnnotation id="sid-5F4AA0FA-A234-483F-BAA2-7C4F64FEA446" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. MMID stands for Material ID and CPN stands for Customer Part Number
2.Derive MMID using CPN or In case MMID is received, that will be used for creation of the order</text>
      </textAnnotation>
      <textAnnotation id="sid-39A7702F-C1B2-4D76-A61E-3BCF98FED836" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening outside of Capture Order and are covered in subsequent L3s</text>
      </textAnnotation>
      <group categoryValueRef="sid-fe9377e3-c58c-4c60-80a6-5a16f0599606" id="sid-CAFC35B9-3635-4281-9FD2-4C34ED0F2C0C">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </group>
      <textAnnotation id="sid-01B4C3B1-F992-4264-90F7-5B9C9BFEA474" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="18.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="18.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform Process Steward: Nuria, Galceran &lt;nuria.galceran@intel.com&gt;, and BPM Champion: Rebeca, Meza Redondo &lt;rebeca.meza.redondo@intel.com&gt; of any changes that occur within the flow from now onwards so that changes can be accurately reflected within BIC</text>
      </textAnnotation>
   </process>
