         </extensionElements>
         <text>Process tower: OTC-Order To Cash
Process Group: O-Order Management
Process: O-020-190 Chargeable Sample Order</text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
