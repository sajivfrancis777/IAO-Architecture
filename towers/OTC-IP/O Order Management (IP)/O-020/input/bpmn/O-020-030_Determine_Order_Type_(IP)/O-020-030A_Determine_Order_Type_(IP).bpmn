   <collaboration id="sid-f0f7b395-d3e2-4ac9-8b3a-038dd8106fb5">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="Sales related business transactions are recorded in the system as sales documents. These sales documents are further identified as the order type. Order types are a key parameter that defines the purpose of the sales document, such as a sales contract, order, FoC etc. They help in categorizing different business transactions. They determine the process steps, document flow and relevant data. Orders types can also be determined automatically based on the pre-defined business rules in SAP"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;nuria.galceran@intel.com&quot;,&quot;teresa.mcnicol@intel.com&quot;,&quot;anita.sandhu@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="22/05/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="Intercompany order automatically will happen in all sales order types"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;Process Approval&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:b:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/05. OTC - Intel Products/6 Detail Design Workshops/IP_Order Management/IP_Process Flows/O-020 Capture Order/Approvals/Approval_O-020-30, O-020-100.pdf?csf=1&amp;web=1&amp;e=uymlFG&quot;}]"/>
