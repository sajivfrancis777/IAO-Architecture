      <textAnnotation id="sid-B227E944-5671-4C48-9730-C51F5D5322C5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Order determination config 
would be in Dassian and 
S4 would validate the 
order that is determined</text>
