      <textAnnotation id="sid-38766547-E886-407F-B1A1-EA5BBFCB3D98" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Planner will be responsible for the creation of KB order manually
2. CBA will also have the access to create and update KB orders
3. This is an Exception</text>
      </textAnnotation>
