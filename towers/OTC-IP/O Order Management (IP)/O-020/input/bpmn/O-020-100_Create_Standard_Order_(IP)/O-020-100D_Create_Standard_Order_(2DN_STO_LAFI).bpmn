      <textAnnotation id="sid-59C94693-5948-44F2-B308-26EA4B0F81B8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text> X Dock to LAFI TR2 flow</text>
      </textAnnotation>
      <textAnnotation id="sid-83837536-452E-4045-98EB-EBCAE618A507" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SO2 needs GTS check to ensure SO1 customers are not on sanction hold, of they are SO2 does not ship</text>
      </textAnnotation>
      <group categoryValueRef="sid-6c7763ab-291c-45a0-81f3-3b995057adfc" id="sid-CAFC35B9-3635-4281-9FD2-4C34ED0F2C0C">
