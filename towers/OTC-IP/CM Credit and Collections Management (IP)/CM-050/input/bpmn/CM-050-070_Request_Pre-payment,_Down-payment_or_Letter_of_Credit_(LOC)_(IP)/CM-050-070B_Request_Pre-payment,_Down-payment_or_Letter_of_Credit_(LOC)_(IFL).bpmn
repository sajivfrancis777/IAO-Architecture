      </textAnnotation>
      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: OTC-Order To Cash
Process Group: CM-Credit &amp; Collection Management
Process Name: CM-050-070B Request Pre-payment, Down-payment or Letter of Credit (LOC) (IFL)</text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="14.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="14.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening outside of Manage Customer Credit Exposure and are covered in subsequent L3s</text>
      </textAnnotation>
      <group categoryValueRef="sid-f94f3791-848e-4cc5-91e7-9836b778277c" id="sid-CAFC35B9-3635-4281-9FD2-4C34ED0F2C0C">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </group>
      <textAnnotation id="sid-6A382521-79B1-4863-A7D2-04BC4461D57E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="36.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="36.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform Process Steward Bui, Hannah N hannah.n.bui@intel.com, Business Analyst Nguyen, Linda Y linda.y.nguyen@intel.com, and Xian, Molly molly.xian@intel.com of any changes that occur within the flow.</text>
      </textAnnotation>
   </process>
