   <collaboration id="sid-f97ed558-feae-4657-b4f0-596f1c156b5a">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="This process explains the credit checks involved at time of Sales Order creation.  &#10;For a Sales Order that fails to pass the credit checks, system will automatically block the sales order from further processing.  Credit Manager can manage the blocked sales orders using the Credit Release Management Dashboard.  Via the dashboard, Credit Manager can release the blocked sales orders at line items level or keep the sales orders, line items on block contingent upon the customer's credit standing."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Lafree, Shelly shelly.lafree@intel.com; McNicol, Teresa teresa.mcnicol@intel.com; Nguyen, Linda Y linda.y.nguyen@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="04/11/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="96974c50539947e98569247e7dbb125d"/>
      </extensionElements>
