      <textAnnotation id="sid-E0C9B099-8C67-4F89-9095-F919BEF2DED3" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Edit the Credit Data on Business Partner Credit Profile based on following parameters
1. Credit Segment
2. Credit Risk Class
3. Credit Check Rule</text>
