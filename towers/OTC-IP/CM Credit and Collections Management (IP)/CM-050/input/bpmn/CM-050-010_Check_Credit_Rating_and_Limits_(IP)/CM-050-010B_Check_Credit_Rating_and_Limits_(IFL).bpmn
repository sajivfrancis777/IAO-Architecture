   <collaboration id="sid-a29c91e5-c9d4-4792-b33e-6447a07cdbed">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="This process explains the three (3) main credit checks performed on Sales Orders:  &#10;Credit check triggered at time of Order Create/Change based on Customer Credit Line availability, Customer Credit Line Valid To/Expiry Date and Customer Payment Performance Check rules.  &#10;Credit check triggered when Sales Orders entering the 14 days horizon window.  &#10;Credit Check triggered automatically for blocked Sales Orders considering changes to Customer Payment info.  &#10;During credit checks, system takes into account customer available credit line as well as their total credit exposure which includes the cumulative value of the sales order backlog, deliveries, open billings &amp; outstanding receivables"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Lafree, Shelly shelly.lafree@intel.com; McNicol, Teresa teresa.mcnicol@intel.com; Nguyen, Linda Y linda.y.nguyen@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="04/11/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="revisionid" metaValue="d1cf2b2097bd42b59ef0a7c5d3a81f4d"/>
      </extensionElements>
