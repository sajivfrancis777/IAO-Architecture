   <collaboration id="sid-85ea3de5-f119-4d80-9fe5-8c4485d3fa21">
      <extensionElements>
         <signavio:signavioDiagramMetaData metaKey="meta-processdescription" metaValue="This process explains when a Sales Order fails to pass credit checks, system will automatically place the order on Credit Hold which will not allow the creation of Delivery Note.  &#10;In response, Credit Manager may initiate a Credit Limit Request to increase customer’s credit line. &#10;- If the Credit Limit Request receives approval, customer's available credit limit will be raised, potentially resulting in the release of the Sales Order from Credit Hold.  Consequently, this would allow Delivery Note and Billing to be processed.&#10;- If the Credit Limit Request is rejected, the Sales Orders will remain on Credit Hold, preventing further processing until the credit issue is resolved."/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvedby" metaValue="[&quot;Lafree, Shelly shelly.lafree@intel.com; McNicol, Teresa teresa.mcnicol@intel.com; Nguyen, Linda Y linda.y.nguyen@intel.com&quot;]"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalstatus" metaValue="ci1710756720720143051910"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvaldate" metaValue="12/08/24"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalcomments" metaValue="&#10;"/>
         <signavio:signavioDiagramMetaData metaKey="meta-approvalevidence" metaValue="[{&quot;label&quot;:&quot;CM-050 Approval Email&quot;,&quot;url&quot;:&quot;https://intel.sharepoint.com/:u:/r/sites/inteldeloitteiao/Shared Documents/General/Implementation/04. OTC - Intel Foundry/2 Design Sprint detailed plans/Phase 1 Detailed design %26 Sprint Planning/Workshops/Credit %26 Collections/Signavio Process Flow Approvals/EXT RE CC Business Process Flows - IP and IF.msg?csf=1&amp;web=1&amp;e=xtycwm&quot;}]"/>
