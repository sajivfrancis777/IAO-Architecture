            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Process is covered outside of BR-170-080</text>
      </textAnnotation>
      <group categoryValueRef="sid-60d11ef3-801e-462d-880e-c97cb9022493" id="sid-CAFC35B9-3635-4281-9FD2-4C34ED0F2C0C">
