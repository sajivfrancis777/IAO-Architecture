         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-7011FDE6-4C45-4729-9596-EDD67C7DB889" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Billing Document will be created by Billing Due List batch Job</text>
      </textAnnotation>
      <textAnnotation id="sid-6C9423C6-FF0B-4817-9A1B-E99A1F1F5F05" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Billing Document will be created by Billing Due List batch Job
2. Manage billing document app can be used for the posting status monitoring 
3.IT ticket can be raised to resolve the billing batch job issue
4.Invoice list will be generated with individual billing documents</text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
