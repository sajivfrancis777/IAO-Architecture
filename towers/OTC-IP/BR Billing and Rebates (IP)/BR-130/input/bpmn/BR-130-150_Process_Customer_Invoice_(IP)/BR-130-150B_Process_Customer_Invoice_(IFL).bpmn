      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: OTC-Order To Cash
Process Group: BR-Billing and Rebates
Process Name: BR-130-150B Process Customer Invoice (IFL)</text>
      </textAnnotation>
      <textAnnotation id="sid-B426D82C-3276-4BAD-BAB7-4BFC0248995B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Once PDF Invoice is approved, billing document will be posted for AR </text>
      </textAnnotation>
      <textAnnotation id="sid-9B204E10-76CE-4BA5-95DB-B80534D02271" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Output will be archived only if A/R Posting is done successfully</text>
      </textAnnotation>
      <textAnnotation id="sid-FF8A78A0-DED0-4582-947D-3683C40D2924" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-B0F5A7D6-7E60-4114-8BB1-B6D30D508116" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-22528553-4D4D-45F9-9E12-40A73E75FC00" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Billing will always end with a Milestone Invoice</text>
      </textAnnotation>
      <textAnnotation id="sid-6F6C97F0-3DF8-49DA-AEDD-CF67A0014A5C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Cost Invoice to be Manually Generated using SF1034 AND sf1035 gov forms.
Milestone Invoice is Systematically Generated.
Progress Billing Invoice is Manually Generated using SF1443  gov form</text>
      </textAnnotation>
      <textAnnotation id="sid-0E346366-AFF3-436C-87EF-77376343E5C1" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Systematic for Milestone </text>
      </textAnnotation>
      <textAnnotation id="sid-8B99A08D-13BE-40C7-AC2D-0AFCD2B088C8" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manual for Cost and Progress Billing</text>
      </textAnnotation>
      <textAnnotation id="sid-4F50F467-0051-4161-B2B7-367C215802DA" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel ref="text_name" valign="middle" x="34.0" y="82.0"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-5EA44D8C-3EFC-4E1E-A0D7-6D06CE9E2EF2" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-629A32EA-4C54-4E18-BF22-D7B99AE0281C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Once approved, invoice sent to the customer.</text>
      </textAnnotation>
      <textAnnotation id="sid-06ABFBD7-6EDD-4A21-A63A-9C4FEAEB7557" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Project Manager and Account Manager approval is required to trigger the AR posting</text>
      </textAnnotation>
      <group categoryValueRef="sid-93b3c61a-3c5d-44d8-a0ca-17d17efb60b4" id="sid-CAFC35B9-3635-4281-9FD2-4C34ED0F2C0C">
