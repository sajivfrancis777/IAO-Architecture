      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: OTC-Order To Cash
Process Group: BR-Billing and Rebates
Process Name: BR-130-060B Create Invoice for Relevant Sales Order Items (IFL)</text>
      </textAnnotation>
      <textAnnotation id="sid-8591AC7E-05F5-45B9-9F39-08E7D6012502" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-7011FDE6-4C45-4729-9596-EDD67C7DB889" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Billing Document will be created by Billing Due List batch Job
2. Manage billing document app can be used for the posting status monitoring 
3.IT ticket can be raised to resolve the billing batch job issue</text>
      </textAnnotation>
      <textAnnotation id="sid-1C64CC4E-25AE-402A-949C-144C2175A647" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Prerequisite:
1.Output condition record to be maintained
2,Delivery Document must be PGI before billing
3. Charge will be calculated through Cost or Milestone Invoice</text>
      </textAnnotation>
      <textAnnotation id="sid-7413EFD0-E564-4564-8FEC-96E5DEB694DA" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.NO A/R Posting for FOC Invoice Process
2. No Invoice Output will be generated</text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Processes are happening outside of BR-130-060B and are covered in subsequent L3s</text>
      </textAnnotation>
      <group categoryValueRef="sid-e1b761ca-b1d9-4682-a8ab-3c33ba722844" id="sid-CAFC35B9-3635-4281-9FD2-4C34ED0F2C0C">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
      </group>
      <textAnnotation id="sid-01B4C3B1-F992-4264-90F7-5B9C9BFEA474" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="18.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="18.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform Process Steward: Matt Bailey&lt;matthew1.bailey@intel.com&gt;, and BPM Champion: Maria Ramirez, Loria &lt;maria.ramirez.loria@intel.com&gt; of any changes that occur within the flow</text>
      </textAnnotation>
   </process>
