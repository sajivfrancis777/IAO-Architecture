      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: OTC-Order To Cash
Process Group: BR-Billing and Rebates
Process Name: BR-130-090 Create Contract Milestone Invoice</text>
      </textAnnotation>
      <textAnnotation id="sid-CE1A94EE-7211-419E-9A31-A866ABA7579F" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
               <signavio:dictionaryLink>/glossary/87e190e5800648088193185674a9aceb</signavio:dictionaryLink>
            </signavio:signavioDictionaryLink>
            <signavio:signavioType dataObjectType="IT-System"/>
            <signavio:signavioMetaData metaKey="bgcolor" metaValue="#e1e1e1"/>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP S/4HANA</text>
      </textAnnotation>
      <textAnnotation id="sid-7011FDE6-4C45-4729-9596-EDD67C7DB889" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1. Billing Document will be created by Billing Due List batch Job
2. Manage billing document app can be used for the posting status monitoring 
3.IT ticket can be raised to resolve the billing batch job issue</text>
      </textAnnotation>
      <textAnnotation id="sid-1C64CC4E-25AE-402A-949C-144C2175A647" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Prerequisite:
 output condition record to be maintained</text>
      </textAnnotation>
      <textAnnotation id="sid-633F6F42-2BF9-46A6-B021-F42C68ED15D0" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>1.Milestone Billing Plan Met
</text>
      </textAnnotation>
