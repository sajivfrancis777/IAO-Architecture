      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: OTC-Order To Cash
Process Group: BR-Billing and Rebates
Process Name: BR-130-170 Run Billing Statement Cycle File (IFL)</text>
      </textAnnotation>
      <textAnnotation id="sid-6F6C97F0-3DF8-49DA-AEDD-CF67A0014A5C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Manually generate an Invoice Output in PDF format, using 1034 and 1035 Government forms</text>
      </textAnnotation>
      <textAnnotation id="sid-B426D82C-3276-4BAD-BAB7-4BFC0248995B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Once PDF Invoice is approved, billing document will be posted for AR </text>
      </textAnnotation>
      <textAnnotation id="sid-9B204E10-76CE-4BA5-95DB-B80534D02271" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Output will be archived only if A/R Posting is done successfully</text>
      </textAnnotation>
      <textAnnotation id="sid-7CD6BB5A-48DB-4105-8920-DB277106F8E6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Create Cost Type Contract Invoice
</text>
      </textAnnotation>
      <textAnnotation id="sid-06ABFBD7-6EDD-4A21-A63A-9C4FEAEB7557" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Project Manager and Account Manager approval is required to trigger the AR posting</text>
      </textAnnotation>
      <textAnnotation id="sid-5138EF0E-CA67-4DAF-A08F-C439C85FBA33" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Once approved, invoice will be send to customer. </text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
