      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="12.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="" fontFamily="" fontSize="12.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Process Tower: OTC-Order To Cash
Process Group: BR-Billing and Rebates
Process Name: BR-130-100B Determine Cause of Discrepancy (IFL)</text>
      </textAnnotation>
      <textAnnotation id="sid-0F5AD99E-2C76-4B59-9503-F7F8F9B705AF" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>If accounting has not posted, no further action is needed. If it has posted, then cancel invoice will be posted to AR</text>
      </textAnnotation>
      <textAnnotation id="sid-B9BA40FF-7F7B-47D5-B0F8-998FAAEEFE0E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>It will be Cost type contract invoice. </text>
      </textAnnotation>
      <textAnnotation id="sid-0911988E-BFC4-487B-ADF3-71349FCF0E40" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#99CC00"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#99cc00" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Process is covered in BR-130-120 L3</text>
      </textAnnotation>
      <group categoryValueRef="sid-4eeb1e61-fce9-4b94-ab46-898a3adc34e0" id="sid-CAFC35B9-3635-4281-9FD2-4C34ED0F2C0C">
