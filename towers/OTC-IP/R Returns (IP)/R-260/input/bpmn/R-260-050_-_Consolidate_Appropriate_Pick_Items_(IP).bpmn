      <textAnnotation id="sid-07EA6F4D-9FCA-492E-9678-E0CC189C0C0A" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Follow GTS Requirement  clearing process</text>
      </textAnnotation>
      <textAnnotation id="sid-B93157AC-9AB3-4F02-9A32-197BE27363E5" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="24.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="24.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform Process Steward: Moore, Kimberly &lt;kimberly.moore@intel.com&gt; and BPM Champion: Bowers, Colleen &lt;colleen.bowers@intel.com&gt;  of any changes that occur within the flow from now onwards so that changes can be accurately reflected within BIC</text>
      </textAnnotation>
   </process>
