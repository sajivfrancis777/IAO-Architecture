            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>SAP Extended Warehouse
 Management (EWM)</text>
      </textAnnotation>
      <textAnnotation id="sid-1D4227FD-6054-4ED8-8417-C13492BA4512" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
