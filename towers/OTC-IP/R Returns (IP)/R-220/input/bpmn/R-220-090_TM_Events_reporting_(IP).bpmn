      </textAnnotation>
      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Order To Cash
Process Group: LO Logistics Management Outbound
Process Name: R-220-090 TM Events reporting</text>
      </textAnnotation>
      <textAnnotation id="sid-76C5ED63-B31D-4943-ACA9-A349E596479C" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="24.0" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="true" fill="#ff0000" fontFamily="" fontSize="24.0" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform Process Steward: Kim Moore &lt;kimberly.moore@intel.com&gt;, and BPM Champion: Colleen Bowers &lt;colleen.bowers@intel.com&gt; of any changes that occur within the flow from now onwards so that changes can be accurately reflected within BIC</text>
      </textAnnotation>
   </process>
