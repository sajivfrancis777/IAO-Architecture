      <textAnnotation id="sid-237DB4B7-DC71-4D88-AF55-0C1F06A2FB68" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
