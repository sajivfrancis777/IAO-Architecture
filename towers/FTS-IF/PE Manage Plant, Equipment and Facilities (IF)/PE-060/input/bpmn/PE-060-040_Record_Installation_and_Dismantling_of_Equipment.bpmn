      <textAnnotation id="sid-7C2C40CC-F562-4633-B392-FAF952EDEB6B" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Process Tower: Forecast to Stock (IF)
Process Group: PE-060 Maintain and Manage Master Maintenance Records (IF)
Process: PE-060-040 Record Installation and Dismantling of Equipment</text>
      </textAnnotation>
      <textAnnotation id="sid-09A36C02-34D3-4038-89AC-480B575D0AD4" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-left"/>
            <signavio:signavioLabel bold="" fill="#ff0000" fontFamily="" fontSize="" italic="" ref="text-right"/>
         </extensionElements>
         <text>Flow has been migrated to BIC. Please inform the process steward Marshall, Laura &lt;laura.marshall@intel.com&gt;and BPM Champions D'Elia, Traci &lt;traci.delia@intel.com&gt;of any design changes that occur within the flow moving forward. This will enable us to reflect those changes in the BIC and WIKI business process documentation.</text>
      </textAnnotation>
   </process>
