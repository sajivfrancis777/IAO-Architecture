         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Via planning data hub, updated schedule within frozen Horizon will be published to PDH</text>
      </textAnnotation>
