      <textAnnotation id="sid-C7AC8373-424F-4861-B877-38503129AD25" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>Storage Bin Determination includes Batch-managed , Temperature-controlled  and Hazardous Inventory </text>
      </textAnnotation>
      <textAnnotation id="sid-C8985F25-9C77-4B89-B9D7-71523627B3DA" signavio:alignment="left" textFormat="text/plain">
