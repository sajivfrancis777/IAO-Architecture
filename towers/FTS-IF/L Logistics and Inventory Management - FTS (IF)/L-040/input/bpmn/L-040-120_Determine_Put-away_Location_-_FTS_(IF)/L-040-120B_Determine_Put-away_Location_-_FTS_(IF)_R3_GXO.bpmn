         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>R3 Flow</text>
      </textAnnotation>
      <textAnnotation id="sid-79EF5E24-744E-47EA-950C-6D979BBB61E7" signavio:alignment="left">
         <extensionElements>
            <signavio:signavioDictionaryLink propertyId="name">
