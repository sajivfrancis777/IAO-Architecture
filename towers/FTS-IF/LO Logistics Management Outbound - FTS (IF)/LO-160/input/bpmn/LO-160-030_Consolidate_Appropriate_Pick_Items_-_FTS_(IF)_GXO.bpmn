      <textAnnotation id="sid-F51911E3-9213-45E3-9A58-3868349E27A6" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>
Process Tower: Forecast to Stock
Process Group: LO Logistics Management Outbound
Process Name: LO-160-030 Consolidate Appropriate Pick Items</text>
      </textAnnotation>
      <textAnnotation id="sid-F54DDF69-EBE4-4A98-931B-531616DC4E5E" signavio:alignment="left" textFormat="text/plain">
         <extensionElements>
            <signavio:signavioMetaData metaKey="bordercolor" metaValue="#000000"/>
         </extensionElements>
         <text>The flow is applicable to R3
For Scenarios Stock Transfer Orders (STO), Plant Maintenance Order and Production Order</text>
      </textAnnotation>
   </process>
